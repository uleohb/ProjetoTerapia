@page
@model ProjetoTerapia.Pages.SolicitarDivulgacaoModel

<div class="divulgacao-page">

    <div class="divulgacao-card">

        <img src="/imagem/logo.png" class="logo-divulgacao" />

        <span class="badge">
            Clube de Descontos
        </span>

        <h1>
            Solicitar divulgação regional
        </h1>

        <p class="sub">
            Escolha um plano para sua clínica aparecer em mais cidades e aumentar sua visibilidade para pacientes.
        </p>

        @if (TempData["Sucesso"] != null)
        {
            <div class="alerta-sucesso">
                @TempData["Sucesso"]
            </div>
        }

        @if (TempData["Erro"] != null)
        {
            <div class="alerta-erro">
                @TempData["Erro"]
            </div>
        }

        <form method="post">

            <div class="planos-grid">

                <label class="plano-card">
                    <input type="radio" name="QuantidadeCidades" value="5" required />
                    <span>+5 cidades</span>
                    <strong>R$ 30,00</strong>
                </label>

                <label class="plano-card">
                    <input type="radio" name="QuantidadeCidades" value="10" />
                    <span>+10 cidades</span>
                    <strong>R$ 35,00</strong>
                </label>

                <label class="plano-card">
                    <input type="radio" name="QuantidadeCidades" value="15" />
                    <span>+15 cidades</span>
                    <strong>R$ 45,00</strong>
                </label>

                <label class="plano-card">
                    <input type="radio" name="QuantidadeCidades" value="20" />
                    <span>+20 cidades</span>
                    <strong>R$ 50,00</strong>
                </label>

                <label class="plano-card">
                    <input type="radio" name="QuantidadeCidades" value="25" />
                    <span>+25 cidades</span>
                    <strong>R$ 55,00</strong>
                </label>

            </div>

            <div class="campo">
                <label>Cidades onde deseja aparecer</label>

                <textarea asp-for="CidadesSelecionadas"
                          placeholder="Exemplo: São Paulo, Rio de Janeiro, Belo Horizonte, Curitiba"
                          required></textarea>

                <small>
                    Separe as cidades por vírgula ou escreva uma por linha.
                </small>
            </div>

            <button type="submit" class="btn-principal">
                Enviar solicitação
            </button>

        </form>

        <a href="/PainelClinica" class="btn-voltar">
            Voltar ao painel
        </a>

    </div>

    <div class="historico-card">

        <h2>
            Minhas solicitações
        </h2>

        @if (!Model.MinhasSolicitacoes.Any())
        {
            <p class="vazio">
                Nenhuma solicitação enviada ainda.
            </p>
        }
        else
        {
            <div class="lista-solicitacoes">

                @foreach (var item in Model.MinhasSolicitacoes)
                {
                    <div class="solicitacao-item">

                        <div>
                            <span>@item.NomePlano</span>
                            <strong>R$ @item.Valor</strong>
                            <p>@item.CidadesSelecionadas</p>
                        </div>

                        <div class="status">
                            @item.Status
                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

    * {
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    html,
    body {
        margin: 0;
        padding: 0;
        background: #eaf8ff;
    }

    .container,
    .container-fluid,
    main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
        background: transparent !important;
    }

    .divulgacao-page {
        min-height: 100vh;
        padding: 45px 22px;
        background: radial-gradient(circle at top left, rgba(14,165,233,.20), transparent 34%), radial-gradient(circle at bottom right, rgba(124,58,237,.16), transparent 35%), linear-gradient(135deg,#e0f7ff 0%, #f8fcff 48%, #edf3ff 100%);
        display: grid;
        grid-template-columns: 1.1fr .9fr;
        gap: 26px;
        align-items: start;
    }

    .divulgacao-card,
    .historico-card {
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(226,232,240,.9);
        backdrop-filter: blur(18px);
        border-radius: 34px;
        padding: 34px;
        box-shadow: 0 25px 70px rgba(15,23,42,.10);
    }

    .logo-divulgacao {
        width: 230px;
        display: block;
        margin: 0 auto 10px;
    }

    .badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(14,165,233,.12);
        color: #0369a1;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    h1 {
        margin: 0 0 12px;
        font-size: 36px;
        color: #0f172a;
        letter-spacing: -1px;
    }

    .sub {
        color: #64748b;
        line-height: 1.7;
        margin-bottom: 28px;
    }

    .planos-grid {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: 12px;
        margin-bottom: 24px;
    }

    .plano-card {
        display: block;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 18px;
        cursor: pointer;
        transition: .25s;
    }

        .plano-card:hover {
            transform: translateY(-3px);
            border-color: #0ea5e9;
        }

        .plano-card input {
            margin-bottom: 12px;
        }

        .plano-card span {
            display: block;
            color: #0f172a;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .plano-card strong {
            color: #16a34a;
            font-size: 20px;
        }

    .campo {
        margin-bottom: 22px;
    }

        .campo label {
            display: block;
            color: #334155;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .campo textarea {
            width: 100%;
            min-height: 130px;
            border-radius: 18px;
            border: 1px solid #dbeafe;
            padding: 16px;
            outline: none;
            resize: vertical;
            background: #f8fafc;
        }

            .campo textarea:focus {
                border-color: #0ea5e9;
                background: white;
                box-shadow: 0 0 0 4px rgba(14,165,233,.10);
            }

        .campo small {
            display: block;
            color: #94a3b8;
            margin-top: 8px;
        }

    .btn-principal,
    .btn-voltar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 16px;
        padding: 15px 22px;
        font-weight: 800;
        transition: .25s;
    }

    .btn-principal {
        width: 100%;
        border: none;
        color: white;
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        cursor: pointer;
        font-size: 16px;
    }

    .btn-voltar {
        margin-top: 14px;
        width: 100%;
        color: #0ea5e9;
        background: white;
        border: 1px solid #dbeafe;
    }

    .historico-card h2 {
        margin: 0 0 20px;
        color: #0f172a;
    }

    .lista-solicitacoes {
        display: grid;
        gap: 14px;
    }

    .solicitacao-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 18px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
    }

        .solicitacao-item span {
            color: #0ea5e9;
            font-weight: 800;
            font-size: 13px;
        }

        .solicitacao-item strong {
            display: block;
            margin: 6px 0;
            color: #0f172a;
        }

        .solicitacao-item p {
            margin: 0;
            color: #64748b;
            line-height: 1.5;
        }

    .status {
        align-self: start;
        padding: 8px 12px;
        border-radius: 999px;
        background: #fef3c7;
        color: #92400e;
        font-weight: 800;
        font-size: 12px;
        white-space: nowrap;
    }

    .alerta-sucesso,
    .alerta-erro {
        padding: 14px;
        border-radius: 16px;
        margin-bottom: 18px;
        font-weight: 700;
    }

    .alerta-sucesso {
        background: #dcfce7;
        color: #166534;
    }

    .alerta-erro {
        background: #fee2e2;
        color: #991b1b;
    }

    .vazio {
        color: #64748b;
    }

    @@media(max-width: 1100px) {
        .divulgacao-page {
            grid-template-columns: 1fr;
        }

        .planos-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 650px) {
        .planos-grid {
            grid-template-columns: 1fr;
        }

        h1 {
            font-size: 30px;
        }
    }

</style>