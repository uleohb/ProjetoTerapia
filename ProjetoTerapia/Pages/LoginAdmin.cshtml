@page
@model ProjetoTerapia.Pages.LoginAdminModel

<div class="admin-login-page">

    <div class="login-bg bg-1"></div>
    <div class="login-bg bg-2"></div>

    <div class="login-admin-card">

        <div class="logo-area-admin">
            <img src="/imagem/logo.png" alt="AlinhaMente" />
        </div>

        <span class="badge-admin-login">
            Acesso administrativo
        </span>

        <h1>
            Painel Administrativo
        </h1>

        <p class="sub-login">
            Entre com suas credenciais para gerenciar profissionais,
            pagamentos, cadastros e divulgações da plataforma.
        </p>

        @if (Model.Erro)
        {
            <div class="erro">
                Usuário ou senha incorretos.
            </div>
        }

        <form method="post">

            <div class="campo-login">
                <label>Usuário</label>

                <input type="text"
                       asp-for="Usuario"
                       placeholder="Digite seu usuário"
                       required />
            </div>

            <div class="campo-login">
                <label>Senha</label>

                <input type="password"
                       asp-for="SenhaHash"
                       placeholder="Digite sua senha"
                       required />
            </div>

            <button type="submit" class="btn-entrar-admin">
                Entrar no painel
            </button>

        </form>

        <a href="/Teste" class="voltar-site">
            Voltar para o site
        </a>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

    * {
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    html,
    body {
        margin: 0;
        padding: 0;
        background: #eaf8ff;
    }

    .container,
    .container-fluid,
    main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
        background: transparent !important;
    }

    .admin-login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        position: relative;
        overflow: hidden;
        background: radial-gradient(circle at top left, rgba(14,165,233,.20), transparent 34%), radial-gradient(circle at bottom right, rgba(124,58,237,.16), transparent 35%), linear-gradient(135deg,#e0f7ff 0%, #f8fcff 48%, #edf3ff 100%);
    }

    .login-bg {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        pointer-events: none;
    }

    .bg-1 {
        width: 340px;
        height: 340px;
        background: rgba(14,165,233,.22);
        top: -120px;
        left: -100px;
    }

    .bg-2 {
        width: 320px;
        height: 320px;
        background: rgba(124,58,237,.18);
        bottom: -120px;
        right: -100px;
    }

    .login-admin-card {
        width: 100%;
        max-width: 470px;
        position: relative;
        z-index: 2;
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(226,232,240,.9);
        backdrop-filter: blur(18px);
        border-radius: 32px;
        padding: 38px;
        box-shadow: 0 25px 70px rgba(15,23,42,.10);
        text-align: center;
    }

    .logo-area-admin img {
        width: 240px;
        max-width: 100%;
        height: auto;
        object-fit: contain;
        margin-bottom: 8px;
    }

    .badge-admin-login {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(14,165,233,.12);
        color: #0369a1;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 18px;
    }

    .login-admin-card h1 {
        margin: 0 0 12px;
        font-size: 34px;
        line-height: 1.1;
        letter-spacing: -1px;
        color: #0f172a;
    }

    .sub-login {
        color: #64748b;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 28px;
    }

    .campo-login {
        text-align: left;
        margin-bottom: 16px;
    }

        .campo-login label {
            display: block;
            color: #334155;
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .campo-login input {
            width: 100%;
            padding: 15px 16px;
            border-radius: 16px;
            border: 1px solid #dbeafe;
            background: #f8fafc;
            color: #0f172a;
            outline: none;
            font-size: 15px;
            transition: .25s;
        }

            .campo-login input:focus {
                border-color: #0ea5e9;
                background: white;
                box-shadow: 0 0 0 4px rgba(14,165,233,.11);
            }

    .btn-entrar-admin {
        width: 100%;
        border: none;
        border-radius: 16px;
        padding: 16px;
        margin-top: 6px;
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        color: white;
        font-weight: 800;
        font-size: 16px;
        cursor: pointer;
        transition: .25s;
        box-shadow: 0 14px 28px rgba(14,165,233,.18);
    }

        .btn-entrar-admin:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(14,165,233,.24);
        }

    .voltar-site {
        display: inline-block;
        margin-top: 22px;
        color: #0ea5e9;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
    }

    .erro {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        padding: 14px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 700;
    }

    @@media(max-width: 600px) {
        .login-admin-card {
            padding: 28px 22px;
            border-radius: 26px;
        }

        .logo-area-admin img {
            width: 210px;
        }

        .login-admin-card h1 {
            font-size: 28px;
        }
    }

</style>