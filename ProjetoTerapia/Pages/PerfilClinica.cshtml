@page
@model ProjetoTerapia.Pages.PerfilClinicaModel

<div class="perfil-page">

    <!-- HERO -->

    <div class="hero-perfil">

        <div class="hero-overlay"></div>

        <div class="hero-content">

            <div class="avatar-perfil">

                @if (!string.IsNullOrEmpty(Model.Clinica.FotoPerfil))
                {
                    <img src="@Model.Clinica.FotoPerfil"
                    style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                }
                else
                {
                    @(string.IsNullOrEmpty(Model.Clinica.Nome)
                                    ? "C"
                                    : Model.Clinica.Nome.Substring(0, 1).ToUpper())
                }

            </div>

            <div class="hero-info">

                <span class="badge-top">
                    Perfil Profissional
                </span>

                <h1>
                    @Model.Clinica.Nome
                </h1>

                <div class="linha-badges">

                    @if (Model.Clinica.AtendimentoOnline)
                    {
                        <span class="badge-info online">
                            💻 Online
                        </span>
                    }

                    @if (Model.Clinica.AtendimentoPresencial)
                    {
                        <span class="badge-info presencial">
                            🏥 Presencial
                        </span>
                    }

                    <span class="badge-info aprovado">
                        ✔ Verificado
                    </span>

                </div>

                <p class="descricao-hero">
                    (@Model.Clinica.Descricao.Length ?? 0) caracteres
                </p>

            </div>

        </div>

    </div>

    <!-- CONTEÚDO -->

    <div class="conteudo-perfil">

        <!-- ESQUERDA -->

        <div class="perfil-main">

            <!-- ESPECIALIDADES -->

            <div class="card-perfil">

                <h3>Especialidades</h3>

                <div class="especialidades-lista">

                    @foreach (var esp in Model.ListaEspecialidades)
                    {
                        <span class="tag-especialidade">
                            @esp
                        </span>
                    }

                </div>

            </div>

            <!-- SOBRE -->

            <div class="card-perfil">

                <h3>Sobre o profissional</h3>

                <p class="texto-sobre">
                    @Model.Clinica.Descricao
                </p>

            </div>

            <!-- LOCALIZAÇÃO -->

            <div class="card-perfil">

                <h3>Localização</h3>

                <p class="info-texto">
                    📍 @Model.Clinica.Endereco
                </p>

            </div>

        </div>

        <!-- DIREITA -->

        <aside class="perfil-side">

            <!-- VALOR -->

            <div class="card-side destaque">

                <span>Consulta inicial</span>

                <h2>
                    R$ @Model.Clinica.Valor
                </h2>

            </div>

            <!-- CONTATO -->

            <div class="card-side">

                <h3>Contato</h3>

                <p>
                    📞 @Model.Clinica.Telefone
                </p>

                @if (!string.IsNullOrEmpty(Model.Clinica.Telefone))
                {
                    <a href="https://wa.me/@(Model.Clinica.Telefone)"
                       target="_blank"
                       class="btn-whatsapp">

                        Falar no WhatsApp

                    </a>
                }

            </div>

            <!-- REDES -->

            <div class="card-side">

                <h3>Redes Sociais</h3>

                <div class="redes-grid">

                    @if (!string.IsNullOrEmpty(Model.Clinica.Instagram))
                    {
                        <a href="@Model.Clinica.Instagram"
                           target="_blank"
                           class="rede insta">

                            Instagram

                        </a>
                    }

                    @if (!string.IsNullOrEmpty(Model.Clinica.Site))
                    {
                        <a href="@Model.Clinica.Site"
                           target="_blank"
                           class="rede site">

                            Site

                        </a>
                    }

                </div>

            </div>

            <!-- STATS -->

            <div class="card-side">

                <h3>Estatísticas</h3>

                <div class="stats-grid">

                    <div class="stat-box">
                        <strong>
                            @Model.Clinica.Visualizacoes
                        </strong>

                        <span>
                            Visualizações
                        </span>
                    </div>

                    <div class="stat-box">
                        <strong>
                            @Model.Clinica.CliquesWhatsapp
                        </strong>

                        <span>
                            Cliques WhatsApp
                        </span>
                    </div>

                </div>

            </div>

            <a href="/CadastroClinica"
               class="btn-editar">

                Editar Perfil

            </a>

        </aside>

    </div>

</div>

<style>

    body {
        margin: 0;
        background: #f8fafc;
        font-family: 'Segoe UI', sans-serif;
    }

    .perfil-page {
        min-height: 100vh;
    }

    /* HERO */

    .hero-perfil {
        position: relative;
        padding: 55px 60px;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(255,255,255,.15), transparent 30%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        gap: 30px;
        align-items: center;
        max-width: 1200px;
        margin: auto;
    }

    .avatar-perfil {
        width: 105px;
        height: 105px;
        border-radius: 50%;
        background: rgba(255,255,255,.2);
        backdrop-filter: blur(10px);
        border: 4px solid rgba(255,255,255,.3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 40px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .hero-info h1 {
        margin: 10px 0;
        font-size: 28px;
        font-weight: 600;
        letter-spacing: -1px;
        color: white;
    }

    .badge-top {
        background: rgba(255,255,255,.15);
        color: white;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .linha-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 18px 0;
    }

    .badge-info {
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .online {
        background: rgba(14,165,233,.18);
        color: white;
    }

    .presencial {
        background: rgba(255,255,255,.15);
        color: white;
    }

    .aprovado {
        background: rgba(34,197,94,.18);
        color: white;
    }

    .descricao-hero {
        color: rgba(255,255,255,.78);
        line-height: 1.7;
        max-width: 620px;
        font-size: 14px;
        font-weight: 400;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    /* CONTEÚDO */

    .conteudo-perfil {
        max-width: 1200px;
        margin: -50px auto 50px;
        position: relative;
        z-index: 10;
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 30px;
        padding: 0 25px;
    }

    /* CARDS */

    .card-perfil,
    .card-side {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
    }

        .card-perfil h3,
        .card-side h3 {
            margin-top: 0;
            margin-bottom: 18px;
            color: #0f172a;
            font-size: 16px;
            font-weight: 600;
        }

    /* TAGS */

    .especialidades-lista {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .tag-especialidade {
        background: #dbeafe;
        color: #2563eb;
        padding: 10px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    /* TEXTO */

    .texto-sobre,
    .info-texto {
        color: #475569;
        line-height: 1.7;
        max-width: 620px;
        font-size: 14px;
        font-weight: 400;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    /* SIDE */

    .destaque {
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
    }

        .destaque span {
            opacity: .85;
        }

        .destaque h2 {
            font-size: 32px;
            font-weight: 700;
        }

    /* BOTÕES */

    .btn-whatsapp,
    .btn-editar {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 16px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
        transition: .25s;
    }

    .btn-whatsapp {
        background: #25D366;
        color: white;
        margin-top: 18px;
    }

    .btn-editar {
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
    }

        .btn-whatsapp:hover,
        .btn-editar:hover {
            transform: translateY(-3px);
        }

    /* REDES */

    .redes-grid {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .rede {
        flex: 1;
        text-align: center;
        padding: 14px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
    }

    .insta {
        background: #fdf2f8;
        color: #be185d;
    }

    .site {
        background: #eff6ff;
        color: #2563eb;
    }

    /* STATS */

    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .stat-box {
        background: #f8fafc;
        border-radius: 18px;
        padding: 20px;
        text-align: center;
    }

        .stat-box strong {
            display: block;
            font-size: 24px;
            color: #0f172a;
        }

        .stat-box span {
            color: #64748b;
            font-size: 13px;
        }

    /* RESPONSIVO */

    @@media(max-width:900px) {

        .hero-content {
            flex-direction: column;
            text-align: center;
        }

        .conteudo-perfil {
            grid-template-columns: 1fr;
        }

        .hero-perfil {
            padding: 50px 25px 90px;
        }

        .hero-info h1 {
            font-size: 32px;
        }
    }

</style>