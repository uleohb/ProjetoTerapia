@page
@model ProjetoTerapia.Pages.CadastroClinicaModel

<div class="topo-perfil">

    <img src="/imagem/logo.png"
         class="logo-perfil" />

    <div>

        <span class="badge-perfil">
            Perfil Profissional
        </span>

        <h1>Meu Perfil Profissional</h1>

        <p>
            Atualize suas informações profissionais,
            especialidades e formas de atendimento.
        </p>

    </div>

</div>

<div class="foto-clinica">

    <div class="perfil-dashboard">

        <div class="perfil-card">

            <div class="avatar-clinica">

                @if (!string.IsNullOrEmpty(Model.NovaClinica.FotoPerfil))
                {
                    <img src="@Model.NovaClinica.FotoPerfil" />
                }
                else
                {
                 @(string.IsNullOrEmpty(Model.NovaClinica.Nome)
                                    ? "A"
                                    : Model.NovaClinica.Nome.Substring(0, 1).ToUpper())
                }

                <label for="foto-upload" class="editar-avatar">
                    <i class="fa-solid fa-pen"></i>
                </label>

            </div>

            <div class="perfil-info">

                <h3>
                    @(string.IsNullOrEmpty(Model.NovaClinica.Nome)
                                        ? "Perfil Profissional"
                                        : Model.NovaClinica.Nome)
                </h3>

                <span>
                    @(Model.NovaClinica.Aprovado
                                        ? "Perfil Aprovado"
                                        : "Aguardando Aprovação")
                </span>

            </div>

        </div>

        <div class="stats-card">

            <div class="stat-item">
                <span>Plano</span>

                <strong class="@(Model.NovaClinica.Pago ? "plano-ativo" : "plano-pendente")">
                    @(Model.NovaClinica.Pago ? "Profissional" : "Pendente")
                </strong>
            </div>

            <div class="stat-item">
                <span>Início</span>
                <strong>
                    @(Model.NovaClinica.DataPagamento?.ToString("dd/MM/yyyy")
                                        ?? "--/--/----")
                </strong>
            </div>

            <div class="stat-item">
                <span>Vencimento</span>
                <strong>
                    @(Model.NovaClinica.DataVencimento?.ToString("dd/MM/yyyy")
                                        ?? "--/--/----")
                </strong>
            </div>

        </div>

    </div>

</div>

<div class="container-cadastro">

    <div class="card-cadastro">

        @if (TempData["Sucesso"] != null)
        {
            <div class="alerta-sucesso">
                @TempData["Sucesso"]
            </div>
        }

        <h3>Cadastro Profissional</h3>

        <p class="subtexto">
            Preencha suas informações para análise e aprovação da plataforma.
        </p>

        <form method="post" enctype="multipart/form-data">

            <input type="file"
                   id="foto-upload"
                   name="FotoUpload"
                   accept="image/*"
                   style="display:none;" />

            <div class="campo">
                <label>Nome da clínica ou profissional</label>
                <input type="text"
                       asp-for="NovaClinica.Nome"
                       required />
            </div>

            <div class="campo">
                <label>Descrição profissional</label>

                <textarea asp-for="NovaClinica.Descricao"
                          maxlength="1000"
                          required></textarea>

                <small>Máximo de 1000 caracteres</small>
            </div>

            <div class="campo">
                <label>CEP</label>
                <input type="text" id="cep" asp-for="NovaClinica.CEP" required />
            </div>

            <div class="campo">
                <label>Endereço</label>
                <input type="text"
                       asp-for="NovaClinica.Endereco"
                       required />
            </div>

            <div class="campo">
                <label>Telefone / WhatsApp</label>
                <input type="text"
                       asp-for="NovaClinica.Telefone"
                       required />
            </div>

            <div class="campo">
                <label>
                    Instagram
                    <span class="opcional">(opcional)</span>
                </label>
                <input type="text"
                       asp-for="NovaClinica.Instagram"
                       placeholder="@@usuario ou link completo" />
            </div>

            <div class="campo">
                <label>
                    Site/Portifólio
                    <span class="opcional">(opcional)</span>
                </label>
                <input type="text"
                       asp-for="NovaClinica.Site"
                       placeholder="https://..." />
            </div>

            <div class="campo">
                <label>Registro profissional (CRP, CRM...)</label>
                <input asp-for="NovaClinica.Documento" />
            </div>

            <div class="campo">
                <label>CPF</label>
                <input type="text" asp-for="NovaClinica.CPF" required />
            </div>

            <div class="campo">
                <label>Especialidades</label>

                <label class="checkbox-item">
                    <input type="checkbox"
                           name="Especialidades"
                           value="Ansiedade"
                           @(Model.EspecialidadesSelecionadas.Contains("Ansiedade") ? "checked" : "") />
                    <span>Ansiedade</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox"
                           name="Especialidades"
                           value="Depressão"
                           @(Model.EspecialidadesSelecionadas.Contains("Depressão") ? "checked" : "") />
                    <span>Depressão</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox"
                           name="Especialidades"
                           value="Infantil"
                           @(Model.EspecialidadesSelecionadas.Contains("Infantil") ? "checked" : "") />
                    <span>Infantil</span>
                </label>
            </div>

            <div class="campo">
                <label>Tipo de atendimento</label>
                <div class="checkbox-group">
                    <label class="checkbox-item">
                        <input asp-for="NovaClinica.AtendimentoPresencial" />
                        <span>Presencial</span>
                    </label>

                    <label class="checkbox-item">
                        <input asp-for="NovaClinica.AtendimentoOnline" />
                        <span>Online</span>
                    </label>
                </div>
            </div>

            <div class="campo">
                <label>Valor da consulta inicial (R$)</label>
                <input type="number"
                       asp-for="NovaClinica.Valor"
                       required />
            </div>

            <div asp-validation-summary="All" style="color:red;"></div>

            <button class="btn-cadastrar">
                Enviar para Análise
            </button>

            <div class="alerta-info">
                Após o envio, nossa equipe realizará a análise das informações cadastradas.
                Após a aprovação e confirmação do plano, seu perfil será disponibilizado para os pacientes na plataforma.
            </div>


        </form>

    </div>

</div>

<style>

    body {
        background: radial-gradient( circle at top, rgba(0,194,255,.08), transparent 40% ), #f8fafc; 
    }

    .topo-cadastro {
        text-align: center;
        padding: 60px 20px 30px;
        background: linear-gradient(135deg, #00c6ff, #009ee3);
        color: white;
        border-radius: 0 0 30px 30px;
    }

        .topo-cadastro h1 {
            font-size: 42px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .topo-cadastro h2 {
            font-size: 30px;
            margin-bottom: 15px;
        }

        .topo-cadastro p {
            font-size: 18px;
            max-width: 700px;
            margin: auto;
            opacity: 0.95;
        }

    .container-cadastro {
        max-width: 850px;
        margin: 10px auto 40px;
        padding: 20px;
    }

    .card-cadastro {
        background: white;
        padding: 35px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

        .card-cadastro h3 {
            font-size: 28px;
            margin-bottom: 10px;
            color: #0f172a;
        }

    .subtexto {
        color: #64748b;
        margin-bottom: 30px;
    }

    .campo {
        margin-bottom: 22px;
    }

        .campo label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #334155;
        }

        .campo input,
        .campo textarea {
            width: 100%;
            padding: 15px;
            border: 1px solid #dbeafe;
            border-radius: 14px;
            font-size: 15px;
            outline: none;
            transition: 0.2s;
        }

        .campo textarea {
            min-height: 130px;
            resize: vertical;
        }

            .campo input:focus,
            .campo textarea:focus {
                border-color: #009ee3;
                box-shadow: 0 0 0 4px rgba(0, 158, 227, 0.08);
            }

    .btn-cadastrar {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 14px;
        background: linear-gradient( 135deg, #00c2ff, #00a3ff );
        color: white;
        font-size: 17px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-cadastrar:hover {
            transform: scale(1.01);
        }

    .alerta-info {
        margin-top: 20px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        padding: 18px;
        border-radius: 14px;
        color: #1e3a8a;
        font-size: 14px;
    }

    .checkbox-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
        cursor: pointer;
    }

        .checkbox-item input {
            width: 18px;
            height: 18px;
        }

    .topo-perfil {
        max-width: 1100px;
        margin: 40px auto 20px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

        .topo-perfil h1 {
            font-size: 42px;
            font-weight: 700;
            background: linear-gradient( 135deg, #2563eb, #0ea5e9 );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .logo-perfil {
        width: 340px;
        margin-bottom: 10px;
    }

    .badge-perfil {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 14px;
        border-radius: 999px;
        background: linear-gradient( 135deg, rgba(0,194,255,.18), rgba(99,102,241,.18) );
        color: #2563eb;
        border: 1px solid rgba(0,194,255,.30);
        box-shadow: 0 0 15px rgba(0,194,255,.12);
        font-size: 11px;
        font-weight: 700;
    }

    .topo-perfil p {
        color: #64748b;
        max-width: 700px;
        font-size: 18px;
        line-height: 1.7;
        margin: 0 auto;
    }

    .foto-clinica {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 35px;
    }

    .avatar-clinica {
        position: relative;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 34px;
        font-weight: 700;
        flex-shrink: 0;
    }

        .avatar-clinica img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

    .editar-avatar {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #ffffff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 3px solid white;
        box-shadow: 0 8px 18px rgba(0,0,0,.18);
        z-index: 10;
        transition: .25s;
    }

        .editar-avatar:hover {
            transform: scale(1.12);
        }

    .btn-logo {
        border: none;
        padding: 12px 18px;
        border-radius: 12px;
        background: rgba(37,99,235,.08);
        color: #2563eb;
        cursor: pointer;
    }

    .btn-salvar {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 16px;
        background: linear-gradient( 135deg, #2563eb, #3b82f6 );
        color: white;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
    }

        .btn-salvar:hover {
            transform: translateY(-2px);
        }

    .perfil-dashboard {
        max-width: 1100px;
        margin: 25px auto 25px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .perfil-card {
        background: white;
        border-radius: 24px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 20px 40px rgba(15,23,42,.06);
        border: 1px solid #edf2f7;
    }

    .perfil-info h3 {
        font-size: 18px;
        font-weight: 600;
    }

    .perfil-info span {
        color: #64748b;
        font-size: 14px;
    }

    .stats-card {
        background: white;
        border-radius: 24px;
        padding: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 20px 40px rgba(15,23,42,.06);
        border: 1px solid #edf2f7;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
    }

        .stat-item span {
            color: #94a3b8;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .stat-item strong {
            color: #0f172a;
            font-size: 18px;
        }

   

    @@media(max-width:900px) {

        .perfil-dashboard {
            grid-template-columns: 1fr;
        }

        .stats-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
    }

    .plano-ativo {
        color: #16a34a;
        font-weight: 700;
    }

    .plano-pendente {
        color: #f59e0b;
        font-weight: 700;
    }

    @@media(max-width:768px) {

        .topo-perfil h1 {
            font-size: 32px;
        }

        .topo-perfil p {
            font-size: 15px;
            padding: 0 15px;
        }

        .perfil-card {
            flex-direction: column;
            text-align: center;
        }

        .avatar-clinica {
            width: 75px;
            height: 75px;
            font-size: 28px;
        }

        .card-cadastro {
            padding: 20px;
        }

        .campo input,
        .campo textarea {
            width: 100%;
            box-sizing: border-box;
        }

        .stats-card {
            gap: 15px;
        }

        .btn-cadastrar {
            font-size: 16px;
        }
    }

    .alerta-sucesso {
        background: #dcfce7;
        color: #166534;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
        animation: fadeOut 5s forwards;
    }

    @@keyframes fadeOut {
        0%

    {
        opacity: 1;
    }

    80% {
        opacity: 1;
    }

    100% {
        opacity: 0;
    }

    }

    .opcional {
        color: #94a3b8;
        font-size: 12px;
        font-weight: 400;
    }

</style>

@* preenche o endereço com base no CEP *@
<script>
    document.getElementById("cep").addEventListener("blur", function () {

        let cep = this.value.replace(/\D/g, '');

        if (cep.length === 8) {

            fetch(`https://viacep.com.br/ws/${cep}/json/`)
                .then(res => res.json())
                .then(data => {

                    if (!data.erro) {

                        document.querySelector("[name='NovaClinica.Endereco']")
                            .value = data.logradouro + ", " + data.bairro + " - " + data.localidade;

                    }

                });
        }

    });    

    document.getElementById("foto-upload")
    .addEventListener("change", function(e) {

        const file = e.target.files[0];

        if (!file)
            return;

            console.log("arquivo selecionado:", file.name);

        const reader = new FileReader();

        reader.onload = function(ev) {

            console.log("imagem carregada");

            let avatar = document.querySelector(".avatar-clinica img");

            if (avatar) {
                avatar.src = ev.target.result;
            }
            else {

                document.querySelector(".avatar-clinica").innerHTML =
                    `<img src="${ev.target.result}" />
                     <label for="foto-upload" class="editar-avatar">
                        <i class="fa-solid fa-pen"></i>
                     </label>`;
            }
        };

        reader.readAsDataURL(file);
    });

</script>

