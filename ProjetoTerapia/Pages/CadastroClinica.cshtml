<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

<script>

    document.addEventListener("DOMContentLoaded", function () {


        // =====================
        // CEP
        // =====================

        const cep = document.getElementById("cep");

        if(cep){

            cep.addEventListener("blur", function(){

                let valor = this.value.replace(/\D/g,'');

                if(valor.length === 8){

                    fetch(`https://viacep.com.br/ws/${valor}/json/`)
                    .then(res => res.json())
                    .then(data => {

                        if(!data.erro){

                            document.querySelector("[name='NovaClinica.Endereco']")
                            .value =
                            data.logradouro + ", " +
                            data.bairro + " - " +
                            data.localidade;

                        }

                    });

                }

            });

        }



        // =====================
        // FOTO CROP
        // =====================


        let cropper = null;


        const inputFoto = document.getElementById("foto-upload");
        const imagemCrop = document.getElementById("imagemCrop");
        const modal = document.getElementById("modalFoto");
        const confirmar = document.getElementById("confirmarFoto");


        if(inputFoto){


            inputFoto.addEventListener("change", function(e){


                let arquivo = e.target.files[0];


                if(!arquivo)
                    return;



                let reader = new FileReader();


                reader.onload = function(event){


                    imagemCrop.src = event.target.result;


                    modal.style.display = "flex";


                    if(cropper)
                        cropper.destroy();



                    cropper = new Cropper(imagemCrop, {


                        aspectRatio:1,

                        viewMode:1,

                        dragMode:"move",

                        autoCropArea:1,

                        zoomable:true,

                        rotatable:true,

                        scalable:true


                    });


                }



                reader.readAsDataURL(arquivo);



            });


        }



        if(confirmar){


            confirmar.addEventListener("click", function(){



                if(!cropper)
                    return;



                let canvas = cropper.getCroppedCanvas({

                    width:500,
                    height:500

                });



                let imagem = canvas.toDataURL("image/jpeg");



                document.getElementById("fotoFinal").value = imagem;



                document.querySelector(".avatar-clinica").innerHTML =

                `
                <img src="${imagem}" />

                <label for="foto-upload" class="editar-avatar">
                    <i class="fa-solid fa-pen"></i>
                </label>
                `;



                modal.style.display="none";


            });


        }




        // =====================
        // VALOR DINHEIRO
        // =====================


        const valorInput = document.getElementById("valorConsulta");


        if(valorInput){


            valorInput.addEventListener("input", function(){


                let valor = this.value.replace(/\D/g,'');



                if(!valor){

                    this.value="";
                    return;

                }



                valor = (valor / 100).toFixed(2);


                valor = valor.replace(".",",");



                valor = valor.replace(
                    /\B(?=(\d{3})+(?!\d))/g,
                    "."
                );



                this.value = valor;



            });


        }



    });


</script>

