@page
@model ProjetoTerapia.Pages.NovaConsultaModel

<div class="container-consulta">

    <div class="logo-central">
        <img src="/imagem/logo.png" alt="Logo" />
    </div>

    <div class="topo">

        <div>
            <span class="badge">
                Agenda Profissional
            </span>

            <h1>Nova Consulta</h1>

            <p>
                Cadastre um novo atendimento para sua agenda.
            </p>
        </div>

        <a href="/AgendaClinica" class="btn-voltar">
            Voltar
        </a>

    </div>

    <div class="card-formulario">

        <form method="post">

            <div asp-validation-summary="All" class="erro-validacao"></div>

            <div class="grupo">

                <label>Nome do Paciente</label>

                <input asp-for="Consulta.NomePaciente"
                       class="input-custom" />

                <span asp-validation-for="Consulta.NomePaciente"
                      class="campo-erro"></span>

            </div>

            <div class="grupo">

                <label>Tipo de Atendimento</label>

                <select asp-for="Consulta.TipoAtendimento"
                        class="input-custom">

                    <option value="">Selecione...</option>
                    <option>Online</option>
                    <option>Presencial</option>

                </select>

                <span asp-validation-for="Consulta.TipoAtendimento"
                      class="campo-erro"></span>

            </div>

            <div class="grupo">

                <label>Data da Consulta</label>

                <input asp-for="Consulta.DataConsulta"
                       type="datetime-local"
                       class="input-custom" />

                <span asp-validation-for="Consulta.DataConsulta"
                      class="campo-erro"></span>

            </div>

            <div class="grupo">

                <label>Status</label>

                <select asp-for="Consulta.Status"
                        class="input-custom">

                    <option>Pendente</option>
                    <option>Confirmado</option>
                    <option>Cancelado</option>

                </select>

            </div>

            <button type="submit"
                    class="btn-salvar">

                Salvar Consulta

            </button>

        </form>

    </div>

</div>

<style>

    body {
        background: #f8fafc;
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .container-consulta {
        max-width: 900px;
        margin: auto;
        padding: 50px 25px;
    }

    .topo {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 35px;
        gap: 20px;
        flex-wrap: wrap;
    }

    .badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(37,99,235,.08);
        color: #2563eb;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .topo h1 {
        margin: 0 0 10px;
        color: #0f172a;
    }

    .topo p {
        margin: 0;
        color: #64748b;
    }

    .btn-voltar {
        text-decoration: none;
        padding: 14px 20px;
        border-radius: 14px;
        background: white;
        border: 1px solid #dbeafe;
        color: #2563eb;
        font-weight: 600;
    }

    .card-formulario {
        background: white;
        padding: 35px;
        border-radius: 28px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15,23,42,.05);
    }

    .grupo {
        margin-bottom: 22px;
    }

        .grupo label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #334155;
        }

    .input-custom {
        width: 100%;
        padding: 15px;
        border-radius: 14px;
        border: 1px solid #cbd5e1;
        font-size: 15px;
        box-sizing: border-box;
    }

    .btn-salvar {
        border: none;
        padding: 16px 24px;
        border-radius: 16px;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        font-weight: 700;
        cursor: pointer;
        width: 100%;
    }

    .erro-validacao {
        color: #dc2626;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .campo-erro {
        display: block;
        margin-top: 6px;
        color: #dc2626;
        font-size: 13px;
        font-weight: 600;
    }

    .logo-central {
        text-align: center;
        margin-bottom: 35px;
    }

        .logo-central img {
            width: 220px;
            padding: 18px 25px;
            background: white;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(15,23,42,.06);
        }

</style>