@page
@model ProjetoTerapia.Pages.TesteModel

<div class="topo-site">

    <h1 class="logo">Ponto Saúde</h1>

    <h2 class="frase-impacto">
        Sua saúde emocional merece atenção
    </h2>

    <p class="sub-frase">
        Em 1 minuto, saiba como você está e receba recomendações personalizadas
    </p>

    <div class="acoes-iniciais">

        <button type="button" onclick="iniciarTeste()" class="btn-principal">
            Começar teste gratuito
        </button>

        <a href="/CadastroClinica" class="btn-clinica">
            Sou profissional / clínica
        </a>

    </div>

</div>

<div id="perguntas">

<!-- TELA INICIAL -->

    <div id="tituloPerguntas" class="titulo-perguntas" style="display:none">
        <h2>Teste de Bem-Estar Emocional</h2>
        <p>Responda com sinceridade para uma recomendação mais precisa</p>
    </div>

<!-- CONTADOR -->
<div class="text-center mb-3" id="topoTeste" style="display:none">
    <span id="contador"></span>
</div>

<!-- BARRA -->
<div class="progress mb-4" id="barraContainer" style="display:none">
    <div id="barra" class="progress-bar" style="width:0%"></div>
</div>

<!-- FORM -->
<form method="post" id="formTeste" style="display:none">

    @for (int i = 0; i < Model.Perguntas.Count; i++)
    {
            <div class="pergunta" style="display:none">
                <div class="card-pergunta">

                    <h3 class="texto-pergunta">
                        @Model.Perguntas[i].Texto
                    </h3>

                    <div class="opcoes-resposta">

                        <label class="opcao-radio">
                            <input type="radio" name="Respostas[@i]" value="true" required />
                            <span>Sim</span>
                        </label>

                        <label class="opcao-radio">
                            <input type="radio" name="Respostas[@i]" value="false" required />
                            <span>Não</span>
                        </label>

                    </div>

                </div>
            </div>
    }

        <div class="acoes-pergunta">

            <button type="button"
                    id="btnVoltar"
                    class="btn-voltar"
                    onclick="voltar()">
                ← Voltar
            </button>

            <button type="button" class="btn-proximo" onclick="proximo()">
                Próximo →
            </button>

            <button type="button"
                    id="finalizar"
                    class="btn-finalizar"
                    style="display:none"
                    onclick="finalizarTeste()">
                Finalizar teste
            </button>

        </div>

 </form>

<!-- BOTÃO RESULTADO -->
    <div id="revelarResultado" class="bloco-resultado" style="display:none">

        <div class="card-revelar-resultado">

            <div class="icone-resultado">
                ✓
            </div>

            <h2>
                Sua análise está pronta
            </h2>

            <p>
                Identificamos sinais importantes sobre seu bem-estar emocional.
                Seu resultado pode ajudar você a entender melhor seu momento atual
                e mostrar o melhor próximo passo.
            </p>

            <button type = "button" class="btn-ver-resultado" onclick="enviarFormulario()">
                Ver meu resultado agora
            </button>

            <span class="texto-seguro">
                100% gratuito • confidencial • sem compromisso
            </span>

        </div>

    </div>

<!-- RESULTADO -->
    @if (Model.MostrarResultado)
    {
        <div id="resultadoFinal" class="container-resultado mt-4">

            <h2 class="titulo-resultado">
                Sua Análise de Bem-Estar Emocional
            </h2>

            <!-- SCORE PRINCIPAL -->
            <div class="card-score">

                <p class="score-label">
                    Seu nível de atenção emocional
                </p>

                <div class="score-valor">
                    @(Model.PorcentagemAnsiedade + Model.PorcentagemDepressao)%
                </div>

                <p class="score-sub">
                    Quanto antes você buscar apoio,
                    mais rápido pode melhorar seu bem-estar.
                </p>

            </div>

            <!-- CARD PRINCIPAL PREMIUM -->
            <div class="card-resultado-premium">

                <span class="badge-nivel
                    @(Model.Nivel == "Alto" ? "alto" :
                                        Model.Nivel == "Moderado" ? "moderado" : "baixo")">

                    @(Model.Nivel == "Alto" ? "🔴 Alto" :
                                    Model.Nivel == "Moderado" ? "🟡 Moderado" : "🟢 Leve")

            </span>

                <h3 class="mt-4">
                    @Model.Mensagem
                </h3>

                <p class="recomendacao-personalizada">
                    Identificamos sinais importantes no seu bem-estar emocional.
                    Com acompanhamento adequado, é possível melhorar sua qualidade
                    de vida e recuperar seu equilíbrio emocional.
                </p>

            </div>

            <!-- DASHBOARD -->
            <div class="card-graficos">

                <div class="grafico-item">

                    <h4>Ansiedade Emocional</h4>

                    <p>
                        Seu nível está em
                        <strong>@Model.PorcentagemAnsiedade%</strong>
                    </p>

                    <div class="progress">
                        <div class="progress-bar barra-ansiedade"
                             style="width:@Model.PorcentagemAnsiedade%">
                        </div>
                    </div>

                </div>

                <div class="grafico-item">

                    <h4>Saúde Emocional</h4>

                    <p>
                        Seu nível está em
                        <strong>@Model.PorcentagemDepressao%</strong>
                    </p>

                    <div class="progress">
                        <div class="progress-bar barra-depressao"
                             style="width:@Model.PorcentagemDepressao%">
                        </div>
                    </div>

                </div>

            </div>

            <!-- RECOMENDAÇÃO -->
            <div class="card-recomendacao">

                <h3>
                    Nossa recomendação para você
                </h3>

                <p>
                    Com base nas suas respostas, recomendamos:
                </p>

                <ul class="lista-recomendacao">
                    <li>Terapia individual com especialista</li>
                    <li>Avaliação inicial do seu bem-estar emocional</li>
                    <li>Orientação profissional personalizada para seu momento atual</li>
                </ul>

            </div>

            <!-- PROVA SOCIAL -->
            <div class="prova-social">

                <p>
                    
                </p>

            </div>

            <!-- CTA FINAL -->
            <div class="cta-final">

                <h3>
                    Quero falar com um especialista agora
                </h3>

                <p>
                    Temos profissionais disponíveis para te ajudar imediatamente.
                </p>

                <a href="/Clinicas" class="btn-especialista">
                    Encontrar ajuda profissional
                </a>

                <div class="cta-secundario">
                    <a href="/Teste">Refazer teste</a>
                    <span>•</span>
                    <a href="/Contato">Falar com suporte</a>
                </div>
            </div>

        </div>

        }


    <div id="loading" class="text-center mt-5" style="display:none">

        <h3>Analisando suas respostas...</h3>

        <div class="spinner mt-3"></div>

    </div>

</div>

<!-- CSS -->
<style>

    .subtitulo {
        color: #666;
        font-size: 18px;
    }

    .frase-ajuda {
        font-size: 20px;
        color: #444;
    }

    .container-resultado {
        max-width: 700px;
        margin: auto;
    }

    .card-resultado {
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: white;
        padding: 25px;
        border-radius: 15px;
        text-align: center;
    }

    .card-graficos {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
    }

    .barra-ansiedade {
        background: orange;
    }

    .barra-depressao {
        background: red;
    }

    .lista-clinicas {
        max-height: 200px;
        overflow-y: auto;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #ddd;
        border-top: 5px solid #007bff;
        border-radius: 50%;
        animation: girar 1s linear infinite;
        margin: auto;
    }
    .progress-bar {
    background-color: #0d6efd;
    height: 100%;
    width: 0%;
    transition: width 0.5s ease-in-out;
}

    @@keyframes girar {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    body {
        background: #f8fafc;
    }

    .topo-site {
        text-align: center;
        padding: 60px 20px 30px;
    }

    .logo {
        font-size: 42px;
        font-weight: bold;
        color: #0f172a;
        margin-bottom: 20px;
    }

    .frase-impacto {
        font-size: 34px;
        font-weight: bold;
        color: #1e293b;
        margin-bottom: 15px;
    }

    .sub-frase {
        font-size: 20px;
        color: #64748b;
        margin-bottom: 35px;
    }

    .acoes-iniciais {
        max-width: 450px;
        margin: auto;
    }

    .btn-principal {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #00c6ff, #009ee3);
        color: white;
        border: none;
        border-radius: 14px;
        font-size: 17px;
        font-weight: bold;
        cursor: pointer;
        margin-bottom: 15px;
        transition: 0.2s;
    }

        .btn-principal:hover {
            transform: scale(1.02);
        }


    .btn-start {
        margin-top: 20px;
        padding: 12px 20px;
        background: white;
        color: #009ee3;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
    }

    .btn-clinica {
        display: block;
        width: 100%;
        padding: 14px;
        border: 2px solid #009ee3;
        border-radius: 14px;
        text-decoration: none;
        color: #009ee3;
        font-weight: bold;
        transition: 0.2s;
    }

        .btn-clinica:hover {
            background: #009ee3;
            color: white;
        }

    .titulo-perguntas {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 30px;
    }

        .titulo-perguntas h2 {
            font-size: 32px;
            color: #1f2937;
            margin-bottom: 10px;
        }

        .titulo-perguntas p {
            color: #6b7280;
            font-size: 16px;
        }

    .card-pergunta {
        background: white;
        max-width: 700px;
        margin: auto;
        padding: 40px;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        text-align: center;
    }

    .texto-pergunta {
        font-size: 28px;
        color: #1e293b;
        margin-bottom: 35px;
        font-weight: 600;
    }

    .opcoes-resposta {
        display: flex;
        gap: 20px;
        justify-content: center;
    }

    .opcao-radio {
        cursor: pointer;
    }

        .opcao-radio input {
            display: none;
        }

        .opcao-radio span {
            display: inline-block;
            padding: 18px 40px;
            border: 2px solid #dbeafe;
            border-radius: 14px;
            font-size: 18px;
            font-weight: 600;
            background: #f8fafc;
            transition: 0.2s;
        }

        .opcao-radio input:checked + span {
            background: #009ee3;
            color: white;
            border-color: #009ee3;
            transform: scale(1.03);
        }

        .opcao-radio span:hover {
            transform: scale(1.02);
        }

    .acoes-pergunta {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-top: 35px;
        margin-bottom: 80px;
        flex-wrap: wrap;
    }

    .btn-voltar,
    .btn-proximo,
    .btn-finalizar {
        padding: 14px 28px;
        border: none;
        border-radius: 14px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-voltar {
        background: #e2e8f0;
        color: #1e293b;
    }

        .btn-voltar:hover {
            transform: scale(1.03);
        }

    .btn-proximo {
        background: linear-gradient(135deg, #00c6ff, #009ee3);
        color: white;
    }

        .btn-proximo:hover {
            transform: scale(1.03);
        }

    .btn-finalizar {
        background: #16a34a;
        color: white;
    }

        .btn-finalizar:hover {
            transform: scale(1.03);
        }

    .titulo-resultado {
        text-align: center;
        font-size: 34px;
        font-weight: bold;
        margin-bottom: 30px;
        color: #0f172a;
    }

    .card-score {
        background: linear-gradient(135deg, #00c6ff, #009ee3);
        color: white;
        padding: 35px;
        border-radius: 20px;
        text-align: center;
        margin-bottom: 25px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .score-label {
        font-size: 18px;
        margin-bottom: 10px;
    }

    .score-valor {
        font-size: 64px;
        font-weight: bold;
        line-height: 1;
        margin-bottom: 15px;
    }

    .score-sub {
        font-size: 15px;
        opacity: 0.95;
    }

    .badge-nivel {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 999px;
        font-weight: bold;
        font-size: 14px;
    }

        .badge-nivel.alto {
            background: #fee2e2;
            color: #b91c1c;
        }

        .badge-nivel.moderado {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-nivel.baixo {
            background: #dcfce7;
            color: #166534;
        }

    .recomendacao-personalizada {
        margin-top: 20px;
        font-size: 17px;
        color: #475569;
        line-height: 1.6;
    }

    .cta-final {
        margin-top: 30px;
        background: white;
        padding: 35px;
        border-radius: 18px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .btn-especialista {
        display: inline-block;
        margin-top: 20px;
        background: #16a34a;
        color: white;
        padding: 16px 28px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: bold;
        font-size: 16px;
        transition: 0.2s;
    }

        .btn-especialista:hover {
            transform: scale(1.03);
        }

    .bloco-resultado {
        position: fixed;
        inset: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        box-sizing: border-box;
        background: rgba(248, 250, 252, 0.95);
        z-index: 999;
    }

    .card-revelar-resultado {
        background: white;
        width: 100%;
        max-width: 760px;
        padding: 55px;
        border-radius: 24px;
        text-align: center;
        box-shadow: 0 20px 50px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
    }

    .icone-resultado {
        width: 80px;
        height: 80px;
        margin: 0 auto 30px;
        background: #dcfce7;
        color: #16a34a;
        border-radius: 50%;
        font-size: 42px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-revelar-resultado h2 {
        font-size: 42px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 20px;
    }

    .card-revelar-resultado p {
        font-size: 20px;
        color: #475569;
        line-height: 1.8;
        margin-bottom: 35px;
        max-width: 620px;
        margin-left: auto;
        margin-right: auto;
    }

    .btn-ver-resultado {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: white;
        border: none;
        padding: 18px 42px;
        border-radius: 16px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 10px 25px rgba(34,197,94,0.18);
    }

        .btn-ver-resultado:hover {
            transform: scale(1.03);
        }

    .texto-seguro {
        display: block;
        margin-top: 22px;
        font-size: 15px;
        color: #64748b;
        font-weight: 500;
    }

    body {
        background: #f8fafc;
        margin: 0;
        padding: 0;
    }

</style>

<!-- JS -->
<script>
    let atual = 0;
    let perguntas;

        function iniciarTeste() {
        document.querySelector(".topo-site").style.display = "none";

        document.getElementById("revelarResultado").style.display = "none";

        document.getElementById("formTeste").style.display = "block";
        document.getElementById("topoTeste").style.display = "block";
        document.getElementById("barraContainer").style.display = "block";

        document.getElementById("tituloPerguntas").style.display = "block";

        perguntas = document.querySelectorAll(".pergunta");

        atual = 0;

        atualizarBarra();
        mostrarPergunta();

       
    }

        function mostrarPergunta() {
        perguntas.forEach(p => p.style.display = "none");
        perguntas[atual].style.display = "block";

        document.getElementById("contador").innerText =
            (atual + 1) + "/" + perguntas.length;

        document.getElementById("finalizar").style.display =
            (atual === perguntas.length - 1) ? "inline" : "none";

        document.getElementById("btnVoltar").style.display =
            (atual === 0) ? "none" : "inline";
    }

           function proximo() {

        let perguntaAtual = perguntas[atual];
        let respostaMarcada = perguntaAtual.querySelector("input[type='radio']:checked");

        if (!respostaMarcada) {
            alert("Responda esta pergunta antes de continuar.");
            return;
        }

        if (atual < perguntas.length - 1) {
            atual++;
            atualizarBarra();
            mostrarPergunta();
        }
    }
    

        function voltar() {
        if (atual > 0) {
            atual--;
            atualizarBarra();
            mostrarPergunta();
        }
    }

    function mostrarResultado() {
        document.getElementById("resultadoFinal").style.display = "block";
        document.getElementById("revelarResultado").style.display = "none";
    }

        function finalizarTeste() {
         let perguntaAtual = perguntas[atual];
         let respostaMarcada = perguntaAtual.querySelector("input[type='radio']:checked");

        if (!respostaMarcada) {
            alert("Você precisa responder esta pergunta antes de finalizar.");
            return;
        }

        document.getElementById("formTeste").style.display = "none";
        document.getElementById("topoTeste").style.display = "none";
        document.getElementById("barraContainer").style.display = "none";
        document.getElementById("tituloPerguntas").style.display = "none";
        document.getElementById("loading").style.display = "block";
        document.querySelector(".topo-site").style.display = "none";

        window.scrollTo({
            top: 0,
            behavior: "smooth"
        });

        setTimeout(() => {

            document.getElementById("loading").style.display = "none";
            document.getElementById("revelarResultado").style.display = "flex";

        }, 2000);
    }
        function enviarFormulario() {
        document.getElementById("formTeste").submit();
    }

        function atualizarBarra() {
        let progresso = ((atual + 1) / perguntas.length) * 100;
        document.getElementById("barra").style.width = progresso + "%";
    }

        function rolarParaPerguntas() {
        document.getElementById("perguntas").scrollIntoView({
            behavior: "smooth"
        });
    }

</script>