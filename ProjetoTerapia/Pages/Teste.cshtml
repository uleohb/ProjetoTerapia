@page
@model ProjetoTerapia.Pages.TesteModel

<div class="hero-home">

    <div class="hero-left">

        <div class="logo-area">

            <img src="/imagem/logo.png"
                 class="logo-img"
                 alt="Logo" />

        </div>

        <div class="badge-home">
            ✨ Plataforma inteligente de saúde emocional
        </div>

        <h2 class="frase-impacto">
            Descubra como está seu
            <span>bem-estar emocional</span>
            em apenas 1 minuto.
        </h2>

        <p class="sub-frase">
            Faça uma análise rápida, gratuita e confidencial
            para entender melhor sua saúde emocional
            e receber recomendações personalizadas.
        </p>

        <div class="acoes-iniciais">

            <button type="button"
                    onclick="iniciarTeste()"
                    class="btn-principal">

                Começar teste gratuito

            </button>

            <a href="/LoginClinica"
               class="btn-clinica">

                Sou profissional / clínica

            </a>

        </div>

    </div>

    <div class="hero-right">

        <img src="/imagem/cerebro-banner.png"
             class="imagem-cerebro"
             alt="Cérebro" />

    </div>

</div>

<div id="perguntas">

<!-- TELA INICIAL -->

    <div id="tituloPerguntas" class="titulo-perguntas" style="display:none">
        <h2>Teste de Bem-Estar Emocional</h2>
        <p>Responda com sinceridade para uma recomendação mais precisa</p>
    </div>

<!-- CONTADOR -->
<div class="text-center mb-3" id="topoTeste" style="display:none">
    <span id="contador"></span>
</div>

<!-- BARRA -->
<div class="progress mb-4" id="barraContainer" style="display:none">
    <div id="barra" class="progress-bar" style="width:0%"></div>
</div>

<!-- FORM -->
<form method="post" id="formTeste" style="display:none">

    @for (int i = 0; i < Model.Perguntas.Count; i++)
    {
            <div class="pergunta" style="display:none">
                <div class="card-pergunta">

                    <h3 class="texto-pergunta">
                        @Model.Perguntas[i].Texto
                    </h3>

                    <div class="opcoes-resposta">

                        <label class="opcao-radio">
                            <input type="radio" name="Respostas[@i]" value="true" required />
                            <span>Sim</span>
                        </label>

                        <label class="opcao-radio">
                            <input type="radio" name="Respostas[@i]" value="false" required />
                            <span>Não</span>
                        </label>

                    </div>

                </div>
            </div>
    }

        <div class="acoes-pergunta">

            <button type="button"
                    id="btnVoltar"
                    class="btn-voltar"
                    onclick="voltar()">
                ← Voltar
            </button>

            <button type="button" class="btn-proximo" onclick="proximo()">
                Próximo →
            </button>

            <button type="button"
                    id="finalizar"
                    class="btn-finalizar"
                    style="display:none"
                    onclick="finalizarTeste()">
                Finalizar teste
            </button>

        </div>

 </form>

<!-- BOTÃO RESULTADO -->
    <div id="revelarResultado" class="bloco-resultado" style="display:none">

        <div class="card-revelar-resultado">

            <div class="icone-resultado">
                ✓
            </div>

            <h2>
                Sua análise está pronta
            </h2>

            <p>
                Identificamos sinais importantes sobre seu bem-estar emocional.
                Seu resultado pode ajudar você a entender melhor seu momento atual
                e mostrar o melhor próximo passo.
            </p>

            <button type = "button" class="btn-ver-resultado" onclick="enviarFormulario()">
                Ver meu resultado agora
            </button>

            <span class="texto-seguro">
                100% gratuito • confidencial • sem compromisso
            </span>

        </div>

    </div>

<!-- RESULTADO -->
    @if (Model.MostrarResultado)
    {
        <div id="resultadoFinal" class="container-resultado mt-4">

            <h2 class="titulo-resultado">
                Sua Análise de Bem-Estar Emocional
            </h2>

            <!-- SCORE PRINCIPAL -->
            <div class="card-score">

                <p class="score-label">
                    Seu nível de atenção emocional
                </p>

                <div class="score-valor">
                    @(Model.PorcentagemAnsiedade + Model.PorcentagemDepressao)%
                </div>

                <p class="score-sub">
                    Quanto antes você buscar apoio,
                    mais rápido pode melhorar seu bem-estar.
                </p>

            </div>

            <!-- CARD PRINCIPAL PREMIUM -->
            <div class="card-resultado-premium">

                <span class="badge-nivel
                    @(Model.Nivel == "Alto" ? "alto" :
                                        Model.Nivel == "Moderado" ? "moderado" : "baixo")">

                    @(Model.Nivel == "Alto" ? "🔴 Alto" :
                                    Model.Nivel == "Moderado" ? "🟡 Moderado" : "🟢 Leve")

            </span>

                <h3 class="mt-4">
                    @Model.Mensagem
                </h3>

                <p class="recomendacao-personalizada">
                    Identificamos sinais importantes no seu bem-estar emocional.
                    Com acompanhamento adequado, é possível melhorar sua qualidade
                    de vida e recuperar seu equilíbrio emocional.
                </p>

            </div>

            <!-- DASHBOARD -->
            <div class="card-graficos">

                <div class="grafico-item">

                    <h4>Ansiedade Emocional</h4>

                    <p>
                        Seu nível está em
                        <strong>@Model.PorcentagemAnsiedade%</strong>
                    </p>

                    <div class="progress">
                        <div class="progress-bar barra-ansiedade"
                             style="width:@Model.PorcentagemAnsiedade%">
                        </div>
                    </div>

                </div>

                <div class="grafico-item">

                    <h4>Saúde Emocional</h4>

                    <p>
                        Seu nível está em
                        <strong>@Model.PorcentagemDepressao%</strong>
                    </p>

                    <div class="progress">
                        <div class="progress-bar barra-depressao"
                             style="width:@Model.PorcentagemDepressao%">
                        </div>
                    </div>

                </div>

            </div>

            <!-- RECOMENDAÇÃO -->
            <div class="card-recomendacao">

                <h3>
                    Nossa recomendação para você
                </h3>

                <p>
                    Com base nas suas respostas, recomendamos:
                </p>

                <ul class="lista-recomendacao">
                    <li>Terapia individual com especialista</li>
                    <li>Avaliação inicial do seu bem-estar emocional</li>
                    <li>Orientação profissional personalizada para seu momento atual</li>
                </ul>

            </div>

            <!-- PROVA SOCIAL -->
            <div class="prova-social">

                <p>
                    
                </p>

            </div>

            <!-- CTA FINAL -->
            <div class="cta-final">

                <h3>
                    Quero falar com um especialista agora
                </h3>

                <p>
                    Temos profissionais disponíveis para te ajudar imediatamente.
                </p>

                <a href="/Clinicas" class="btn-especialista">
                    Encontrar ajuda profissional
                </a>

                <div class="cta-secundario">
                    <a href="/Teste">Refazer teste</a>
                    <span>•</span>
                    <a href="/Contato">Falar com suporte</a>
                </div>
            </div>

        </div>

        }


    <div id="loading" class="text-center mt-5" style="display:none">

        <h3>Analisando suas respostas...</h3>

        <div class="spinner mt-3"></div>

    </div>

</div>

<!-- CSS -->
<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #f8fafc;
        font-family: "Segoe UI",sans-serif;
        overflow-x: hidden;
    }

    /* =========================
       TÍTULO TESTE
    ========================= */

    .titulo-perguntas {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 30px;
        padding: 0 20px;
    }

        .titulo-perguntas h2 {
            font-size: clamp(28px,4vw,42px);
            color: #0f172a;
            margin-bottom: 10px;
        }

        .titulo-perguntas p {
            color: #64748b;
            font-size: 18px;
        }

    /* =========================
       CARD PERGUNTA
    ========================= */

    .card-pergunta {
        width: calc(100% - 30px);
        max-width: 760px;
        margin: auto;
        background: white;
        border-radius: 24px;
        padding: 45px;
        box-shadow: 0 15px 35px rgba(0,0,0,.06);
        text-align: center;
    }

    .texto-pergunta {
        font-size: clamp(24px,3vw,34px);
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 35px;
        line-height: 1.4;
    }

    /* =========================
       OPÇÕES
    ========================= */

    .opcoes-resposta {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .opcao-radio {
        cursor: pointer;
    }

        .opcao-radio input {
            display: none;
        }

        .opcao-radio span {
            display: inline-block;
            min-width: 140px;
            padding: 18px 30px;
            border-radius: 16px;
            border: 2px solid #dbeafe;
            background: #f8fafc;
            font-size: 18px;
            font-weight: 700;
            transition: .2s;
        }

            .opcao-radio span:hover {
                transform: scale(1.03);
            }

        .opcao-radio input:checked + span {
            background: linear-gradient(135deg,#00c6ff,#009ee3);
            color: white;
            border-color: transparent;
        }

    /* =========================
       BOTÕES
    ========================= */

    .acoes-pergunta {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin: 40px 0 80px;
        flex-wrap: wrap;
    }

    .btn-voltar,
    .btn-proximo,
    .btn-finalizar {
        border: none;
        border-radius: 14px;
        padding: 15px 28px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: .2s;
    }

    .btn-voltar {
        background: #e2e8f0;
        color: #0f172a;
    }

    .btn-proximo {
        background: linear-gradient(135deg,#00c6ff,#009ee3);
        color: white;
    }

    .btn-finalizar {
        background: #16a34a;
        color: white;
    }

        .btn-voltar:hover,
        .btn-proximo:hover,
        .btn-finalizar:hover {
            transform: translateY(-2px);
        }

    /* =========================
       PROGRESSO
    ========================= */

    .progress {
        width: calc(100% - 30px);
        max-width: 760px;
        height: 14px;
        margin: auto;
        border-radius: 999px;
        overflow: hidden;
        background: #e2e8f0;
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg,#00c6ff,#009ee3);
        transition: .4s;
    }

    /* =========================
       RESULTADO
    ========================= */

    .container-resultado {
        width: calc(100% - 30px);
        max-width: 760px;
        margin: 40px auto 80px;
    }

    .titulo-resultado {
        text-align: center;
        font-size: clamp(30px,4vw,46px);
        margin-bottom: 30px;
        color: #0f172a;
        font-weight: 800;
    }

    .card-score {
        background: linear-gradient(135deg,#00c6ff,#009ee3);
        color: white;
        padding: 40px;
        border-radius: 24px;
        text-align: center;
        margin-bottom: 25px;
    }

    .score-label {
        font-size: 18px;
        margin-bottom: 12px;
    }

    .score-valor {
        font-size: 72px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 15px;
    }

    .score-sub {
        font-size: 15px;
        opacity: .95;
    }

    /* =========================
       RESULTADO MODAL
    ========================= */

    .bloco-resultado {
        position: fixed;
        inset: 0;
        background: rgba(248,250,252,.96);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
        z-index: 999;
    }

    .card-revelar-resultado {
        width: 100%;
        max-width: 760px;
        background: white;
        border-radius: 28px;
        padding: 50px;
        text-align: center;
        box-shadow: 0 20px 50px rgba(0,0,0,.08);
    }

    .icone-resultado {
        width: 85px;
        height: 85px;
        border-radius: 50%;
        background: #dcfce7;
        color: #16a34a;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 auto 25px;
        font-size: 42px;
        font-weight: 800;
    }

    .card-revelar-resultado h2 {
        font-size: clamp(30px,4vw,48px);
        color: #0f172a;
        margin-bottom: 18px;
    }

    .card-revelar-resultado p {
        color: #475569;
        font-size: 19px;
        line-height: 1.8;
        margin-bottom: 30px;
    }

    .btn-ver-resultado {
        border: none;
        background: linear-gradient(135deg,#16a34a,#22c55e);
        color: white;
        padding: 18px 40px;
        border-radius: 16px;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        transition: .2s;
    }

        .btn-ver-resultado:hover {
            transform: translateY(-2px);
        }

    .texto-seguro {
        display: block;
        margin-top: 18px;
        color: #64748b;
        font-size: 14px;
    }

    /* =========================
       SPINNER
    ========================= */

    .spinner {
        width: 55px;
        height: 55px;
        border: 5px solid #ddd;
        border-top: 5px solid #009ee3;
        border-radius: 50%;
        margin: auto;
        animation: girar 1s linear infinite;
    }

    @@keyframes girar {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    /* =========================
       RESPONSIVO
    ========================= */

    @@media(max-width:768px) {

        .topo-site {
            padding: 40px 18px;
            min-height: auto;
        }

        .sub-frase {
            margin-bottom: 30px;
        }

        .card-pergunta {
            padding: 28px 22px;
            border-radius: 20px;
        }

        .opcoes-resposta {
            flex-direction: column;
        }

        .opcao-radio span {
            width: 100%;
        }

        .card-revelar-resultado {
            padding: 35px 24px;
        }

            .card-revelar-resultado p {
                font-size: 16px;
            }

        .score-valor {
            font-size: 56px;
        }
    }

    /* =========================
       HERO PREMIUM
    ========================= */

    .hero-home {
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 40px;
        padding: 40px 6%;
        overflow: hidden;
        background: radial-gradient(circle at top left, rgba(0,198,255,.12), transparent 35%), #f8fafc;
    }

    /* ESQUERDA */

    .hero-left {
        flex: 1;
        max-width: 620px;
        z-index: 2;
    }


    /* DIREITA */

    .hero-right {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    /* LOGO */

    .logo-area {
        display: flex;
        align-items: center;
        gap: 18px;
        margin-bottom: 28px;

    }

    /* LÂMPADA */

    .logo-img {
        width: 300px;
        height:300px;
        object-fit: contain;

        margin-top: 20px;
    }

    /* NOME */

    .logo {
        font-size: clamp(42px, 4vw, 72px);
        font-weight: 900;
        line-height: 1;
        margin: 0;
        letter-spacing: -3px;
        color: #2b125d;
    }

    /* BADGE */

    .badge-home {
        display: inline-block;
        background: rgba(0,198,255,.10);
        color: #009ee3;
        padding: 12px 22px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 28px;
    }

    /* TITULO PRINCIPAL */

    .frase-impacto {
        font-size: clamp(32px, 3.2vw, 53px);
        font-weight: 900;
        line-height: 1.07;
        color: #0f172a;
        margin-bottom: 28px;
        letter-spacing: -3px;
        max-width: 700px;
    }

        .frase-impacto span {
            background: linear-gradient(135deg, #5b21b6, #2563eb, #00c6ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    /* SUBTEXTO */

    .sub-frase {
        font-size: 18px;
        color: #64748b;
        line-height: 1.8;
        margin-bottom: 36px;
        max-width: 560px;
    }


    /* BOTÕES */

    .acoes-iniciais {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: nowrap;
    }

    /* BOTÃO PRINCIPAL */

    .btn-principal {
        padding: 15px 26px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg,#00c6ff,#009ee3);
        color: white;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
        box-shadow: 0 10px 25px rgba(0,158,227,.20);
        white-space: nowrap;
    }

        .btn-principal:hover {
            transform: translateY(-3px);
        }

    /* BOTÃO CLÍNICA */

    .btn-clinica {
        padding: 15px 24px;
        border-radius: 14px;
        border: 2px solid #009ee3;
        background: white;
        color: #009ee3;
        text-decoration: none;
        font-size: 15px;
        font-weight: 700;
        transition: .25s;
        white-space: nowrap;
    }

        .btn-clinica:hover {
            background: #009ee3;
            color: white;
        }

    /* CÉREBRO GIGANTE */

    .hero-right {
        flex: 1.5;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .imagem-cerebro {
        width: 100%;
        max-width: 780px;
        height: auto;
        object-fit: contain;
        animation: flutuar 5s ease-in-out infinite;
    }



    /* ANIMAÇÃO */

    @@keyframes flutuar {
        0%

    {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-18px);
    }

    100% {
        transform: translateY(0px);
    }

    }

    /* RESPONSIVO */

    @@media(max - width:1100px) {
        .hero-home

    {
        flex-direction: column;
        text-align: center;
        padding-top: 60px;
    }

    .hero-left {
        max-width: 100%;
    }

    .hero-right {
        width: 100%;
    }

    .logo-area {
        justify-content: center;
    }

    .acoes-iniciais {
        justify-content: center;
    }

    .sub-frase {
        margin-left: auto;
        margin-right: auto;
    }

    .imagem-cerebro {
        max-width: 650px;
    }

    }

    @@media(max - width:768px) {
        .hero-home

    {
        padding: 40px 20px 60px;
    }

    .logo-area {
        flex-direction: column;
        gap: 10px;
    }

    .logo-img {
        width: 90px;
        height: 90px;
    }

    .logo {
        font-size: 48px;
    }

    .logo-sub {
        font-size: 10px;
        letter-spacing: 2px;
    }

    .frase-impacto {
        font-size: 42px;
        letter-spacing: -2px;
    }

    .sub-frase {
        font-size: 16px;
    }

    .acoes-iniciais {
        flex-direction: column;
    }

    .btn-principal,
    .btn-clinica {
        width: 100%;
    }

    .imagem-cerebro {
        max-width: 420px;
    }

    }
</style>

<!-- JS -->
<script>
    let atual = 0;
    let perguntas;

            function iniciarTeste() {

        document.getElementById("formTeste").style.display = "block";
        document.getElementById("topoTeste").style.display = "block";
        document.getElementById("barraContainer").style.display = "block";
        document.getElementById("tituloPerguntas").style.display = "block";

        perguntas = document.querySelectorAll(".pergunta");

        atual = 0;

        atualizarBarra();
        mostrarPergunta();

        document.getElementById("perguntas").scrollIntoView({
            behavior: "smooth"
        });
    }

        function mostrarPergunta() {
        perguntas.forEach(p => p.style.display = "none");
        perguntas[atual].style.display = "block";

        document.getElementById("contador").innerText =
            (atual + 1) + "/" + perguntas.length;

        document.getElementById("finalizar").style.display =
            (atual === perguntas.length - 1) ? "inline" : "none";

        document.getElementById("btnVoltar").style.display =
            (atual === 0) ? "none" : "inline";
    }

           function proximo() {

        let perguntaAtual = perguntas[atual];
        let respostaMarcada = perguntaAtual.querySelector("input[type='radio']:checked");

        if (!respostaMarcada) {
            alert("Responda esta pergunta antes de continuar.");
            return;
        }

        if (atual < perguntas.length - 1) {
            atual++;
            atualizarBarra();
            mostrarPergunta();
        }
    }
    

        function voltar() {
        if (atual > 0) {
            atual--;
            atualizarBarra();
            mostrarPergunta();
        }
    }

    function mostrarResultado() {
        document.getElementById("resultadoFinal").style.display = "block";
        document.getElementById("revelarResultado").style.display = "none";
    }

        function finalizarTeste() {
         let perguntaAtual = perguntas[atual];
         let respostaMarcada = perguntaAtual.querySelector("input[type='radio']:checked");

        if (!respostaMarcada) {
            alert("Você precisa responder esta pergunta antes de finalizar.");
            return;
        }

        document.getElementById("formTeste").style.display = "none";
        document.getElementById("topoTeste").style.display = "none";
        document.getElementById("barraContainer").style.display = "none";
        document.getElementById("tituloPerguntas").style.display = "none";
        document.getElementById("loading").style.display = "block";
        document.querySelector(".hero-home").style.display = "none";

        window.scrollTo({
            top: 0,
            behavior: "smooth"
        });

        setTimeout(() => {

            document.getElementById("loading").style.display = "none";
            document.getElementById("revelarResultado").style.display = "flex";

        }, 2000);
    }
        function enviarFormulario() {
        document.getElementById("formTeste").submit();
    }

        function atualizarBarra() {
        let progresso = ((atual + 1) / perguntas.length) * 100;
        document.getElementById("barra").style.width = progresso + "%";
    }

        function rolarParaPerguntas() {
        document.getElementById("perguntas").scrollIntoView({
            behavior: "smooth"
        });
    }

</script>