@page
@model ProjetoTerapia.Pages.TesteModel

<div style="background: linear-gradient(135deg, #4facfe, #00f2fe); padding: 20px; border-radius: 0 0 20px 20px;">
    <h2 style="color: white; text-align:center; margin:0;">
        PsiConecta
    </h2>
</div>

<div class="text-center mt-4">
    <h1>Teste de Bem-Estar</h1>
    <p class="subtitulo">Em menos de 1 minuto, descubra como está sua saúde emocional</p>
</div>

<!-- TELA INICIAL -->
<div id="inicio" class="text-center mt-5">
    <h3>Você gostaria de saber como você está hoje?</h3>

    <button class="btn btn-primary mt-3" onclick="iniciarTeste()">
        Começar agora
    </button>

    <!-- NOVO BOTÃO -->
    <div class="mt-4">
        <a href="/CadastroClinica" class="btn btn-outline-success">
            Sou profissional / clínica
        </a>
    </div>
</div>

<!-- CONTADOR -->
<div class="text-center mb-3" id="topoTeste" style="display:none">
    <span id="contador"></span>
</div>

<!-- BARRA -->
<div class="progress mb-4" id="barraContainer" style="display:none">
    <div id="barra" class="progress-bar" style="width:0%"></div>
</div>

<!-- FORM -->
<form method="post" id="formTeste" style="display:none">

    @for (int i = 0; i < Model.Perguntas.Count; i++)
    {
        <div class="pergunta" style="display:none">
            <h4>@Model.Perguntas[i].Texto</h4>

            <input type="radio" name="Respostas[@i]" value="true" required /> Sim
            <input type="radio" name="Respostas[@i]" value="false" required /> Não
        </div>
    }

    <div class="text-center mt-4">
        <button type="button" onclick="voltar()">Voltar</button>
        <button type="button" onclick="proximo()">Próximo</button>
        <button type="button" id="finalizar" style="display:none" onclick="finalizarTeste()">
            Finalizar
        </button>
    </div>

</form>

<!-- FRASE -->
<div id="fraseAjuda" class="text-center mt-4" style="display:none">
    <p class="frase-ajuda">
        Você pode estar precisando de apoio profissional para melhorar seu bem-estar emocional.
    </p>
</div>

<!-- BOTÃO RESULTADO -->
<div id="revelarResultado" class="text-center mt-4" style="display:none">
    <h4>Quer ver seu resultado?</h4>
    <button class="btn btn-success mt-2" onclick="enviarFormulario()">
        Ver resultado
    </button>
</div>

<div id="loading" class="text-center mt-5" style="display:none">

    <h3>Analisando suas respostas...</h3>

    <div class="spinner mt-3"></div>

</div>



<!-- RESULTADO -->
@if (Model.MostrarResultado)
{
    <div id="resultadoFinal" class="container-resultado mt-4">

        <h2 class="text-center mb-4">Seu Resultado</h2>

        <div class="card-resultado">
            <h3>@Model.Nivel</h3>
            <p>@Model.Mensagem</p>
        </div>

        <div class="card-graficos">
            <div class="mb-3">
                <span>Ansiedade: @Model.PorcentagemAnsiedade%</span>
                <div class="progress">
                    <div class="progress-bar barra-ansiedade"
                         style="width:@Model.PorcentagemAnsiedade%">
                    </div>
                </div>
            </div>

            <div>
                <span>Depressão: @Model.PorcentagemDepressao%</span>
                <div class="progress">
                    <div class="progress-bar barra-depressao"
                         style="width:@Model.PorcentagemDepressao%">
                    </div>
                </div>
            </div>
        </div>
        @if (Model.Nivel == "Alto")
        {
            <div class="text-center mt-4">

                <div class="alert alert-warning">
                    ⚠️ Recomendamos procurar ajuda profissional
                </div>

                <a href="/Clinicas" class="btn btn-danger">
                    Ver profissionais recomendados
                </a>

            </div>
        }
        else if (Model.Nivel == "Moderado")
        {
            <div class="text-center mt-4">

                <div class="alert alert-info">
                    💡 Você pode se beneficiar de conversar com um profissional, se quiser.
                </div>

                <a href="/Clinicas" class="btn btn-outline-primary">
                    Ver profissionais disponíveis
                </a>

            </div>
        }

        else
        {
            <div class="text-center mt-4">

                <div class="alert alert-success">
                    ✅ Continue se cuidando! Se quiser evoluir ainda mais, temos profissionais disponíveis.
                </div>

                <a href="/Clinicas" class="btn btn-outline-success">
                    Conhecer profissionais
                </a>

            </div>
        }
    </div>
}

<!-- CSS -->
<style>

    .subtitulo {
        color: #666;
        font-size: 18px;
    }

    .frase-ajuda {
        font-size: 20px;
        color: #444;
    }

    .container-resultado {
        max-width: 700px;
        margin: auto;
    }

    .card-resultado {
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: white;
        padding: 25px;
        border-radius: 15px;
        text-align: center;
    }

    .card-graficos {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
    }

    .barra-ansiedade {
        background: orange;
    }

    .barra-depressao {
        background: red;
    }

    .lista-clinicas {
        max-height: 200px;
        overflow-y: auto;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #ddd;
        border-top: 5px solid #007bff;
        border-radius: 50%;
        animation: girar 1s linear infinite;
        margin: auto;
    }
    .progress-bar {
    background-color: #0d6efd;
    height: 100%;
    width: 0%;
    transition: width 0.5s ease-in-out;
}

    @@keyframes girar {
     0%{transform: rotate(0deg);}
     100% {transform: rotate(360deg);}
    }
</style>

<!-- JS -->
<script>
    let atual = 0;
    let perguntas;

        function iniciarTeste() {
        document.getElementById("inicio").style.display = "none";
        document.getElementById("formTeste").style.display = "block";
        document.getElementById("topoTeste").style.display = "block";
        document.getElementById("barraContainer").style.display = "block";

        perguntas = document.querySelectorAll(".pergunta");

        atualizarBarra(); 
        mostrarPergunta();
    }

        function mostrarPergunta() {
        perguntas.forEach(p => p.style.display = "none");
        perguntas[atual].style.display = "block";

        document.getElementById("contador").innerText =
            (atual + 1) + "/" + perguntas.length;

        document.getElementById("finalizar").style.display =
            (atual === perguntas.length - 1) ? "inline" : "none";
    }

        function proximo() {
        if (atual < perguntas.length - 1) {
            atual++;
            atualizarBarra(); 
            mostrarPergunta();
        }
    }

        function voltar() {
        if (atual > 0) {
            atual--;
            atualizarBarra();
            mostrarPergunta();
        }
    }

    function mostrarResultado() {
        document.getElementById("resultadoFinal").style.display = "block";
        document.getElementById("revelarResultado").style.display = "none";
    }

        function finalizarTeste() {


        // Esconde perguntas
        document.getElementById("formTeste").style.display = "none";
        document.getElementById("topoTeste").style.display = "none";
        document.getElementById("barraContainer").style.display = "none";

        // Mostra loading
        document.getElementById("loading").style.display = "block";

        // Delay de 2 segundos
        setTimeout(() => {

            document.getElementById("loading").style.display = "none";

            document.getElementById("fraseAjuda").style.display = "block";
            document.getElementById("revelarResultado").style.display = "block";

        }, 2000);
    }
        function enviarFormulario() {
        document.getElementById("formTeste").submit();
    }

        function atualizarBarra() {
        let progresso = ((atual + 1) / perguntas.length) * 100;
        document.getElementById("barra").style.width = progresso + "%";
    }
</script>