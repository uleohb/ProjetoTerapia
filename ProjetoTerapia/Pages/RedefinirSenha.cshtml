@page
@model ProjetoTerapia.Pages.RedefinirSenhaModel


<div class="recuperacao-container">

    <div class="recuperacao-card">


        <img src="/imagem/logo.png"
             class="logo-empresa" />


        <div class="icone">
            🔐
        </div>


        <h1>Redefinir senha</h1>


        <p>
            Crie uma nova senha segura para acessar
            sua conta profissional.
        </p>



        <form method="post">


            <input type="hidden"
                   asp-for="Token" />



            <div class="campo">

                <label>
                    Nova senha
                </label>


                <input asp-for="NovaSenha"
                       type="password"
                       placeholder="Digite sua nova senha"
                       required />

            </div>




            <div class="campo">

                <label>
                    Confirmar nova senha
                </label>


                <input asp-for="ConfirmarSenha"
                       type="password"
                       placeholder="Repita sua senha"
                       required />

            </div>




            <button class="btn-recuperar">

                Alterar senha

            </button>


        </form>




        @if (!string.IsNullOrEmpty(Model.Mensagem))
        {

            <div class="mensagem">

                @Model.Mensagem

            </div>

        }




        <a class="voltar"
           href="/LoginClinica">

            ← Voltar para login

        </a>



    </div>

</div>





<style>


    body {
        background: #f8fafc;
    }




    .recuperacao-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }




    .recuperacao-card {
        background: white;
        width: 420px;
        padding: 40px;
        border-radius: 25px;
        box-shadow: 0 20px 50px rgba(0,0,0,.08);
        text-align: center;
    }




    .logo-empresa {
        width: 220px;
        height: auto;
        margin-bottom: 20px;
    }




    .icone {
        width: 55px;
        height: 55px;
        background: #eff6ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        font-size: 25px;
    }




    h1 {
        color: #0f172a;
        margin-top: 20px;
    }





    p {
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 30px;
    }





    .campo {
        text-align: left;
        margin-bottom: 20px;
    }





        .campo label {
            font-weight: 600;
            display: block;
            margin-bottom: 8px;
        }





        .campo input {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            border: 1px solid #dbeafe;
            font-size: 15px;
        }





    .btn-recuperar {
        width: 100%;
        padding: 15px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        font-weight: bold;
        cursor: pointer;
        font-size: 16px;
    }




    .mensagem {
        margin-top: 20px;
        background: #eff6ff;
        padding: 15px;
        border-radius: 12px;
        color: #1e40af;
    }




    .voltar {
        display: block;
        margin-top: 20px;
        text-decoration: none;
        color: #2563eb;
        font-weight: 600;
    }

</style>