@page
@model ProjetoTerapia.Pages.RedefinirSenhaPacienteModel

<div class="redefinir-container">

    <div class="redefinir-card">

        <img src="/imagem/logo.png"
             class="logo-auth"
             alt="Logo AlinhaMente" />

        <h1>Redefinir senha</h1>

        <p>
            Crie uma nova senha para acessar sua área do paciente.
        </p>

        @if (Model.TokenValido)
        {
            <form method="post">

                <input type="hidden" asp-for="Token" />

                <div class="campo">
                    <label>Nova senha</label>
                    <input asp-for="NovaSenha"
                           type="password"
                           placeholder="Digite sua nova senha"
                           required />
                </div>

                <div class="campo">
                    <label>Confirmar nova senha</label>
                    <input asp-for="ConfirmarSenha"
                           type="password"
                           placeholder="Confirme sua nova senha"
                           required />
                </div>

                <button type="submit" class="btn-primary">
                    Alterar senha
                </button>

            </form>
        }

        @if (!string.IsNullOrEmpty(Model.Mensagem))
        {
            <div class="mensagem">
                @Model.Mensagem
            </div>
        }

        @if (Model.SenhaAlterada)
        {
            <a href="/LoginPaciente" class="btn-login">
                Ir para login
            </a>
        }
        else
        {
            <a href="/LoginPaciente" class="voltar">
                Voltar para login
            </a>
        }

    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

    * {
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    body {
        margin: 0;
        background: linear-gradient(135deg,#ecfeff,#f8fafc,#eef2ff);
    }

    .redefinir-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
    }

    .redefinir-card {
        width: 100%;
        max-width: 520px;
        background: white;
        padding: 42px;
        border-radius: 30px;
        box-shadow: 0 25px 60px rgba(15,23,42,.12);
        text-align: center;
    }

    .logo-auth {
        width: 240px;
        max-width: 100%;
        margin-bottom: 18px;
    }

    h1 {
        color: #0f172a;
        font-size: 30px;
        margin-bottom: 12px;
    }

    p {
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    .campo {
        text-align: left;
        margin-bottom: 18px;
    }

        .campo label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
            color: #0f172a;
        }

        .campo input {
            width: 100%;
            padding: 16px;
            border-radius: 14px;
            border: 1px solid #dbeafe;
            background: #f8fafc;
            font-size: 15px;
            outline: none;
        }

            .campo input:focus {
                border-color: #0ea5e9;
                background: white;
                box-shadow: 0 0 0 4px rgba(14,165,233,.12);
            }

    .btn-primary,
    .btn-login {
        width: 100%;
        display: block;
        padding: 16px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        color: white;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        text-decoration: none;
        margin-top: 10px;
    }

    .mensagem {
        margin-top: 20px;
        background: #eff6ff;
        color: #1e40af;
        padding: 14px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.5;
    }

    .voltar {
        display: block;
        margin-top: 22px;
        color: #0ea5e9;
        text-decoration: none;
        font-weight: 600;
    }
</style>