@page
@model ProjetoTerapia.Pages.HomePacienteModel

<div class="paciente-page">

    <aside class="sidebar">

        <div class="brand">
            <img src="/imagem/logo.png" alt="AlinhaMente" />
        </div>

        <nav class="menu">
            <a href="/HomePaciente" class="active">Início</a>
            <a href="/Teste">Teste emocional</a>
            <a href="#diario">Diário emocional</a>
            <a href="#historico">Histórico</a>
            <a href="/HomePaciente?handler=Sair">Sair</a>
        </nav>

    </aside>

    <main class="main-content">

        <section class="hero">

            <div class="hero-text">

                <span class="tag">Área do paciente</span>

                <h1>
                    Olá, @Model.Paciente?.Nome
                </h1>

                <p>
                    Este é o seu espaço de cuidado. Aqui você pode acompanhar sua jornada,
                    registrar como está se sentindo e acessar ferramentas para entender melhor
                    sua saúde emocional.
                </p>

                <div class="hero-actions">
                    <a href="/Teste" class="btn-primary">Fazer teste emocional</a>
                    <a href="#diario" class="btn-secondary">Registrar meu dia</a>
                </div>

            </div>

            <div class="hero-card">

                <span>Resumo da jornada</span>

                <h2>
                    @Model.Registros.Count
                </h2>

                <p>
                    registros emocionais recentes
                </p>

            </div>

        </section>

        @if (Model.UltimoResultadoTeste != null)
        {
            <section class="resultado-teste-card">

                <div class="resultado-info-principal">

                    <span>Último teste emocional</span>

                    <h2>
                        @Model.UltimoResultadoTeste.Nivel
                    </h2>

                    <p>
                        @Model.UltimoResultadoTeste.Mensagem
                    </p>

                    <small>
                        Realizado em @Model.UltimoResultadoTeste.DataResultado.ToString("dd/MM/yyyy HH:mm")
                    </small>

                </div>

                <div class="resultado-numeros">

                    <div>
                        <span>Ansiedade</span>
                        <strong>@Model.UltimoResultadoTeste.PercentualAnsiedade%</strong>
                    </div>

                    <div>
                        <span>Depressão</span>
                        <strong>@Model.UltimoResultadoTeste.PercentualDepressao%</strong>
                    </div>

                </div>

                <a href="/Teste" class="btn-refazer-teste">
                    Refazer teste
                </a>

            </section>
        }
        else
        {
            <section class="resultado-teste-card vazio">

                <div>
                    <span>Teste emocional</span>

                    <h2>
                        Você ainda não fez um teste logado
                    </h2>

                    <p>
                        Faça o teste emocional para salvar seu resultado e acompanhar sua evolução.
                    </p>
                </div>

                <a href="/Teste" class="btn-refazer-teste">
                    Fazer teste agora
                </a>

            </section>
        }

        <section class="cards-grid">

            <div class="info-card">
                <span class="number">01</span>
                <h3>Entenda seus sinais</h3>
                <p>
                    Faça o teste emocional e acompanhe seus resultados ao longo do tempo.
                </p>
            </div>

            <div class="info-card">
                <span class="number">02</span>
                <h3>Registre sua evolução</h3>
                <p>
                    Use o diário emocional para escrever sobre seus dias, sentimentos e pensamentos.
                </p>
            </div>

            <div class="info-card">
                <span class="number">03</span>
                <h3>Busque apoio</h3>
                <p>
                    Encontre profissionais preparados para ajudar você em sua jornada.
                </p>
            </div>

        </section>

        <section class="content-grid">

            <div class="diario-card" id="diario">

                <div class="section-title">
                    <span>Check-in emocional</span>
                    <h2>Como você está se sentindo hoje?</h2>
                    <p>
                        Escolha uma nota e escreva uma anotação sobre o seu dia.
                    </p>
                </div>

                <form method="post">

                    <input type="hidden" asp-for="Nota" id="notaHumor" />

                    <div class="mood-options">

                        <button type="button" class="mood-btn" data-nota="1">
                            <strong>1</strong>
                            <span>Muito difícil</span>
                        </button>

                        <button type="button" class="mood-btn" data-nota="2">
                            <strong>2</strong>
                            <span>Difícil</span>
                        </button>

                        <button type="button" class="mood-btn" data-nota="3">
                            <strong>3</strong>
                            <span>Neutro</span>
                        </button>

                        <button type="button" class="mood-btn" data-nota="4">
                            <strong>4</strong>
                            <span>Bem</span>
                        </button>

                        <button type="button" class="mood-btn" data-nota="5">
                            <strong>5</strong>
                            <span>Muito bem</span>
                        </button>

                    </div>

                    <textarea asp-for="Observacao"
                              placeholder="Escreva aqui como foi seu dia, o que sentiu ou algo que deseja lembrar..."></textarea>

                    <button type="submit" class="btn-save">
                        Salvar registro
                    </button>

                </form>

            </div>

            <div class="historico-card" id="historico">

                <div class="section-title">
                    <span>Histórico recente</span>
                    <h2>Seus últimos registros</h2>
                </div>

                @if (Model.Registros.Any())
                {
                    <div class="timeline">

                        @foreach (var item in Model.Registros)
                        {
                            <div class="timeline-item">

                                <div class="timeline-date">
                                    @item.Data.ToString("dd/MM")
                                </div>

                                <div class="timeline-content">

                                    <strong>
                                        Nota emocional: @item.Nota/5
                                    </strong>

                                    <p>
                                        @(string.IsNullOrWhiteSpace(item.Observacao)
                                                                        ? "Sem anotação neste registro."
                                                                        : item.Observacao)
                            </p>

                                    <small>
                                        @item.Data.ToString("HH:mm")
                                    </small>

                                </div>

                            </div>
                                        }

                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <h3>Nenhum registro ainda</h3>
                        <p>
                            Comece registrando como você está se sentindo hoje.
                        </p>
                    </div>
                }

            </div>

        </section>

    </main>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    body {
        background: #f8fafc;
        color: #0f172a;
    }

    .paciente-page {
        min-height: 100vh;
        display: flex;
    }

    .sidebar {
        width: 280px;
        background: linear-gradient(180deg, #0f766e, #0ea5e9);
        padding: 30px 24px;
        color: white;
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
    }

    .brand {
        background: white;
        border-radius: 22px;
        padding: 18px;
        margin-bottom: 35px;
        text-align: center;
    }

        .brand img {
            width: 190px;
            max-width: 100%;
        }

    .menu {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

        .menu a {
            color: rgba(255,255,255,.88);
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 14px;
            font-weight: 500;
            transition: .25s;
        }

            .menu a:hover,
            .menu a.active {
                background: rgba(255,255,255,.16);
                color: white;
            }

    .main-content {
        margin-left: 280px;
        width: calc(100% - 280px);
        padding: 38px;
    }

    .hero {
        display: grid;
        grid-template-columns: 1fr 330px;
        gap: 28px;
        align-items: stretch;
        background: linear-gradient(135deg,#ecfeff,#ffffff,#eef2ff);
        padding: 42px;
        border-radius: 32px;
        box-shadow: 0 25px 60px rgba(15,23,42,.08);
        margin-bottom: 28px;
    }

    .tag {
        display: inline-block;
        background: #ccfbf1;
        color: #0f766e;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .hero h1 {
        font-size: 44px;
        letter-spacing: -1px;
        margin-bottom: 16px;
        color: #0f172a;
    }

    .hero p {
        font-size: 17px;
        line-height: 1.8;
        color: #64748b;
        max-width: 780px;
    }

    .hero-actions {
        display: flex;
        gap: 14px;
        margin-top: 28px;
        flex-wrap: wrap;
    }

    .btn-primary,
    .btn-secondary {
        padding: 14px 20px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        display: inline-block;
    }

    .btn-primary {
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        color: white;
    }

    .btn-secondary {
        background: white;
        color: #0f766e;
        border: 1px solid #dbeafe;
    }

    .hero-card {
        background: white;
        border-radius: 26px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: 0 18px 40px rgba(15,23,42,.08);
    }

        .hero-card span {
            color: #64748b;
            font-weight: 600;
        }

        .hero-card h2 {
            font-size: 70px;
            color: #0ea5e9;
            line-height: 1;
            margin: 18px 0;
        }

        .hero-card p {
            color: #64748b;
        }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
        margin-bottom: 28px;
    }

    .info-card {
        background: white;
        padding: 26px;
        border-radius: 24px;
        box-shadow: 0 18px 45px rgba(15,23,42,.06);
        border: 1px solid #e2e8f0;
    }

        .info-card .number {
            display: inline-flex;
            width: 42px;
            height: 42px;
            align-items: center;
            justify-content: center;
            border-radius: 14px;
            background: #ecfeff;
            color: #0f766e;
            font-weight: 800;
            margin-bottom: 18px;
        }

        .info-card h3 {
            margin-bottom: 10px;
            font-size: 20px;
        }

        .info-card p {
            color: #64748b;
            line-height: 1.6;
        }

    .content-grid {
        display: grid;
        grid-template-columns: 1.25fr .75fr;
        gap: 28px;
        align-items: start;
    }

    .diario-card,
    .historico-card {
        background: white;
        padding: 30px;
        border-radius: 28px;
        box-shadow: 0 18px 45px rgba(15,23,42,.06);
        border: 1px solid #e2e8f0;
    }

    .section-title span {
        color: #0ea5e9;
        font-weight: 700;
        font-size: 14px;
    }

    .section-title h2 {
        margin: 8px 0 8px;
        font-size: 26px;
    }

    .section-title p {
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 22px;
    }

    .mood-options {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 12px;
        margin: 22px 0;
    }

    .mood-btn {
        background: #f8fafc;
        border: 1px solid #dbeafe;
        border-radius: 18px;
        padding: 16px 10px;
        cursor: pointer;
        transition: .25s;
        color: #334155;
    }

        .mood-btn strong {
            display: block;
            font-size: 24px;
            color: #0f766e;
            margin-bottom: 6px;
        }

        .mood-btn span {
            font-size: 12px;
            font-weight: 600;
        }

        .mood-btn:hover,
        .mood-btn.selected {
            background: linear-gradient(135deg,#14b8a6,#0ea5e9);
            color: white;
            transform: translateY(-2px);
        }

            .mood-btn:hover strong,
            .mood-btn.selected strong {
                color: white;
            }

    textarea {
        width: 100%;
        min-height: 150px;
        resize: vertical;
        padding: 18px;
        border-radius: 18px;
        border: 1px solid #dbeafe;
        background: #f8fafc;
        font-size: 15px;
        outline: none;
        line-height: 1.6;
    }

        textarea:focus {
            border-color: #0ea5e9;
            background: white;
            box-shadow: 0 0 0 4px rgba(14,165,233,.12);
        }

    .btn-save {
        margin-top: 16px;
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        color: white;
        font-weight: 800;
        font-size: 16px;
        cursor: pointer;
    }

    .timeline {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .timeline-item {
        display: flex;
        gap: 14px;
        padding-bottom: 16px;
        border-bottom: 1px solid #e2e8f0;
    }

    .timeline-date {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: #ecfeff;
        color: #0f766e;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        flex-shrink: 0;
    }

    .timeline-content strong {
        display: block;
        margin-bottom: 6px;
    }

    .timeline-content p {
        color: #64748b;
        line-height: 1.5;
        margin-bottom: 6px;
    }

    .timeline-content small {
        color: #94a3b8;
    }

    .empty-state {
        padding: 28px;
        border-radius: 22px;
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        text-align: center;
    }

        .empty-state h3 {
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            line-height: 1.6;
        }

    .resultado-teste-card {
        background: white;
        border-radius: 28px;
        padding: 30px;
        margin-bottom: 28px;
        box-shadow: 0 18px 45px rgba(15,23,42,.06);
        border: 1px solid #e2e8f0;
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: center;
        gap: 24px;
    }

        .resultado-teste-card.vazio {
            grid-template-columns: 1fr auto;
        }

            .resultado-info-principal span,
            .resultado-teste-card.vazio span {
                color: #0ea5e9;
                font-size: 14px;
                font-weight: 800;
            }

            .resultado-info-principal h2,
            .resultado-teste-card.vazio h2 {
                margin: 8px 0;
                font-size: 28px;
                color: #0f172a;
            }

            .resultado-info-principal p,
            .resultado-teste-card.vazio p {
                color: #64748b;
                line-height: 1.6;
            }

    .resultado-info-principal small {
        display: block;
        margin-top: 10px;
        color: #94a3b8;
    }

    .resultado-numeros {
        display: flex;
        gap: 14px;
    }

        .resultado-numeros div {
            min-width: 130px;
            padding: 18px;
            border-radius: 20px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            text-align: center;
        }

        .resultado-numeros span {
            display: block;
            color: #64748b;
            font-size: 13px;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .resultado-numeros strong {
            font-size: 26px;
            color: #0ea5e9;
        }

    .btn-refazer-teste {
        padding: 15px 22px;
        border-radius: 16px;
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        color: white;
        text-decoration: none;
        font-weight: 800;
        white-space: nowrap;
    }

    @@media(max-width: 1000px) {

        .sidebar {
            position: relative;
            width: 100%;
            height: auto;
        }

        .paciente-page {
            display: block;
        }

        .main-content {
            margin-left: 0;
            width: 100%;
            padding: 20px;
        }

        .hero,
        .cards-grid,
        .content-grid {
            grid-template-columns: 1fr;
        }

        .mood-options {
            grid-template-columns: 1fr;
        }

        .hero h1 {
            font-size: 34px;
        }
    }

</style>

<script>
    const botoesHumor = document.querySelectorAll('.mood-btn');
    const inputNota = document.getElementById('notaHumor');

    botoesHumor.forEach(botao => {
        botao.addEventListener('click', () => {

            botoesHumor.forEach(b => b.classList.remove('selected'));

            botao.classList.add('selected');

            inputNota.value = botao.getAttribute('data-nota');
        });
    });
</script>