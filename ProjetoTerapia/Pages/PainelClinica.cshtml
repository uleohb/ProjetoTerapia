@page
@model ProjetoTerapia.Pages.PainelClinicaModel

<div class="painel-container">

    <!-- BG -->
    <div class="blur blur-1"></div>
    <div class="blur blur-2"></div>

    <div class="topo-painel">

        <div>
            <span class="badge-painel">
                ✨ Painel da Clínica
            </span>

            <h1>
                Bem-vindo,
                @Model.Clinica?.Nome
            </h1>

            <p>
                Gerencie sua conta e acompanhe
                sua assinatura da plataforma.
            </p>
        </div>

        <a href="/Teste" class="btn-voltar-site">
            Voltar ao site
        </a>

    </div>

    @if (Model.Clinica != null)
    {
        <div class="grid-cards">

            <div class="card-dashboard">

                <span class="icone-card">🏥</span>

                <h3>Clínica</h3>

                <p>@Model.Clinica.Nome</p>

            </div>

            <div class="card-dashboard">

                <span class="icone-card">📧</span>

                <h3>Email</h3>

                <p>@Model.Clinica.Email</p>

            </div>

            <div class="card-dashboard">

                <span class="icone-card">📞</span>

                <h3>Telefone</h3>

                <p>@Model.Clinica.Telefone</p>

            </div>

            <div class="card-dashboard">

                <span class="icone-card">💰</span>

                <h3>Plano</h3>

                <p>R$ @Model.Clinica.Valor</p>

            </div>

        </div>

        <div class="card-status">

            <div>

                <h2>Status da Assinatura</h2>

                <p>
                    Sua clínica está atualmente:
                </p>

            </div>

            <div class="status-area">

                @if (Model.Clinica.Pago)
                {
                    <span class="status ativo">
                        🟢 Ativo
                    </span>
                }
                else
                {
                    <span class="status pendente">
                        🟡 Pendente
                    </span>
                }

            </div>

        </div>

        <div class="acoes-dashboard">

            <a href="/Clinicas" class="btn-dashboard principal">
                Ver página pública
            </a>

            <a href="/Contato" class="btn-dashboard secundario">
                Falar com suporte
            </a>

        </div>
    }
    else
    {
        <div class="erro-card">

            <h2>
                Erro ao carregar os dados da clínica
            </h2>

            <a href="/LoginClinica" class="btn-dashboard principal">
                Fazer login novamente
            </a>

        </div>
    }

</div>

<style>

    body {
        background: #f8fafc;
        margin: 0;
        padding: 0;
    }

    .painel-container {
        position: relative;
        overflow: hidden;
        min-height: 100vh;
        padding: 60px 40px;
        max-width: 1200px;
        margin: auto;
    }

    .blur {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        z-index: 0;
    }

    .blur-1 {
        width: 300px;
        height: 300px;
        background: rgba(124,58,237,0.12);
        top: -100px;
        left: -100px;
    }

    .blur-2 {
        width: 280px;
        height: 280px;
        background: rgba(37,99,235,0.12);
        bottom: -120px;
        right: -120px;
    }

    .topo-painel {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 50px;
        flex-wrap: wrap;
    }

    .badge-painel {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 999px;
        background: rgba(124,58,237,0.08);
        color: #7c3aed;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 18px;
    }

    .topo-painel h1 {
        font-size: 54px;
        margin: 0 0 12px;
        line-height: 1;
        font-weight: 700;
        letter-spacing: -2px;
        background: linear-gradient(90deg,#7c3aed,#2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .topo-painel p {
        color: #64748b;
        font-size: 18px;
        max-width: 600px;
    }

    .btn-voltar-site {
        padding: 16px 24px;
        border-radius: 16px;
        text-decoration: none;
        background: white;
        border: 1px solid #dbeafe;
        color: #2563eb;
        font-weight: 600;
        transition: .2s;
    }

        .btn-voltar-site:hover {
            transform: translateY(-2px);
        }

    .grid-cards {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 22px;
        margin-bottom: 35px;
    }

    .card-dashboard {
        background: white;
        padding: 30px;
        border-radius: 24px;
        border: 1px solid #eef2ff;
        box-shadow: 0 10px 25px rgba(15,23,42,0.05);
    }

    .icone-card {
        font-size: 34px;
        display: block;
        margin-bottom: 18px;
    }

    .card-dashboard h3 {
        margin: 0 0 10px;
        color: #0f172a;
    }

    .card-dashboard p {
        margin: 0;
        color: #64748b;
        font-size: 17px;
    }

    .card-status {
        position: relative;
        z-index: 2;
        background: white;
        border-radius: 28px;
        padding: 35px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        box-shadow: 0 10px 25px rgba(15,23,42,0.05);
        margin-bottom: 35px;
    }

        .card-status h2 {
            margin: 0 0 10px;
            color: #0f172a;
        }

        .card-status p {
            margin: 0;
            color: #64748b;
        }

    .status {
        padding: 14px 24px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 16px;
    }

    .ativo {
        background: #dcfce7;
        color: #166534;
    }

    .pendente {
        background: #fef3c7;
        color: #92400e;
    }

    .acoes-dashboard {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
    }

    .btn-dashboard {
        padding: 18px 28px;
        border-radius: 18px;
        text-decoration: none;
        font-weight: 700;
        transition: .2s;
    }

        .btn-dashboard:hover {
            transform: translateY(-2px);
        }

        .btn-dashboard.principal {
            background: linear-gradient(135deg,#00c6ff,#009ee3);
            color: white;
            box-shadow: 0 10px 25px rgba(0,158,227,0.20);
        }

        .btn-dashboard.secundario {
            background: white;
            border: 1px solid #dbeafe;
            color: #2563eb;
        }

    .erro-card {
        background: white;
        padding: 40px;
        border-radius: 24px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(15,23,42,0.05);
    }

    @@media(max-width:768px) {

        .painel-container {
            padding: 40px 20px;
        }

        .topo-painel h1 {
            font-size: 42px;
        }
    }

</style>