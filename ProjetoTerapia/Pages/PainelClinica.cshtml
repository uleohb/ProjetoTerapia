@page
@model ProjetoTerapia.Pages.PainelClinicaModel

<div class="painel-container">

    <!-- BG -->
    <div class="blur blur-1"></div>
    <div class="blur blur-2"></div>

    <div class="topo-painel">

        <div class="logo-area">

            <img src="/imagem/logo.png" class="logo-painel" />

            <div>
                <span class="badge-painel">
                    Painel Profissional
                </span>

                <h1>
                    @(string.IsNullOrEmpty(Model.Clinica?.Nome)
                                        ? "Profissional"
                                        : Model.Clinica.Nome)
                </h1>

                <p>
                    Gerencie seus atendimentos e informações profissionais.
                </p>
            </div>

        </div>

        <a href="/Teste" class="btn-voltar-site">
            Voltar ao site
        </a>

    </div>

    @if (Model.Clinica != null && !Model.Clinica.PerfilCompleto)
    {
        <div class="alerta-perfil">

            <div>
                <span class="tag-alerta">
                     Perfil incompleto
                </span>

                <h3>
                    Finalize seu cadastro profissional
                </h3>

                <p>
                    Adicione suas informações para que sua clínica
                    possa ser analisada e aprovada pela plataforma.
                </p>
            </div>

            <a href="/CadastroClinica"
               class="btn-completar">

                Completar perfil

            </a>

        </div>
    }

    @if (Model.Clinica != null)
    {
        <div class="titulo-secao">
            <h2>Informações da Conta</h2>
            <p>Resumo da sua clínica e assinatura.</p>
        </div>

        <div class="grid-cards">

            <div class="card-dashboard">

                <div class="icone-card">
                    <i class="fa-solid fa-building"></i>
                </div>

                <h3>Clínica</h3>

                <p>@Model.Clinica.Nome</p>

            </div>

            <div class="card-dashboard">

                <div class= "icone-card">
                 <i class="fa-regular fa-envelope"></i>
                </div>

                <h3>Email</h3>

                <p>@Model.Clinica.Email</p>

            </div>

            <div class="card-dashboard">

				<div class="icone-card">
                 <i class="fa-solid fa-phone"></i>
                </div>

                <h3>Telefone</h3>

                <p>@Model.Clinica.Telefone</p>

            </div>

            <div class="card-dashboard">

				<div class="icone-card">
                 <i class="fa-solid fa-wallet"></i>
                </div>
                 
                <h3>Plano</h3>

                <p>R$ @Model.Clinica.Valor</p>

            </div>

        </div>

        <div class="card-status">

            <div>

                <h2>Status da Assinatura</h2>

                <p>
                    Sua clínica está atualmente:
                </p>

            </div>

            <div class="status-area">

                @if (Model.Clinica.Pago)
                {
                    <span class="status ativo">
                         Ativo
                    </span>
                }
                else
                {
                    <span class="status pendente">
                         Pendente
                    </span>
                }

            </div>

        </div>

        <div class="titulo-secao">
            <h2>Área Operacional</h2>
            <p>Gerencie seu perfil, agenda e desempenho.</p>
        </div>

        <div class="grid-operacional">

            <a href="/AgendaClinica" class="card-operacional">

                <div class="topo-operacional">
                    <i class="fa-regular fa-calendar"></i>
                </div>

                <h3>Agenda</h3>

                <p>
                    Gerencie consultas e horários disponíveis.
                </p>

            </a>

            <a href="#" class="card-operacional">

                <div class="topo-operacional">
                    <i class="fa-solid fa-user-group"></i>
                </div>

                <h3>Pacientes</h3>

                <p>
                    @Model.Clinica.Visualizacoes visualizações
                </p>

                <small>
                    @Model.Clinica.CliquesWhatsapp contatos iniciados
                </small>

            </a>

            <a href="#" class="card-operacional">

                <div class="topo-operacional">
                    <i class="fa-solid fa-chart-line"></i>
                </div>

                <h3>Financeiro</h3>

                <p>
                    Acompanhe pagamentos e faturamento.
                </p>

            </a>

            <a href="/CadastroClinica" class="card-operacional">

                <div class="topo-operacional">
                    <i class="fa-regular fa-id-card"></i>
                </div>

                <h3>Perfil Profissional</h3>

                <p>
                    Atualize suas informações públicas.
                </p>

            </a>

        </div>

        <div class="acoes-dashboard">

            <a href="/CadastroClinica" class="btn-dashboard principal">
                Editar perfil
            </a>

            <a href="/Contato" class="btn-dashboard secundario">
                Falar com suporte
            </a>

        </div>
    }
    else
    {
        <div class="erro-card">

            <h2>
                Erro ao carregar os dados da clínica
            </h2>

            <a href="/LoginClinica" class="btn-dashboard principal">
                Fazer login novamente
            </a>

        </div>
    }

</div>


<!-- Ícones FontAwesome -->
<link rel="stylesheet"
	  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" /> 

<style>

    body {
        background: #f8fafc;
        margin: 0;
        padding: 0;
    }

    .painel-container {
        position: relative;
        overflow: hidden;
        min-height: 100vh;
        padding: 60px 40px;
        max-width: 1200px;
        margin: auto;
    }

    .blur {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        z-index: 0;
    }

    .blur-1 {
        width: 300px;
        height: 300px;
        background: rgba(124,58,237,0.12);
        top: -100px;
        left: -100px;
    }

    .blur-2 {
        width: 280px;
        height: 280px;
        background: rgba(37,99,235,0.12);
        bottom: -120px;
        right: -120px;
    }

    .topo-painel {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 50px;
        flex-wrap: wrap;
    }

    .logo-area {
        display: flex;
        align-items: flex-start;
        gap: 28px;
    }

    .logo-painel {
        width: 260px;
        max-width: 100%;
        height: auto;
        object-fit: contain;
    }

    .badge-painel {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(37,99,235,.08);
        color: #1d4ed8;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 14px;
    }

    .topo-painel h1 {
        font-size: 30px;
        max-width: 600px;
        margin: 0 0 10px;
        line-height: 1.1;
        font-weight: 700;
        letter-spacing: -1px;
        color: #0f172a;
    }

    .topo-painel p {
        color: #64748b;
        font-size: 18px;
        max-width: 600px;
    }

    .btn-voltar-site {
        padding: 16px 24px;
        border-radius: 16px;
        text-decoration: none;
        background: white;
        border: 1px solid #dbeafe;
        color: #2563eb;
        font-weight: 600;
        transition: .2s;
    }

        .btn-voltar-site:hover {
            transform: translateY(-2px);
        }

    .grid-cards {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 22px;
        margin-bottom: 35px;
    }

    .card-dashboard {
        background: rgba(255,255,255,0.85);
        padding: 32px;
        border-radius: 28px;
        border: 1px solid rgba(226,232,240,0.8);
        backdrop-filter: blur(14px);
        box-shadow: 0 10px 30px rgba(15,23,42,0.05);
        transition: .25s;
    }

    .icone-card {
        width: 62px;
        height: 62px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 22px;
        background: linear-gradient( 135deg, rgba(37,99,235,.10), rgba(124,58,237,.10) );
        color: #2563eb;
        font-size: 24px;
    }

    .card-dashboard h3 {
        margin: 0 0 10px;
        color: #0f172a;
    }

    .card-dashboard p {
        margin: 0;
        color: #64748b;
        font-size: 17px;
    }

    .card-dashboard:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(15,23,42,0.08);
    }

    .card-status {
        position: relative;
        z-index: 2;
        background: white;
        border-radius: 28px;
        padding: 35px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        box-shadow: 0 10px 25px rgba(15,23,42,0.05);
        margin-bottom: 35px;
    }

        .card-status h2 {
            margin: 0 0 10px;
            color: #0f172a;
        }

        .card-status p {
            margin: 0;
            color: #64748b;
        }

    .status {
        padding: 14px 26px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: .3px;
    }

    .ativo {
        background: #dcfce7;
        color: #166534;
    }

    .pendente {
        background: #fef3c7;
        color: #92400e;
    }

    .acoes-dashboard {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
    }

    .btn-dashboard {
        padding: 18px 28px;
        border-radius: 18px;
        text-decoration: none;
        font-weight: 700;
        transition: .2s;
    }

        .btn-dashboard:hover {
            transform: translateY(-2px);
        }

        .btn-dashboard.principal {
            background: linear-gradient( 135deg, #2563eb, #0ea5e9 );
            color: white;
            box-shadow: 0 12px 30px rgba(37,99,235,.18);
        }

        .btn-dashboard.secundario {
            background: white;
            border: 1px solid #dbeafe;
            color: #2563eb;
        }

    .erro-card {
        background: white;
        padding: 40px;
        border-radius: 24px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(15,23,42,0.05);
    }

    @@media(max-width:768px) {

        .painel-container {
            padding: 40px 20px;
        }

        .topo-painel h1 {
            font-size: 42px;
        }
    }

    .alerta-perfil {
        position: relative;
        z-index: 2;
        margin-bottom: 35px;
        padding: 30px;
        border-radius: 28px;
        background: linear-gradient(135deg,#fff7ed,#fffbeb);
        border: 1px solid #fed7aa;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 25px;
        flex-wrap: wrap;
        box-shadow: 0 10px 25px rgba(15,23,42,0.04);
    }

    .tag-alerta {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(251,146,60,.15);
        color: #c2410c;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .alerta-perfil h3 {
        margin: 0 0 10px;
        color: #7c2d12;
        font-size: 28px;
    }

    .alerta-perfil p {
        margin: 0;
        color: #9a3412;
        max-width: 650px;
        line-height: 1.7;
    }

    .btn-completar {
        padding: 18px 26px;
        border-radius: 18px;
        text-decoration: none;
        background: linear-gradient(135deg,#f97316,#ea580c);
        color: white;


        font-weight: 700;
        transition: .2s;
        white-space: nowrap;
    }

        .btn-completar:hover {
            transform: translateY(-2px);
        }

    .grid-operacional {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
        gap: 22px;
        margin-bottom: 35px;
    }

    .card-operacional {
        background: rgba(255,255,255,0.88);
        border: 1px solid rgba(226,232,240,.9);
        border-radius: 28px;
        padding: 28px;
        text-decoration: none;
        transition: .25s;
        backdrop-filter: blur(14px);
        box-shadow: 0 10px 30px rgba(15,23,42,.05);
    }

        .card-operacional:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 45px rgba(15,23,42,.08);
        }

    .topo-operacional {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 22px;
        background: linear-gradient( 135deg, rgba(37,99,235,.10), rgba(124,58,237,.10) );
    }

        .topo-operacional i {
            font-size: 22px;
            color: #2563eb;
        }

    .card-operacional h3 {
        margin: 0 0 10px;
        color: #0f172a;
        font-size: 20px;
    }

    .card-operacional p {
        margin: 0;
        color: #64748b;
        line-height: 1.7;
    }

    .titulo-secao {
        position: relative;
        z-index: 2;
        margin-bottom: 22px;
    }

        .titulo-secao h2 {
            margin: 0 0 8px;
            font-size: 28px;
            color: #0f172a;
        }

        .titulo-secao p {
            margin: 0;
            color: #64748b;
        }

</style>