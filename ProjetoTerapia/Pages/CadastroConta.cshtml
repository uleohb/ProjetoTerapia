@page
@model ProjetoTerapia.Pages.CadastroContaModel

<div class="container-auth">

    <div class="auth-wrapper">

        <!-- LADO ESQUERDO -->
        <div class="side-image">

            <div class="gradient-circle circle-1"></div>
            <div class="gradient-circle circle-2"></div>

            <div class="content-side">

                <span class="badge-side">
                    🏥 Plataforma para profissionais da saúde
                </span>

                <h1>
                    Gerencie seus atendimentos
                    com tecnologia e credibilidade.
                </h1>

                <p>
                    Cadastre sua clínica, conecte-se com novos pacientes,
                    organize consultas e fortaleça sua presença profissional
                    em uma plataforma moderna e segura.
                </p>

                <div class="cards-preview">

                    <div class="preview-card">
                        <div class="icon-card">📅</div>

                        <div>
                            <strong>Agenda Inteligente</strong>
                            <span>Organize consultas e horários</span>
                        </div>
                    </div>

                    <div class="preview-card">
                        <div class="icon-card">👥</div>

                        <div>
                            <strong>Captação de Pacientes</strong>
                            <span>Aumente sua visibilidade profissional</span>
                        </div>
                    </div>

                    <div class="preview-card">
                        <div class="icon-card">🛡️</div>

                        <div>
                            <strong>Ambiente Seguro</strong>
                            <span>Privacidade e proteção de dados</span>
                        </div>
                    </div>

                </div>

            </div>

        </div>

        <!-- LADO DIREITO -->
        <div class="card-auth">

            <img src="/imagem/logo.png?v=2"
                 class="logo-auth"
                 alt="Logo AlinhaMente" />

            <h2>Cadastro Profissional</h2>

            <p class="sub">
                Crie sua conta profissional e comece
                a atender pacientes com mais organização,
                visibilidade e praticidade.
            </p>

            <!-- GOOGLE -->
            <a href="/CadastroConta?handler=LoginGoogle"
               class="btn-google">

                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                     class="google-icon" />

                <span>Continuar com Google</span>

            </a>

            <div class="divider">
                <span>ou</span>
            </div>

            @if (!ModelState.IsValid)
            {
                <div class="validation-box">

                    @foreach (var erro in ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@erro.ErrorMessage</p>
                    }

                </div>
            }

            <!-- FORM -->
            <form method="post">

                <input type="email"
                       asp-for="Email"
                       placeholder="Email"
                       required />

                <input type="password"
                       asp-for="Senha"
                       placeholder="Senha"
                       required />

                <input type="password"
                       asp-for="ConfirmarSenha"
                       placeholder="Confirmar senha"
                       required />

                <button type="submit" class="btn-primary">
                    Criar conta
                </button>

            </form>

            <p class="link-login">
                Já tem conta?
                <a href="/LoginClinica">Entrar</a>
            </p>

        </div>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    body {
        overflow-y: auto;
        overflow-x: hidden;
    }

    .container-auth {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
        background: linear-gradient(135deg,#06121f,#0b1b2b,#10263a);
    }


    .auth-wrapper {
        width: 100%;
        max-width: 1450px;
        min-height: auto;
        display: flex;
        overflow: hidden;
        border-radius: 35px;
        background: rgba(255,255,255,0.04);
        backdrop-filter: blur(10px);
        box-shadow: 0 30px 80px rgba(0,0,0,0.35);
    }

    .bg-effect {
        position: absolute;
        width: 500px;
        height: 500px;
        background: rgba(168,85,247,0.18);
        border-radius: 50%;
        filter: blur(120px);
        top: -120px;
        right: -100px;
    }

    .card-auth {
        position: relative;
        z-index: 1;
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(10px);
        padding: 35px;
        border-radius: 28px;
        width: 45%;
        max-width: 520px;
        margin: auto;
        box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        text-align: center;
    }

    .logo-auth {
        width: 280px;
        max-width: 100%;
        margin-bottom: 10px;
        object-fit: contain;
        display: block;
        margin-left: auto;
        margin-right: auto;
    }

    .card-auth h1 {
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 8px;
        color: #7c3aed;
        letter-spacing: -1px;
    }

    .card-auth h2 {
        font-size: 26px;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .sub {
        color: #64748b;
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    .google-icon {
        width: 22px;
        margin-right: 10px;
    }


    .btn-google {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 14px;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        background: white;
        text-decoration: none;
        color: #334155;
        font-weight: 500;
        transition: 0.25s;
        margin-bottom: 18px;
    }

        .btn-google:hover {
            transform: translateY(-2px);
            border-color: #cbd5e1;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }

    .divider {
        position: relative;
        margin: 25px 0;
        text-align: center;
    }

        .divider::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 1px;
            background: #e2e8f0;
            left: 0;
            top: 50%;
        }

        .divider span {
            position: relative;
            background: white;
            padding: 0 14px;
            color: #94a3b8;
            font-size: 14px;
        }

    form {
        margin-top: 10px;
    }

    input {
        width: 100%;
        padding: 16px;
        margin-bottom: 14px;
        border-radius: 14px;
        border: 1px solid #dbeafe;
        background: #f8fafc;
        font-size: 15px;
        transition: 0.2s;
        outline: none;
    }

        input:focus {
            border-color: #7c3aed;
            background: white;
            box-shadow: 0 0 0 4px rgba(124,58,237,0.10);
        }

    .btn-primary {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #7c3aed, #2563eb, #06b6d4);
        color: white;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.25s;
        margin-top: 5px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(124,58,237,0.25);
        }

    .link-login {
        margin-top: 22px;
        color: #64748b;
        font-size: 15px;
    }

        .link-login a {
            color: #7c3aed;
            text-decoration: none;
            font-weight: 600;
        }

            .link-login a:hover {
                text-decoration: underline;
            }


    .side-image {
        width: 55%;
        position: relative;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

        .side-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient( 90deg, rgba(15,23,42,0.15), rgba(15,23,42,0.45) );
        }

@@keyframes float {

    0% {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-12px);
    }

    100% {
        transform: translateY(0px);
    }
}

    @@media(max-width: 900px) {

        * {
            max-width: 100%;
        }

        body {
            overflow-x: hidden;
        }

        .container-auth {
            width: 100%;
            padding: 12px;
            min-height: auto;
            align-items: flex-start;
        }

        .auth-wrapper {
            width: 100%;
            min-height: auto;
            display: block;
            border-radius: 24px;
        }

        .side-image {
            display: none;
        }

        .card-auth {
            width: 100%;
            max-width: 100%;
            margin: 0;
            border-radius: 24px;
            padding: 28px 22px;
            box-sizing: border-box;
        }

        .logo-auth {
            width: 200px;
        }

        .card-auth h2 {
            font-size: 24px;
        }

        .sub {
            font-size: 14px;
            line-height: 1.5;
        }

        input {
            padding: 14px;
            font-size: 16px;
        }

        .btn-primary,
        .btn-google {
            padding: 15px;
        }
    }
}