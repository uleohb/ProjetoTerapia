@page
@model ProjetoTerapia.Pages.EditarConsultaModel

<div class="editar-layout">

    <div class="editar-card">

        <img src="/imagem/logo.png" class="logo-editar" />

        <span class="badge-editar">
            Consulta
        </span>

        <h1>
            Editar Consulta
        </h1>

        <p>
            Atualize as informações do atendimento.
        </p>

        <form method="post">

            <input type="hidden" asp-for="Consulta.Id" />

            <div class="campo">

                <label>Paciente</label>

                <input asp-for="Consulta.NomePaciente"
                       class="input-custom" />

            </div>

            <div class="campo">

                <label>Tipo de Atendimento</label>

                <input asp-for="Consulta.TipoAtendimento"
                       class="input-custom" />

            </div>

            <div class="campo">

                <label>Data e Hora</label>

                <input asp-for="Consulta.DataConsulta"
                       type="datetime-local"
                       class="input-custom" />

            </div>

            <div class="campo">

                <label>Status</label>

                <select asp-for="Consulta.Status"
                        class="input-custom">

                    <option>Pendente</option>
                    <option>Confirmado</option>
                    <option>Cancelado</option>

                </select>

            </div>

            <div class="acoes">

                <a href="/AgendaClinica"
                   class="btn-voltar">
                    Voltar
                </a>

                <button type="submit"
                        class="btn-salvar">

                    Salvar Alterações

                </button>

            </div>

        </form>

    </div>

</div>

<style>

    body {
        margin: 0;
        background: #f1f5f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .editar-layout {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .editar-card {
        width: 100%;
        max-width: 700px;
        background: white;
        border-radius: 30px;
        padding: 45px;
        box-shadow: 0 20px 50px rgba(15,23,42,.08);
        border: 1px solid #e2e8f0;
    }

    .logo-editar {
        width: 220px;
        display: block;
        margin: 0 auto 25px;
    }

    .badge-editar {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(37,99,235,.08);
        color: #2563eb;
        font-weight: 700;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .editar-card h1 {
        margin: 0;
        color: #0f172a;
        font-size: 34px;
    }

    .editar-card p {
        color: #64748b;
        margin-top: 10px;
        margin-bottom: 35px;
    }

    .campo {
        margin-bottom: 22px;
    }

        .campo label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #334155;
        }

    .input-custom {
        width: 100%;
        box-sizing: border-box;
        padding: 16px;
        border-radius: 16px;
        border: 1px solid #cbd5e1;
        font-size: 15px;
        transition: .2s;
        background: white;
    }

        .input-custom:focus {
            outline: none;
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37,99,235,.10);
        }

    .acoes {
        display: flex;
        justify-content: space-between;
        gap: 15px;
        margin-top: 35px;
    }

    .btn-voltar {
        text-decoration: none;
        padding: 15px 25px;
        border-radius: 16px;
        background: #e2e8f0;
        color: #334155;
        font-weight: 700;
        transition: .2s;
    }

        .btn-voltar:hover {
            background: #cbd5e1;
        }

    .btn-salvar {
        border: none;
        padding: 15px 25px;
        border-radius: 16px;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 12px 30px rgba(37,99,235,.18);
    }

        .btn-salvar:hover {
            transform: translateY(-2px);
        }

</style>