@page
@model ProjetoTerapia.Pages.AgendaClinicaModel

<div class="agenda-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <img src="/imagem/logo.png" class="logo-sidebar" />

        <div class="menu-sidebar">

            <a href="/PainelClinica" class="menu-item">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>

            <a href="/AgendaClinica" class="menu-item ativo">
                <i class="fa-regular fa-calendar"></i>
                Agenda
            </a>

            <a href="#" class="menu-item">
                <i class="fa-solid fa-user-group"></i>
                Pacientes
            </a>

            <a href="/PerfilClinica" class="menu-item">
                <i class="fa-regular fa-id-card"></i>
                Perfil
            </a>

        </div>

    </aside>

    <!-- CONTEÚDO -->
    <main class="agenda-content">

        <!-- TOPO -->
        <div class="topo-agenda">

            <div class="logo-agenda-area">

                <div class="titulo-agenda">

                    <span class="badge-agenda">
                        Agenda Profissional
                    </span>

                    <h1>
                        Agenda
                    </h1>

                    <p>
                        Gerencie horários, consultas e pacientes
                        em uma experiência organizada e profissional.
                    </p>

                </div>

            </div>

            <a href="/NovaConsulta" class="btn-nova-consulta">
                Nova Consulta
            </a>

        </div>

        <!-- RESUMO -->
        <div class="grid-resumo">

            <div class="card-resumo">
                <span>Consultas Hoje</span>
                <h2>@Model.ConsultasHoje</h2>
            </div>

            <div class="card-resumo">
                <span>Confirmadas</span>
                <h2>@Model.Confirmadas</h2>
            </div>

            <div class="card-resumo">
                <span>Pendentes</span>
                <h2>@Model.Pendentes</h2>
            </div>

            <div class="card-resumo">
                <span>Canceladas</span>
                <h2>@Model.Canceladas</h2>
            </div>

        </div>

       

        <!-- CONSULTAS -->
        <div class="consultas-box">

            <form method="get" class="busca-agenda">

                <input type="text"
                       name="Busca"
                       value="@Model.Busca"
                       placeholder="Buscar paciente..."
                       class="campo-busca" />

                <button type="submit" class="btn-buscar">
                    Buscar
                </button>

            </form>

            <div class="titulo-box">

                <div>
                    <h3>Próximos Atendimentos</h3>
                    <p>Consultas agendadas para hoje</p>
                </div>

            </div>

            @if (Model.Consultas.Any())
            {
                @foreach (var consulta in Model.Consultas)
                {
                    <div class="consulta-card @(consulta.DataConsulta?.Date == DateTime.Today ? "consulta-hoje" : "")">

                        <div class="consulta-esquerda">

                            <div class="avatar">
                                @consulta.NomePaciente.Substring(0, 1).ToUpper()
                            </div>

                            <div class="dados-paciente">

                                <h4>@consulta.NomePaciente</h4>

                                <div class="infos-consulta">

                                    <span>
                                        <i class="fa-regular fa-calendar"></i>
                                        @(consulta.DataConsulta?.ToString("dd/MM/yyyy"))
                                    </span>

                                    <span>
                                        <i class="fa-regular fa-clock"></i>
                                        @(consulta.DataConsulta?.ToString("HH:mm"))
                                    </span>

                                    <span>
                                        <i class="fa-solid fa-stethoscope"></i>
                                        @consulta.TipoAtendimento
                                    </span>

                                </div>

                            </div>

                        </div>

                        <div class="consulta-direita">

                            <div class="status
                    @(consulta.Status == "Confirmado" ? "confirmado" :
                                               consulta.Status == "Pendente" ? "pendente" :
                                               "cancelado")">

                        @consulta.Status

                            </div>

                            <div class="acoes-consulta">

                                <a href="/EditarConsulta?id=@consulta.Id"
                                   class="btn-acao btn-editar">

                                    <i class="fa-solid fa-pen"></i>

                                </a>

                                <form method="post" asp-page-handler="Confirmar">
                                    <input type="hidden" name="id" value="@consulta.Id" />
                                    <button type="submit" class="btn-acao btn-confirmar">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                </form>

                                <form method="post" asp-page-handler="Cancelar">
                                    <input type="hidden" name="id" value="@consulta.Id" />
                                    <button type="submit" class="btn-acao btn-cancelar">
                                        <i class="fa-solid fa-ban"></i>
                                    </button>
                                </form>

                                <form method="post"
                                      asp-page-handler="Excluir"
                                      onsubmit="return confirm('Deseja excluir esta consulta?')">

                                    <input type="hidden" name="id" value="@consulta.Id" />

                                    <button type="submit"
                                            class="btn-acao btn-excluir">

                                        <i class="fa-solid fa-trash"></i>

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="consulta-vazia">

                    <i class="fa-regular fa-calendar-xmark"></i>

                    <h3>
                        Nenhuma consulta cadastrada
                    </h3>

                    <p>
                        Quando novos atendimentos forem criados,
                        eles aparecerão aqui.
                    </p>

                </div>
            }

        </div>

    </main>

</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>

    /* =========================
       BASE
    ========================= */

    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top right, rgba(37,99,235,.05), transparent 25%), radial-gradient(circle at bottom left, rgba(14,165,233,.04), transparent 30%), #f8fafc;
    }

    .agenda-layout {
        display: flex;
        min-height: 100vh;
    }

    /* =========================
       SIDEBAR
    ========================= */

    .sidebar {
        width: 270px;
        padding: 32px 24px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);
        border-right: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        box-shadow: 0 0 30px rgba(15,23,42,.03);
    }

        .sidebar::before {
            content: "";
            position: absolute;
            width: 240px;
            height: 240px;
            top: -120px;
            left: -120px;
            border-radius: 50%;
            background: rgba(37,99,235,.08);
            filter: blur(60px);
        }

        .sidebar::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            bottom: -120px;
            right: -120px;
            border-radius: 50%;
            background: rgba(14,165,233,.08);
            filter: blur(60px);
        }

    .logo-sidebar {
        width: 210px;
        object-fit: contain;
        margin-bottom: 45px;
        position: relative;
        z-index: 2;
    }

    .menu-sidebar {
        display: flex;
        flex-direction: column;
        gap: 12px;
        position: relative;
        z-index: 2;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 15px 18px;
        border-radius: 16px;
        text-decoration: none;
        color: #475569;
        font-weight: 600;
        transition: .25s;
    }

        .menu-item i {
            font-size: 15px;
        }

        .menu-item:hover {
            background: rgba(37,99,235,.05);
            color: #2563eb;
            transform: translateX(4px);
        }

        .menu-item.ativo {
            background: linear-gradient(135deg,#2563eb,#06b6d4);
            color: white;
            box-shadow: 0 8px 20px rgba(37,99,235,.18);
        }

    /* =========================
       CONTEÚDO
    ========================= */

    .agenda-content {
        flex: 1;
        padding: 45px;
    }

    /* =========================
       TOPO
    ========================= */

    .topo-agenda {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
        margin-bottom: 45px;
    }

    .titulo-agenda {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .badge-agenda {
        display: inline-flex;
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(37,99,235,.06);
        color: #3b82f6;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
        border: 1px solid rgba(37,99,235,.08);
    }

    .topo-agenda h1 {
        margin: 0;
        font-size: 34px;
        font-weight: 700;
        letter-spacing: -1px;
        color: #0f172a;
    }

    .topo-agenda p {
        margin: 0;
        color: #64748b;
        font-size: 15px;
        line-height: 1.7;
        max-width: 650px;
    }

    /* =========================
       BOTÃO
    ========================= */

    .btn-nova-consulta {
        text-decoration: none;
        border: none;
        padding: 16px 28px;
        border-radius: 18px;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
        box-shadow: 0 12px 30px rgba(37,99,235,.18);
    }

        .btn-nova-consulta:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(37,99,235,.25);
        }

    /* =========================
       RESUMO
    ========================= */

    .grid-resumo {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-bottom: 35px;
    }

    .card-resumo {
        background: rgba(255,255,255,.75);
        backdrop-filter: blur(18px);
        border-radius: 24px;
        padding: 26px;
        border: 1px solid rgba(255,255,255,.4);
        box-shadow: 0 10px 30px rgba(15,23,42,.04);
        transition: .25s;
    }

        .card-resumo:hover {
            transform: translateY(-4px);
        }

        .card-resumo span {
            color: #64748b;
            font-size: 14px;
        }

        .card-resumo h2 {
            margin: 14px 0 0;
            font-size: 34px;
            color: #0f172a;
        }

    /* =========================
       PERFIL PÚBLICO
    ========================= */

    .perfil-publico-box {
        margin-bottom: 35px;
        padding: 30px;
        border-radius: 30px;
        background: rgba(255,255,255,.85);
        backdrop-filter: blur(18px);
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15,23,42,.04);
    }

    .perfil-publico-topo {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 30px;
    }

    .badge-publico {
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(37,99,235,.08);
        color: #2563eb;
        font-size: 12px;
        font-weight: 700;
    }

    .status-publico {
        padding: 12px 18px;
        border-radius: 16px;
        font-weight: 700;
    }

        .status-publico.aprovado {
            background: #dcfce7;
            color: #166534;
        }

    .perfil-publico-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .perfil-esquerda {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .avatar-publico {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg,#2563eb,#06b6d4);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 700;
    }

    .descricao-publica {
        margin-top: 12px;
        color: #64748b;
        line-height: 1.7;
        max-width: 600px;
    }

    .perfil-direita {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .mini-info {
        padding: 14px 18px;
        border-radius: 16px;
        background: #f8fafc;
        color: #334155;
        font-weight: 600;
    }

        .mini-info.destaque {
            background: linear-gradient(135deg,#2563eb,#06b6d4);
            color: white;
        }

    /* =========================
       CONSULTAS
    ========================= */

    .consultas-box {
        background: rgba(255,255,255,.95);
        border-radius: 30px;
        padding: 30px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15,23,42,.04);
    }

    .busca-agenda {
        display: flex;
        gap: 12px;
        margin-bottom: 25px;
    }

    .campo-busca {
        flex: 1;
        padding: 14px 18px;
        border-radius: 14px;
        border: 1px solid #dbe2ea;
        font-size: 14px;
        outline: none;
    }

        .campo-busca:focus {
            border-color: #2563eb;
        }

    .btn-buscar {
        border: none;
        background: #2563eb;
        color: white;
        padding: 14px 24px;
        border-radius: 14px;
        cursor: pointer;
        font-weight: 600;
    }

    .consulta-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 25px;
        flex-wrap: wrap;
        padding: 22px;
        margin-bottom: 16px;
        border-radius: 24px;
        background: #f8fafc;
        border: 1px solid #eef2f7;
        transition: .25s;
    }

        .consulta-card:hover {
            background: white;
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(15,23,42,.08);
        }

    .consulta-hoje {
        border-left: 5px solid #2563eb;
        background: white;
    }

    .consulta-esquerda {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37,99,235,.18);
    }

    .dados-paciente h4 {
        margin: 0 0 10px;
        color: #0f172a;
    }

    .infos-consulta {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
    }

        .infos-consulta span {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #64748b;
            font-size: 13px;
        }

    .consulta-direita {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* =========================
       STATUS
    ========================= */

    .status {
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .confirmado {
        background: #dcfce7;
        color: #166534;
    }

    .pendente {
        background: #fef3c7;
        color: #92400e;
    }

    .cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    /* =========================
       AÇÕES
    ========================= */

    .acoes-consulta {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .acoes-consulta form {
            margin: 0;
        }

    .btn-acao {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
        transition: .25s;
        font-size: 14px;
    }

        .btn-acao:hover {
            transform: translateY(-2px);
        }

    .btn-editar {
        background: rgba(37,99,235,.10);
        color: #2563eb;
    }

    .btn-confirmar {
        background: rgba(14,165,233,.10);
        color: #0284c7;
    }

    .btn-cancelar {
        background: rgba(148,163,184,.15);
        color: #64748b;
    }

    .btn-excluir {
        background: rgba(239,68,68,.08);
        color: #dc2626;
    }

    /* =========================
       VAZIO
    ========================= */

    .consulta-vazia {
        text-align: center;
        padding: 60px 30px;
    }

        .consulta-vazia i {
            font-size: 42px;
            color: #94a3b8;
            margin-bottom: 20px;
        }

    /* =========================
       RESPONSIVO
    ========================= */

    @@media (max-width: 900px) {

        .agenda-layout {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            box-sizing: border-box;
        }

        .agenda-content {
            padding: 25px;
        }

        .topo-agenda {
            flex-direction: column;
            align-items: flex-start;
        }

        .consulta-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .consulta-direita {
            width: 100%;
            justify-content: space-between;
        }

        .perfil-publico-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .perfil-esquerda {
            flex-direction: column;
            align-items: flex-start;
        }

        .busca-agenda {
            flex-direction: column;
        }

        .btn-buscar {
            width: 100%;
        }
    }

</style>