@page
@model ProjetoTerapia.Pages.AgendaClinicaModel

<div class="agenda-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <img src="/imagem/logo.png" class="logo-sidebar" />

        <div class="menu-sidebar">

            <a href="/PainelClinica" class="menu-item">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>

            <a href="/AgendaClinica" class="menu-item ativo">
                <i class="fa-regular fa-calendar"></i>
                Agenda
            </a>

            <a href="#" class="menu-item">
                <i class="fa-solid fa-user-group"></i>
                Pacientes
            </a>

            <a href="/CadastroClinica" class="menu-item">
                <i class="fa-regular fa-id-card"></i>
                Perfil
            </a>

        </div>

    </aside>

    <!-- CONTEÚDO -->
    <main class="agenda-content">

        <!-- TOPO -->
        <div class="topo-agenda">

            <div class="logo-agenda-area">

                <div class="titulo-agenda">

                    <span class="badge-agenda">
                        Agenda Profissional
                    </span>

                    <h1>
                        Agenda
                    </h1>

                    <p>
                        Gerencie horários, consultas e pacientes
                        em uma experiência organizada e profissional.
                    </p>

                </div>

            </div>

            <a href="/NovaConsulta" class="btn-nova-consulta">
                Nova Consulta
            </a>

        </div>

        <!-- RESUMO -->
        <div class="grid-resumo">

            <div class="card-resumo">
                <span>Consultas Hoje</span>
                <h2>@Model.ConsultasHoje</h2>
            </div>

            <div class="card-resumo">
                <span>Confirmadas</span>
                <h2>@Model.Confirmadas</h2>
            </div>

            <div class="card-resumo">
                <span>Pendentes</span>
                <h2>@Model.Pendentes</h2>
            </div>

            <div class="card-resumo">
                <span>Canceladas</span>
                <h2>@Model.Canceladas</h2>
            </div>

        </div>

        <!-- CONSULTAS -->
        <div class="consultas-box">

            <div class="titulo-box">

                <div>
                    <h3>Próximos Atendimentos</h3>
                    <p>Consultas agendadas para hoje</p>
                </div>

            </div>

            @if (Model.Consultas.Any())
            {
                @foreach (var consulta in Model.Consultas)
                {
                    <div class="consulta-card">

                        <div class="usuario">

                            <div class="avatar">
                                @consulta.NomePaciente.Substring(0, 1).ToUpper()
                            </div>

                            <div>

                                <h4>@consulta.NomePaciente</h4>

                                <span>
                                    @consulta.TipoAtendimento
                                </span>

                            </div>

                        </div>

                        <div class="consulta-hora">
                            @(consulta.DataConsulta.HasValue
                                                ? consulta.DataConsulta.Value.ToString("dd/MM/yyyy HH:mm")
                                                : "-")
                        </div>

                        <div class="status
                          @(consulta.Status == "Confirmado" ? "confirmado" :
                                   consulta.Status == "Pendente" ? "pendente" :
                                   "cancelado")">

                           @consulta.Status

                        </div>

                        <div class="acoes-consulta">

                            <a href="/EditarConsulta?id=@consulta.Id"
                               class="btn-acao btn-editar">

                                <i class="fa-solid fa-pen"></i>

                            </a>

                            <form method="post" asp-page-handler="Confirmar">

                                <input type="hidden"
                                       name="id"
                                       value="@consulta.Id" />

                                <button type="submit"
                                        class="btn-acao btn-confirmar">

                                    <i class="fa-solid fa-check"></i>

                                </button>

                            </form>

                            <form method="post" asp-page-handler="Cancelar">

                                <input type="hidden"
                                       name="id"
                                       value="@consulta.Id" />

                                <button type="submit"
                                        class="btn-acao btn-cancelar">

                                    <i class="fa-solid fa-ban"></i>

                                </button>

                            </form>

                            <form method="post"
                                  asp-page-handler="Excluir"
                                  onsubmit="return confirm('Deseja excluir esta consulta?')">

                                <input type="hidden"
                                       name="id"
                                       value="@consulta.Id" />

                                <button type="submit"
                                        class="btn-acao btn-excluir">

                                    <i class="fa-solid fa-trash"></i>

                                </button>

                            </form>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="consulta-vazia">

                    <i class="fa-regular fa-calendar-xmark"></i>

                    <h3>
                        Nenhuma consulta cadastrada
                    </h3>

                    <p>
                        Quando novos atendimentos forem criados,
                        eles aparecerão aqui.
                    </p>

                </div>
            }

        </div>

    </main>

</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>

    /* =========================
           BASE
        ========================== */

    body {
        margin: 0;
        background: #f1f5f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .agenda-layout {
        display: flex;
        min-height: 100vh;
    }

    /* =========================
       SIDEBAR
    ========================== */

    .sidebar {
        width: 270px;
        padding: 32px 24px;
        position: relative;
        overflow: hidden;
        background: linear-gradient( 180deg, #ffffff 0%, #f8fbff 100% );
        border-right: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        box-shadow: 0 0 30px rgba(15,23,42,.03);
    }

        /* efeito suave */
        .sidebar::before {
            content: "";
            position: absolute;
            width: 240px;
            height: 240px;
            top: -120px;
            left: -120px;
            border-radius: 50%;
            background: rgba(37,99,235,.08);
            filter: blur(60px);
        }

        .sidebar::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            bottom: -120px;
            right: -120px;
            border-radius: 50%;
            background: rgba(14,165,233,.08);
            filter: blur(60px);
        }

    .logo-sidebar {
        width: 210px;
        object-fit: contain;
        margin-bottom: 45px;
        position: relative;
        z-index: 2;
    }

    .menu-sidebar {
        display: flex;
        flex-direction: column;
        gap: 12px;
        position: relative;
        z-index: 2;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 18px;
        border-radius: 18px;
        text-decoration: none;
        color: #475569;
        font-weight: 600;
        transition: .25s;
    }

        .menu-item i {
            font-size: 15px;
        }

        .menu-item:hover {
            background: rgba(37,99,235,.06);
            color: #2563eb;
            transform: translateX(3px);
        }

        .menu-item.ativo {
            background: linear-gradient( 135deg, #2563eb, #0ea5e9 );
            color: white;
            box-shadow: 0 12px 25px rgba(37,99,235,.18);
        }

    /* =========================
           CONTEÚDO
        ========================== */

    .agenda-content {
        flex: 1;
        padding: 45px;
    }

    /* =========================
           TOPO
        ========================== */

    .topo-agenda {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
        margin-bottom: 45px;
    }

    .titulo-agenda {
        display: flex;
        flex-direction: column;
    }

    .badge-agenda {
        display: inline-flex;
        width: fit-content;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(37,99,235,.08);
        color: #2563eb;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .topo-agenda h1 {
        margin: 0 0 10px;
        font-size: 34px;
        line-height: 1.1;
        font-weight: 700;
        letter-spacing: -.8px;
        color: #0f172a;
    }

    .topo-agenda p {
        margin: 0;
        color: #64748b;
        font-size: 15px;
        line-height: 1.7;
        max-width: 620px;
    }

    .btn-nova-consulta {
        text-decoration: none;
        border: none;
        padding: 16px 28px;
        border-radius: 18px;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
        box-shadow: 0 12px 30px rgba(37,99,235,.18);
    }

        .btn-nova-consulta:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(37,99,235,.25);
        }

    /* =========================
           CARDS RESUMO
        ========================== */

    .grid-resumo {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-bottom: 35px;
    }

    .card-resumo {
        background: rgba(255,255,255,.92);
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 26px;
        box-shadow: 0 10px 30px rgba(15,23,42,.04);
        transition: .2s;
    }

        .card-resumo:hover {
            transform: translateY(-3px);
        }

        .card-resumo span {
            color: #64748b;
            font-size: 14px;
        }

        .card-resumo h2 {
            margin: 14px 0 0;
            font-size: 34px;
            color: #0f172a;
        }

    /* =========================
           CONSULTAS
        ========================== */

    .consultas-box {
        background: rgba(255,255,255,.95);
        border-radius: 30px;
        padding: 30px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15,23,42,.04);
    }

    .titulo-box {
        margin-bottom: 25px;
    }

        .titulo-box h3 {
            margin: 0 0 8px;
            font-size: 24px;
            color: #0f172a;
        }

        .titulo-box p {
            margin: 0;
            color: #64748b;
            font-size: 14px;
        }

    /* =========================
           CONSULTA CARD
        ========================== */

    .consulta-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        padding: 22px;
        margin-bottom: 16px;
        border-radius: 24px;
        background: #f8fafc;
        border: 1px solid #eef2f7;
        transition: .2s;
    }

        .consulta-card:hover {
            background: white;
            box-shadow: 0 10px 25px rgba(15,23,42,.05);
        }

    .usuario {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 15px;
        box-shadow: 0 8px 18px rgba(37,99,235,.18);
    }

    .usuario h4 {
        margin: 0 0 6px;
        font-size: 16px;
        color: #0f172a;
    }

    .usuario span {
        color: #64748b;
        font-size: 14px;
    }

    .consulta-hora {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    /* =========================
           STATUS
        ========================== */

    .status {
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .confirmado {
        background: #dcfce7;
        color: #166534;
    }

    .pendente {
        background: #fef3c7;
        color: #92400e;
    }

    /* =========================
           VAZIO
        ========================== */

    .consulta-vazia {
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(226,232,240,.8);
        border-radius: 30px;
        padding: 60px 30px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(15,23,42,.05);
    }

        .consulta-vazia i {
            font-size: 42px;
            color: #94a3b8;
            margin-bottom: 20px;
        }

        .consulta-vazia h3 {
            margin: 0 0 12px;
            font-size: 24px;
            color: #0f172a;
        }

        .consulta-vazia p {
            margin: 0;
            color: #64748b;
            line-height: 1.7;
        }

    /* =========================
           RESPONSIVO
        ========================== */

    @@media(max-width:900px) {

        .agenda-layout {
            flex-direction: column;
        }

        .sidebar {
            width: auto;
            border-right: none;
            border-bottom: 1px solid #e2e8f0;
        }

        .agenda-content {
            padding: 25px;
        }

        .logo-agenda {
            width: 220px;
        }

        .topo-agenda h1 {
            font-size: 28px;
        }
    }

    .cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    .acoes-consulta {
        display: flex;
        gap: 10px;
    }

    .acoes-consulta {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .acoes-consulta form {
            margin: 0;
        }

    .btn-acao {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
        transition: .25s;
        font-size: 14px;
    }

        .btn-acao:hover {
            transform: translateY(-2px);
        }

    /* Editar */

    .btn-editar {
        background: rgba(37,99,235,.10);
        color: #2563eb;
    }

        .btn-editar:hover {
            background: rgba(37,99,235,.18);
        }

    /* Confirmar */

    .btn-confirmar {
        background: rgba(14,165,233,.10);
        color: #0284c7;
    }

        .btn-confirmar:hover {
            background: rgba(14,165,233,.18);
        }

    /* Cancelar */

    .btn-cancelar {
        background: rgba(148,163,184,.15);
        color: #64748b;
    }

        .btn-cancelar:hover {
            background: rgba(148,163,184,.25);
        }

    /* Excluir */

    .btn-excluir {
        background: rgba(239,68,68,.08);
        color: #dc2626;
    }

        .btn-excluir:hover {
            background: rgba(239,68,68,.15);
        }

</style>