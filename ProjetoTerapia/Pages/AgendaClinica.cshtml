@page
@model ProjetoTerapia.Pages.AgendaClinicaModel

<div class="agenda-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <img src="/imagem/logo.png" class="logo-sidebar" />

        <div class="menu-sidebar">

            <a href="/PainelClinica" class="menu-item">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>

            <a href="/AgendaClinica" class="menu-item ativo">
                <i class="fa-regular fa-calendar"></i>
                Agenda
            </a>

            <a href="#" class="menu-item">
                <i class="fa-solid fa-user-group"></i>
                Pacientes
            </a>

            <a href="/CadastroClinica" class="menu-item">
                <i class="fa-regular fa-id-card"></i>
                Perfil
            </a>

        </div>

    </aside>

    <!-- CONTEÚDO -->
    <main class="agenda-content">

        <!-- HEADER -->
        <div class="topo-agenda">

            <div>

                <span class="mini-badge">
                    Painel de Agenda
                </span>

                <h1>
                    Agenda Clínica
                </h1>

                <p>
                    Controle seus atendimentos e horários.
                </p>

            </div>

            <button class="btn-consulta">
                Nova Consulta
            </button>

        </div>

        <!-- RESUMO -->
        <div class="grid-resumo">

            <div class="card-resumo">
                <span>Consultas Hoje</span>
                <h2>12</h2>
            </div>

            <div class="card-resumo">
                <span>Confirmadas</span>
                <h2>8</h2>
            </div>

            <div class="card-resumo">
                <span>Pendentes</span>
                <h2>3</h2>
            </div>

            <div class="card-resumo">
                <span>Canceladas</span>
                <h2>1</h2>
            </div>

        </div>

        <!-- CONSULTAS -->
        <div class="consultas-box">

            <div class="titulo-box">

                <div>
                    <h3>Próximos Atendimentos</h3>
                    <p>Consultas agendadas para hoje</p>
                </div>

            </div>

            <div class="consulta-card">

                <div class="usuario">

                    <div class="avatar">
                        M
                    </div>

                    <div>

                        <h4>Maria Oliveira</h4>

                        <span>
                            Atendimento Online
                        </span>

                    </div>

                </div>

                <div class="consulta-hora">
                    14:00
                </div>

                <div class="status confirmado">
                    Confirmado
                </div>

            </div>

            <div class="consulta-card">

                <div class="usuario">

                    <div class="avatar">
                        J
                    </div>

                    <div>

                        <h4>João Henrique</h4>

                        <span>
                            Atendimento Presencial
                        </span>

                    </div>

                </div>

                <div class="consulta-hora">
                    16:30
                </div>

                <div class="status pendente">
                    Pendente
                </div>

            </div>

        </div>

    </main>

</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>

    body {
        margin: 0;
        background: #f1f5f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .agenda-layout {
        display: flex;
        min-height: 100vh;
    }

    /* SIDEBAR */

    .sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #e2e8f0;
        padding: 30px;
    }

    .logo-sidebar {
        width: 180px;
        margin-bottom: 50px;
    }

    .menu-sidebar {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        color: #475569;
        padding: 16px 18px;
        border-radius: 16px;
        transition: .2s;
        font-weight: 600;
    }

        .menu-item:hover {
            background: #f8fafc;
        }

        .menu-item.ativo {
            background: linear-gradient(135deg,#2563eb,#0ea5e9);
            color: white;
        }

    /* CONTENT */

    .agenda-content {
        flex: 1;
        padding: 45px;
    }

    .topo-agenda {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 35px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .mini-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(37,99,235,.08);
        color: #2563eb;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .topo-agenda h1 {
        margin: 0 0 10px;
        font-size: 34px;
        color: #0f172a;
    }

    .topo-agenda p {
        margin: 0;
        color: #64748b;
    }

    .btn-consulta {
        border: none;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        padding: 16px 22px;
        border-radius: 16px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,.18);
    }

    /* CARDS */

    .grid-resumo {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-bottom: 35px;
    }

    .card-resumo {
        background: white;
        padding: 26px;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
    }

        .card-resumo span {
            color: #64748b;
            font-size: 14px;
        }

        .card-resumo h2 {
            margin: 14px 0 0;
            font-size: 34px;
            color: #0f172a;
        }

    /* CONSULTAS */

    .consultas-box {
        background: white;
        border-radius: 28px;
        padding: 30px;
        border: 1px solid #e2e8f0;
    }

    .titulo-box {
        margin-bottom: 25px;
    }

        .titulo-box h3 {
            margin: 0 0 8px;
            font-size: 24px;
            color: #0f172a;
        }

        .titulo-box p {
            margin: 0;
            color: #64748b;
        }

    .consulta-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 22px;
        border-radius: 22px;
        background: #f8fafc;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .usuario {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg,#2563eb,#0ea5e9);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .usuario h4 {
        margin: 0 0 6px;
        color: #0f172a;
        font-size: 17px;
    }

    .usuario span {
        color: #64748b;
        font-size: 14px;
    }

    .consulta-hora {
        font-weight: 700;
        color: #0f172a;
        font-size: 16px;
    }

    .status {
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .confirmado {
        background: #dcfce7;
        color: #166534;
    }

    .pendente {
        background: #fef3c7;
        color: #92400e;
    }

    @@media(max-width:900px) {

        .agenda-layout {
            flex-direction: column;
        }

        .sidebar {
            width: auto;
            border-right: none;
            border-bottom: 1px solid #e2e8f0;
        }

        .agenda-content {
            padding: 25px;
        }
    }

</style>