@page
@model ProjetoTerapia.Pages.Paciente.CadastroPacienteModel

<div class="container-auth">

    <div class="auth-wrapper">

        <div class="side-info">

            <div class="content-side">

                <span class="badge-side">
                    Plataforma para cuidado emocional
                </span>

                <h1>
                    Comece sua jornada de cuidado com a sua mente.
                </h1>

                <p>
                    Encontre profissionais, acompanhe seus sentimentos
                    e registre sua evolução em um espaço seguro e acolhedor.
                </p>

                <div class="cards-preview">

                    <div class="preview-card">
                        <div class="icon-card">01</div>
                        <div>
                            <strong>Profissionais qualificados</strong>
                            <span>Encontre especialistas alinhados ao que você precisa.</span>
                        </div>
                    </div>

                    <div class="preview-card">
                        <div class="icon-card">02</div>
                        <div>
                            <strong>Acompanhamento emocional</strong>
                            <span>Registre seus dias, sentimentos e evolução pessoal.</span>
                        </div>
                    </div>

                    <div class="preview-card">
                        <div class="icon-card">03</div>
                        <div>
                            <strong>Ambiente seguro</strong>
                            <span>Suas informações ficam protegidas dentro da plataforma.</span>
                        </div>
                    </div>

                </div>

            </div>

        </div>

        <div class="card-auth">

            <img src="/imagem/logo.png"
                 class="logo-auth"
                 alt="Logo AlinhaMente" />

            <h2>Cadastro do Paciente</h2>

            <p class="sub">
                Crie sua conta para acessar sua área pessoal
                e acompanhar sua jornada emocional.
            </p>

            <a asp-page="/Paciente/CadastroPaciente"
               asp-page-handler="LoginGoogle"
               class="btn-google">

                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                     class="google-icon" />

                <span>Continuar com Google</span>

            </a>

            <div class="divider">
                <span>ou</span>
            </div>

            <form method="post">

                <input asp-for="Nome"
                       placeholder="Nome completo"
                       required />

                <input asp-for="Email"
                       type="email"
                       placeholder="Email"
                       required />

                <input asp-for="Senha"
                       type="password"
                       placeholder="Senha"
                       required />

                <input asp-for="ConfirmarSenha"
                       type="password"
                       placeholder="Confirmar senha"
                       required />

                <button type="submit" class="btn-primary">
                    Criar conta
                </button>

            </form>

            @if (!string.IsNullOrEmpty(Model.Mensagem))
            {
                <div class="validation-box">
                    @Model.Mensagem
                </div>
            }

            <p class="link-login">
                Já tem conta?
                <a href="/Paciente/LoginPaciente">Entrar</a>
            </p>

        </div>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    body {
        overflow-x: hidden;
        background: linear-gradient(135deg,#ecfeff,#f8fafc,#eef2ff);
    }

    .container-auth {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .auth-wrapper {
        width: 100%;
        max-width: 1450px;
        min-height: 760px;
        display: flex;
        overflow: hidden;
        border-radius: 35px;
        background: rgba(255,255,255,0.04);
        backdrop-filter: blur(10px);
        box-shadow: 0 30px 80px rgba(0,0,0,0.35);
    }

    .side-info {
        width: 55%;
        position: relative;
        display: flex;
        align-items: center;
        background: linear-gradient(135deg,#0f766e,#0ea5e9);
    }

        .side-info::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top left, rgba(14,165,233,.18), transparent 35%);
        }

    .content-side {
        position: relative;
        z-index: 2;
        padding: 70px;
        color: white;
    }

    .badge-side {
        display: inline-block;
        padding: 9px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.2);
        font-size: 13px;
        margin-bottom: 28px;
    }

    .content-side h1 {
        font-size: 58px;
        line-height: 1.1;
        margin-bottom: 28px;
        color: white;
        letter-spacing: -1px;
    }

    .content-side p {
        font-size: 18px;
        line-height: 1.8;
        color: rgba(255,255,255,.85);
        margin-bottom: 42px;
        max-width: 720px;
    }

    .cards-preview {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .preview-card {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 20px;
        border-radius: 18px;
        background: rgba(255,255,255,.08);
        backdrop-filter: blur(10px);
    }

        .preview-card strong {
            display: block;
            color: white;
            margin-bottom: 5px;
        }

        .preview-card span {
            color: rgba(255,255,255,.75);
            font-size: 14px;
        }

    .icon-card {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: rgba(255,255,255,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        flex-shrink: 0;
    }

    .card-auth {
        background: rgba(255,255,255,0.97);
        padding: 38px;
        width: 45%;
        max-width: 560px;
        margin: auto;
        border-radius: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        text-align: center;
    }

    .logo-auth {
        width: 250px;
        max-width: 100%;
        margin-bottom: 12px;
    }

    .card-auth h2 {
        font-size: 28px;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .sub {
        color: #64748b;
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    form {
        margin-top: 10px;
    }

    input {
        width: 100%;
        padding: 16px;
        margin-bottom: 14px;
        border-radius: 14px;
        border: 1px solid #dbeafe;
        background: #f8fafc;
        font-size: 15px;
        outline: none;
    }

        input:focus {
            border-color: #7c3aed;
            background: white;
            box-shadow: 0 0 0 4px rgba(124,58,237,0.10);
        }

    .btn-primary {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #14b8a6, #0ea5e9);
        color: white;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.25s;
        margin-top: 5px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(124,58,237,0.25);
        }

    .link-login {
        margin-top: 22px;
        color: #64748b;
        font-size: 15px;
    }

        .link-login a {
            color: #7c3aed;
            text-decoration: none;
            font-weight: 700;
        }

    .validation-box {
        margin-top: 18px;
        background: #eff6ff;
        color: #1e40af;
        padding: 14px;
        border-radius: 12px;
        font-size: 14px;
    }

    @@media(max-width: 900px) {

        .container-auth {
            padding: 12px;
            align-items: flex-start;
        }

        .auth-wrapper {
            display: block;
            min-height: auto;
            border-radius: 24px;
        }

        .side-info {
            display: none;
        }

        .card-auth {
            width: 100%;
            max-width: 100%;
            margin: 0;
            border-radius: 24px;
            padding: 28px 22px;
        }

        .logo-auth {
            width: 210px;
        }

        .card-auth h2 {
            font-size: 24px;
        }
    }

    .btn-google {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 14px;
        border-radius: 14px;
        border: 1px solid #dbeafe;
        background: white;
        text-decoration: none;
        color: #334155;
        font-weight: 600;
        transition: .25s;
        margin-bottom: 22px;
    }

        .btn-google:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(15,23,42,.08);
        }

    .google-icon {
        width: 22px;
        margin-right: 10px;
    }

    .divider {
        position: relative;
        margin: 24px 0;
        text-align: center;
    }

        .divider::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 1px;
            background: #dbeafe;
            left: 0;
            top: 50%;
        }

        .divider span {
            position: relative;
            background: white;
            padding: 0 14px;
            color: #94a3b8;
            font-size: 14px;
        }

</style>