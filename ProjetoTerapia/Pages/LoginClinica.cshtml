@page
@model ProjetoTerapia.Pages.LoginClinicaModel

<div class="container">

    <div class="card">

        <img src="/imagem/logo.png" class="logo-login" />

        <p>
            Conectando pessoas a profissionais
            da saúde emocional de forma simples,
            segura e acolhedora.
        </p>

        <p>Entre na sua conta para acessar seu painel</p>

        <form method="post">

            <input type="email" asp-for="Email" placeholder="Email" required />

            <input type="password" asp-for="Senha" placeholder="Senha" required />

            <button type="submit">Entrar</button>

        </form>

        @if (Model.Erro != null)
        {
            <p class="erro">@Model.Erro</p>
        }

        <div class="divider">ou</div>

        <a href="/CadastroConta" class="btn-secundario">
            Criar conta
        </a>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

    * {
        font-family: 'Poppins', sans-serif;
    }

    .card h1 {
        font-size: 52px;
        font-weight: 700;
        margin-bottom: 10px;
        background: linear-gradient(90deg,#7c3aed,#9333ea,#06b6d4);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -2px;
    }

    .container {
        overflow: hidden;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: linear-gradient(135deg,#00c6ff,#009ee3);
    }

    .card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        width: 350px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    input {
        width: 100%;
        padding: 12px;
        margin: 10px 0;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #009ee3;
        color: white;
        font-weight: bold;
        cursor: pointer;
    }

        button:hover {
            transform: scale(1.02);
        }

    .divider {
        margin: 20px 0;
        color: #888;
    }

    .btn-secundario {
        display: block;
        padding: 10px;
        border: 1px solid #009ee3;
        border-radius: 10px;
        text-decoration: none;
        color: #009ee3;
    }

    .erro {
        color: red;
        margin-top: 10px;
    }

    .logo-login {
    width: 120px;
    margin-bottom: 5px;
    filter: drop-shadow(0 10px 25px rgba(168,85,247,0.25));
}

    .container::before {
        content: '';
        position: absolute;
        width: 500px;
        height: 500px;
        background: rgba(168,85,247,0.15);
        border-radius: 50%;
        top: -150px;
        right: -150px;
        filter: blur(80px);
    }

    .container::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        background: rgba(34,211,238,0.12);
        border-radius: 50%;
        bottom: -150px;
        left: -150px;
        filter: blur(80px);
    }
</style>