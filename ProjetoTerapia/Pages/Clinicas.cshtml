@page
@model ProjetoTerapia.Pages.ClinicasModel

<form method="get" class="busca-clinica">

    <input type="text"
           name="busca"
           value="@Model.Busca"
           placeholder="Buscar profissional, especialidade ou região..." />

    <button type="submit">
        Buscar
    </button>

</form>

<div class="topo-clinicas">

    <h1>Profissionais Recomendados</h1>

    <p>
        Encontre profissionais e clínicas preparados para cuidar da sua saúde emocional
    </p>

</div>

<div class="container-clinicas">

    @if (!Model.Clinicas.Any())
    {
        <div class="alerta-vazio">
            Nenhum profissional cadastrado no momento.
        </div>
    }

    @foreach (var clinica in Model.Clinicas)
    {
        <div class="card-clinica">

            <div class="topo-card">
                <div>
                    <h3>@clinica.Nome</h3>
                    @if (clinica.Pago)
                    {
                        <span class="selo-aprovado">✔ Verificado</span>
                    }
                    else
                    {
                        <span style="color:gray;">⏳ Em análise</span>
                    }
                </div>

                <div class="valor">
                    R$ @clinica.Valor
                </div>
            </div>

            <p class="descricao">
                @clinica.Descricao
            </p>

            @if (!string.IsNullOrEmpty(clinica.Especialidades))
            {
                var lista = clinica.Especialidades.Split(',');

                <div class="lista-especialidades">
                    @foreach (var esp in lista)
                    {
                        <span class="tag-especialidade">@esp</span>
                    }
                </div>
            }

            <div class="infos">
                <p><strong>📍 Endereço:</strong> @clinica.Endereco</p>
            </div>

            @if (!string.IsNullOrEmpty(clinica.Telefone))
            {
                <p><strong>📞 Contato:</strong> @clinica.Telefone</p>

                <a href="https://wa.me/@(clinica.Telefone)"
                   target="_blank"
                   class="btn-whatsapp">
                    Falar no WhatsApp
                </a>
            }
            else
            {
                <p style="color:gray;">Contato não informado</p>
            }

            <div class="redes-sociais">

                @if (!string.IsNullOrEmpty(clinica.Instagram))
                {
                    <a href="@clinica.Instagram" target="_blank" class="icon insta">
                        📸
                    </a>
                }

                @if (!string.IsNullOrEmpty(clinica.Site))
                {
                    <a href="@clinica.Site" target="_blank" class="icon site">
                        🌐
                    </a>
                }

            </div>

        </div>
 }

    <div class="area-profissional">
        <h3>É profissional ou possui clínica?</h3>
        <p>Cadastre-se e receba pacientes qualificados</p>

        <a href="/CadastroConta" class="btn-cadastro">
            Quero cadastrar minha clínica
        </a>
    </div>

</div>

<style>

    body {
        background: #f8fafc;
    }

    .topo-clinicas {
        text-align: center;
        padding: 60px 20px 30px;
    }

    .topo-clinicas h1 {
        font-size: 38px;
        font-weight: bold;
        color: #0f172a;
        margin-bottom: 15px;
    }

    .topo-clinicas p {
        font-size: 18px;
        color: #64748b;
        max-width: 700px;
        margin: auto;
    }

    .container-clinicas {
        max-width: 900px;
        margin: auto;
        padding: 20px;
    }

    .card-clinica {
        background: white;
        border-radius: 18px;
        padding: 28px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .topo-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .topo-card h3 {
        margin: 0;
        font-size: 24px;
        color: #111827;
    }

    .selo-aprovado {
        display: inline-block;
        margin-top: 8px;
        background: #dcfce7;
        color: #166534;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: bold;
    }

    .valor {
        font-size: 22px;
        font-weight: bold;
        color: #009ee3;
    }

    .descricao {
        color: #475569;
        font-size: 16px;
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .infos p {
        margin-bottom: 10px;
        color: #334155;
    }

    .btn-whatsapp {
        display: inline-block;
        margin-top: 20px;
        background: #25D366;
        color: white;
        padding: 14px 22px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
    }

    .btn-whatsapp:hover {
        transform: scale(1.02);
    }

    .area-profissional {
        margin-top: 50px;
        background: white;
        padding: 35px;
        border-radius: 18px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .btn-cadastro {
        display: inline-block;
        margin-top: 20px;
        background: #009ee3;
        color: white;
        padding: 14px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: bold;
    }

    .alerta-vazio {
        background: white;
        padding: 25px;
        border-radius: 14px;
        text-align: center;
        margin-bottom: 30px;
    }

    .busca-clinica {
        max-width: 900px;
        margin: 30px auto 10px;
        display: flex;
        gap: 15px;
        align-items: center;
        background: white;
        padding: 18px;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

        .busca-clinica input {
            flex: 1;
            border: 1px solid #dbeafe;
            border-radius: 14px;
            padding: 16px 18px;
            font-size: 16px;
            outline: none;
            transition: 0.2s;
        }

            .busca-clinica input:focus {
                border-color: #009ee3;
                box-shadow: 0 0 0 4px rgba(0, 158, 227, 0.08);
            }

        .busca-clinica button {
            padding: 16px 28px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #00c6ff, #009ee3);
            color: white;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

            .busca-clinica button:hover {
                transform: scale(1.03);
            }

    @@media (max-width: 768px) {
        .busca-clinica {
            flex-direction: column;
        }

            .busca-clinica button {
                width: 100%;
            }
    }

    .lista-especialidades {
        margin-top: 10px;
    }

    .tag-especialidade {
        display: inline-block;
        background: #e0f2fe;
        color: #0369a1;
        padding: 6px 10px;
        border-radius: 999px;
        margin-right: 6px;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
    }

    .redes-sociais {
    margin-top: 15px;
    display: flex;
    gap: 12px;
}

.icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    font-size: 20px;
    text-decoration: none;
    transition: 0.2s;
}

.icon.insta {
    background: #fdf2f8;
}

.icon.site {
    background: #eff6ff;
}

.icon:hover {
    transform: scale(1.1);
}

    .btn-instagram {
        display: inline-block;
        margin-top: 10px;
        background: #E1306C;
        color: white;
        padding: 10px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: bold;
    }

</style>