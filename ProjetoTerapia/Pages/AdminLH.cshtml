@page
@model ProjetoTerapia.Pages.AdminLHModel

<div class="admin-page">

    <aside class="sidebar-admin">

        <div class="logo-admin">
            <img src="/imagem/logo.png" alt="AlinhaMente" />
        </div>

        <nav class="menu-admin">

            <a href="javascript:void(0)" onclick="mostrarAba('dashboard', this)">
                Dashboard
            </a>

            <a href="javascript:void(0)" onclick="mostrarAba('clinicas', this)">
                Clínicas
            </a>

            <a href="javascript:void(0)" onclick="mostrarAba('alteracoes', this)">
                Alterações
            </a>

            <a href="javascript:void(0)" onclick="mostrarAba('pagamentos', this)">
                Pagamentos
            </a>

            <a href="javascript:void(0)" onclick="mostrarAba('divulgacao', this)">
                Clube de Descontos
            </a>

        </nav>

        <form method="post" asp-page-handler="Logout" class="form-logout">
            <button class="btn-logout">
                Sair
            </button>
        </form>

    </aside>

    <main class="conteudo-admin">

        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alerta-sucesso">
                @TempData["MensagemSucesso"]
            </div>
        }

        @if (TempData["MensagemErro"] != null)
        {
            <div class="alerta-erro">
                @TempData["MensagemErro"]
            </div>
        }

        <section id="dashboard" class="aba">

            <div class="topo-conteudo">

                <div>
                    <span class="badge-admin">
                        Administração
                    </span>

                    <h1>
                        Painel Administrativo
                    </h1>

                    <p>
                        Acompanhe cadastros, pagamentos, visualizações e solicitações da plataforma.
                    </p>
                </div>

                <a href="/Teste" class="btn-site">
                    Ver site
                </a>

            </div>

            <div class="cards-dashboard">

                <div class="card-info">
                    <span>Total de profissionais</span>
                    <strong>@Model.TotalClinicas</strong>
                    <p>Cadastros realizados</p>
                </div>

                <div class="card-info pendente">
                    <span>Pendentes</span>
                    <strong>@Model.Pendentes</strong>
                    <p>Aguardando aprovação</p>
                </div>

                <div class="card-info ativo">
                    <span>Ativos</span>
                    <strong>@Model.Ativas</strong>
                    <p>Pagamentos confirmados</p>
                </div>

                <div class="card-info alerta">
                    <span>Alterações pendentes</span>
                    <strong>@Model.AlteracoesPendentes</strong>
                    <p>Perfis aguardando revisão</p>
                </div>

                <div class="card-info destaque">
                    <span>Receita prevista</span>
                    <strong>@Model.ReceitaPrevistaFormatada</strong>
                    <p>Planos ativos no sistema</p>
                </div>

                <div class="card-info">
                    <span>Visualizações</span>
                    <strong>@Model.TotalVisualizacoes</strong>
                    <p>Total de acessos aos perfis</p>
                </div>

                <div class="card-info">
                    <span>Cliques WhatsApp</span>
                    <strong>@Model.TotalCliquesWhatsapp</strong>
                    <p>Contatos iniciados</p>
                </div>

                <div class="card-info conversao">
                    <span>Conversão</span>
                    <strong>@Model.TaxaConversao%</strong>
                    <p>Aprovadas que viraram pagas</p>
                </div>

            </div>

        </section>

        <section id="clinicas" class="aba" style="display:none">

            <div class="topo-secao">

                <div>
                    <h2>
                        Gerenciar profissionais
                    </h2>

                    <p>
                        Aprove cadastros, confirme pagamentos e revise perfis cadastrados.
                    </p>
                </div>

            </div>

            <form method="get" class="filtros-admin">

                <input type="hidden" name="aba" value="clinicas" />

                <input type="text"
                       name="Busca"
                       value="@Model.Busca"
                       placeholder="Buscar por nome, email ou cidade..." />

                <select name="FiltroStatus">
                    <option value="">Todos os status</option>
                    <option value="pendente">Pendentes</option>
                    <option value="aprovado">Aprovadas sem pagamento</option>
                    <option value="ativo">Ativas</option>
                    <option value="alteracao">Alterações pendentes</option>
                </select>

                <button type="submit" class="btn-filtrar">
                    Filtrar
                </button>

            </form>

            <div class="lista-clinicas">

                @foreach (var clinica in Model.Clinicas)
                {
                    <article class="card-clinica">

                        <div class="card-topo">

                            <div>
                                <h3>
                                    @clinica.Nome
                                </h3>

                                <p>
                                    @clinica.Email
                                </p>
                            </div>

                            <div class="status-tags">

                                @if (!clinica.Aprovado)
                                {
                                    <span class="tag pendente">
                                        Pendente
                                    </span>
                                }
                                else
                                {
                                    <span class="tag aprovado">
                                        Aprovado
                                    </span>
                                }

                                @if (clinica.Pago)
                                {
                                    <span class="tag pago">
                                        Pago
                                    </span>
                                }
                                else
                                {
                                    <span class="tag nao-pago">
                                        Não pago
                                    </span>
                                }

                                @if (clinica.ClinicaAlteracaoPendente)
                                {
                                    <span class="tag alteracao">
                                        Alteração pendente
                                    </span>
                                }

                        </div>

                    </div>

                    <div class="info-grid">

                        <div>
                            <span>Cidade</span>
                            <strong>@(string.IsNullOrWhiteSpace(clinica.Cidade) ? "Não informada" : clinica.Cidade)</strong>
                        </div>

                        <div>
                            <span>Telefone</span>
                            <strong>@(string.IsNullOrWhiteSpace(clinica.Telefone) ? "Não informado" : clinica.Telefone)</strong>
                        </div>

                        <div>
                            <span>Valor consulta</span>
                            <strong>R$ @clinica.Valor</strong>
                        </div>

                        <div>
                            <span>Visualizações</span>
                            <strong>@clinica.Visualizacoes</strong>
                        </div>

                        <div>
                            <span>Cliques WhatsApp</span>
                            <strong>@clinica.CliquesWhatsapp</strong>
                        </div>

                        <div>
                            <span>Vencimento</span>
                            <strong>
                                @(clinica.DataVencimento.HasValue
                                                                ? clinica.DataVencimento.Value.ToString("dd/MM/yyyy")
                                                                : "Sem vencimento")
                                                                               </strong>
                                                                           </div>

                    </div>

                    <p class="descricao-card">
                        @(string.IsNullOrWhiteSpace(clinica.Descricao)
                                                ? "Sem descrição cadastrada."
                                                : clinica.Descricao)
                    </p>

                        <div class="acoes-card-admin">

                            <form method="post">

                                <input type="hidden" name="id" value="@clinica.Id" />

                            @if (!clinica.Aprovado)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="aprovar"
                                            class="btn-acao aprovar"
                                            onclick='return confirmarAcao(this, "aprovar este profissional?")'>
                                        Aprovar cadastro
                                    </button>
                                }

                                @if (clinica.ClinicaAlteracaoPendente)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="aprovarAlteracao"
                                            class="btn-acao aprovar"
                                            onclick='return confirmarAcao(this, "aprovar as alterações deste perfil?")'>
                                        Aprovar alterações
                                    </button>
                                }

                                @if (clinica.Aprovado && !clinica.Pago)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="pagar"
                                            class="btn-acao pagar"
                                            onclick='return confirmarAcao(this, "confirmar o pagamento deste profissional?")'>
                                        Confirmar pagamento
                                    </button>
                                }

                                @if (clinica.Pago)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="suspender"
                                            class="btn-acao suspender"
                                            onclick='return confirmarAcao(this, "suspender o plano deste profissional?")'>
                                        Suspender plano
                                    </button>
                                }

                                <button type="submit"
                                        name="acao"
                                        value="excluir"
                                        class="btn-acao excluir"
                                        onclick='return confirmarAcao(this, "excluir permanentemente este profissional?")'>
                                    Excluir
                                </button>

                            </form>

                            <a href="/PerfilClinica?id=@clinica.Id"
                               target="_blank"
                               class="btn-ver-perfil">
                                Ver perfil público
                            </a>

                        </div>

                    </article>
                }

                @if (!Model.Clinicas.Any())
                {
                    <div class="vazio-card">
                        Nenhum profissional encontrado com os filtros selecionados.
                    </div>
                }

            </div>

        </section>

        <section id="alteracoes" class="aba" style="display:none">

            <div class="topo-secao">

                <div>
                    <h2>
                        Alterações pendentes
                    </h2>

                    <p>
                        Revise profissionais que editaram o perfil após aprovação.
                    </p>
                </div>

            </div>

            <div class="lista-clinicas">

                @foreach (var clinica in Model.ClinicasComAlteracao)
                {
                    <article class="card-clinica">

                        <div class="card-topo">

                            <div>
                                <h3>@clinica.Nome</h3>
                                <p>@clinica.Email</p>
                            </div>

                            <span class="tag alteracao">
                                Aguardando revisão
                            </span>

                        </div>

                        <div class="info-grid">

                            <div>
                                <span>Cidade</span>
                                <strong>@(string.IsNullOrWhiteSpace(clinica.Cidade) ? "Não informada" : clinica.Cidade)</strong>
                            </div>

                            <div>
                                <span>Telefone</span>
                                <strong>@(string.IsNullOrWhiteSpace(clinica.Telefone) ? "Não informado" : clinica.Telefone)</strong>
                            </div>

                            <div>
                                <span>Valor consulta</span>
                                <strong>R$ @clinica.Valor</strong>
                            </div>

                        </div>

                        <p class="descricao-card">
                            @(string.IsNullOrWhiteSpace(clinica.Descricao)
                                                    ? "Sem descrição cadastrada."
                                                    : clinica.Descricao)
                    </p>

                        <div class="acoes-card-admin">

                            <form method="post">

                                <input type="hidden" name="id" value="@clinica.Id" />

                                <button type="submit"
                                        name="acao"
                                        value="aprovarAlteracao"
                                        class="btn-acao aprovar"
                                        onclick='return confirmarAcao(this, "aprovar as alterações deste perfil?")'>
                                    Aprovar alterações
                                </button>

                            </form>

                            <a href="/PerfilClinica?id=@clinica.Id"
                               target="_blank"
                               class="btn-ver-perfil">
                                Ver perfil público
                            </a>

                        </div>

                    </article>
                                }

                @if (!Model.ClinicasComAlteracao.Any())
                {
                    <div class="vazio-card">
                        Nenhuma alteração pendente no momento.
                    </div>
                }

            </div>

        </section>

        <section id="pagamentos" class="aba" style="display:none">

            <div class="topo-secao">

                <div>
                    <h2>
                        Pagamentos
                    </h2>

                    <p>
                        Confirme manualmente pagamentos realizados pelo link do Mercado Pago.
                    </p>
                </div>

            </div>

            <div class="lista-clinicas">

                @foreach (var clinica in Model.Clinicas.Where(c => c.Aprovado && !c.Pago))
                {
                    <article class="card-clinica">

                        <div class="card-topo">

                            <div>
                                <h3>@clinica.Nome</h3>
                                <p>@clinica.Email</p>
                            </div>

                            <span class="tag nao-pago">
                                Pagamento pendente
                            </span>

                        </div>

                        <div class="pagamento-box">

                            <div>
                                <span>Plano</span>
                                <strong>Plano Profissional Anual</strong>
                            </div>

                            <div>
                                <span>Valor</span>
                                <strong>R$ 360,00 / ano</strong>
                            </div>

                            <div>
                                <span>Forma atual</span>
                                <strong>Link Mercado Pago</strong>
                            </div>

                        </div>

                        <div class="acoes-card-admin">

                            <a href="https://mpago.la/33FgjZL"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="btn-ver-perfil">
                                Abrir link de pagamento
                            </a>

                            <form method="post">

                                <input type="hidden" name="id" value="@clinica.Id" />

                                <button type="submit"
                                        name="acao"
                                        value="pagar"
                                        class="btn-acao pagar"
                                        onclick='return confirmarAcao(this, "confirmar o pagamento deste profissional?")'>
                                    Confirmar pagamento
                                </button>

                            </form>

                        </div>

                    </article>
                }

                @if (!Model.Clinicas.Any(c => c.Aprovado && !c.Pago))
                {
                    <div class="vazio-card">
                        Nenhum pagamento pendente no momento.
                    </div>
                }

            </div>

        </section>

        <section id="divulgacao" class="aba" style="display:none">

            <div class="topo-secao">

                <div>
                    <h2>
                        Clube de Descontos
                    </h2>

                    <p>
                        Gerencie solicitações de divulgação regional e cidades extras dos profissionais.
                    </p>
                </div>

            </div>

            <div class="clube-grid">

                <div class="clube-card">
                    <span>Divulgação regional</span>
                    <h3>+5 cidades</h3>
                    <strong>R$ 30,00</strong>
                    <p>Exibição em até 5 cidades adicionais.</p>
                </div>

                <div class="clube-card">
                    <span>Divulgação regional</span>
                    <h3>+10 cidades</h3>
                    <strong>R$ 35,00</strong>
                    <p>Exibição em até 10 cidades adicionais.</p>
                </div>

                <div class="clube-card">
                    <span>Divulgação regional</span>
                    <h3>+15 cidades</h3>
                    <strong>R$ 45,00</strong>
                    <p>Maior alcance para atendimentos online.</p>
                </div>

                <div class="clube-card">
                    <span>Divulgação regional</span>
                    <h3>+20 cidades</h3>
                    <strong>R$ 50,00</strong>
                    <p>Presença ampliada em regiões estratégicas.</p>
                </div>

                <div class="clube-card">
                    <span>Divulgação regional</span>
                    <h3>+25 cidades</h3>
                    <strong>R$ 55,00</strong>
                    <p>Plano com maior alcance regional.</p>
                </div>

            </div>

            <div class="lista-clinicas">

                @foreach (var item in Model.DivulgacoesRegionais)
                {
                    <article class="card-clinica">

                        <div class="card-topo">

                            <div>
                                <h3>
                                    @(item.Clinica?.Nome ?? "Profissional não encontrado")
                                </h3>

                                <p>
                                    @(item.Clinica?.Email ?? "")
                                </p>
                            </div>

                            <div class="status-tags">

                                @if (item.Ativo)
                                {
                                    <span class="tag pago">
                                        Ativo
                                    </span>
                                }
                                else if (item.Pago)
                                {
                                    <span class="tag aprovado">
                                        Pago
                                    </span>
                                }
                                else
                                {
                                    <span class="tag nao-pago">
                                        Aguardando pagamento
                                    </span>
                                }

                        </div>

                    </div>

                    <div class="info-grid">

                        <div>
                            <span>Plano</span>
                            <strong>@item.NomePlano</strong>
                        </div>

                        <div>
                            <span>Valor</span>
                            <strong>R$ @item.Valor</strong>
                        </div>

                        <div>
                            <span>Status</span>
                            <strong>@item.Status</strong>
                        </div>

                        <div>
                            <span>Cidades</span>
                            <strong>@item.CidadesSelecionadas</strong>
                        </div>

                        <div>
                            <span>Solicitado em</span>
                            <strong>@item.DataSolicitacao.ToString("dd/MM/yyyy HH:mm")</strong>
                        </div>

                        <div>
                            <span>Fim</span>
                            <strong>
                                @(item.DataFim.HasValue
                                                                ? item.DataFim.Value.ToString("dd/MM/yyyy")
                                                                : "Não iniciado")
                            </strong>
                        </div>

                        </div>

                        <div class="acoes-card-admin">

                            <form method="post">

                                <input type="hidden" name="id" value="@item.Id" />

                            @if (!item.Pago)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="confirmarPagamentoDivulgacao"
                                            class="btn-acao pagar"
                                            onclick='return confirmarAcao(this, "confirmar o pagamento desta divulgação?")'>
                                        Confirmar pagamento
                                    </button>
                                }

                                @if (item.Pago && !item.Aprovado)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="aprovarDivulgacao"
                                            class="btn-acao aprovar"
                                            onclick='return confirmarAcao(this, "aprovar e ativar esta divulgação?")'>
                                        Aprovar divulgação
                                    </button>
                                }

                                @if (item.Ativo)
                                {
                                    <button type="submit"
                                            name="acao"
                                            value="cancelarDivulgacao"
                                            class="btn-acao suspender"
                                            onclick='return confirmarAcao(this, "cancelar esta divulgação?")'>
                                        Cancelar divulgação
                                    </button>
                                }

                            </form>

                            @if (item.Clinica != null)
                            {
                                <a href="/PerfilClinica?id=@item.Clinica.Id"
                                   target="_blank"
                                   class="btn-ver-perfil">
                                    Ver perfil
                                </a>
                            }

                        </div>

                    </article>
                }

                @if (!Model.DivulgacoesRegionais.Any())
                {
                    <div class="vazio-card">
                        Nenhuma solicitação de divulgação regional no momento.
                    </div>
                }

            </div>

        </section>

    </main>

</div>

<div id="modalConfirmacao" class="modal-confirmacao">

    <div class="modal-box">

        <h3>
            Confirmar ação
        </h3>

        <p id="textoModal">
            Deseja realmente continuar?
        </p>

        <div class="modal-botoes">

            <button type="button"
                    class="btn-cancelar"
                    onclick="fecharModal()">
                Cancelar
            </button>

            <button type="button"
                    class="btn-confirmar"
                    id="btnConfirmarFinal">
                Confirmar
            </button>

        </div>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

    * {
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    html,
    body {
        margin: 0;
        padding: 0;
        background: #eaf8ff;
        color: #0f172a;
    }

    .container,
    .container-fluid {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
        background: transparent !important;
    }

    .admin-page {
        min-height: 100vh;
        display: flex;
        background: radial-gradient(circle at top left, rgba(14,165,233,.18), transparent 32%), radial-gradient(circle at bottom right, rgba(124,58,237,.13), transparent 35%), linear-gradient(135deg,#e0f7ff 0%, #f8fcff 45%, #edf3ff 100%);
    }

    .sidebar-admin {
        width: 290px;
        min-height: 100vh;
        padding: 26px 22px;
        background: linear-gradient(180deg, rgba(255,255,255,.96), rgba(236,254,255,.94));
        border-right: 1px solid #dbeafe;
        color: #0f172a;
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 0;
        box-shadow: 12px 0 35px rgba(15,23,42,.05);
    }

    .logo-admin {
        display: flex;
        justify-content: center;
        margin-bottom: 34px;
    }

        .logo-admin img {
            width: 230px;
            max-width: 100%;
            height: auto;
            object-fit: contain;
        }

    .menu-admin {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .menu-admin a {
            color: #334155;
            text-decoration: none;
            padding: 15px 18px;
            border-radius: 16px;
            font-weight: 800;
            transition: .25s;
            background: rgba(255,255,255,.55);
            border: 1px solid transparent;
        }

            .menu-admin a:hover,
            .menu-admin a.ativo {
                background: linear-gradient(135deg,#14b8a6,#0ea5e9);
                color: white;
                box-shadow: 0 14px 28px rgba(14,165,233,.18);
            }

    .form-logout {
        margin-top: auto;
    }

    .btn-logout {
        width: 100%;
        border: none;
        border-radius: 16px;
        padding: 14px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 800;
        cursor: pointer;
        transition: .25s;
    }

        .btn-logout:hover {
            transform: translateY(-2px);
            background: #ef4444;
            color: white;
        }

    .conteudo-admin {
        flex: 1;
        padding: 42px 46px !important;
        min-width: 0;
    }

    .topo-conteudo,
    .topo-secao {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        margin-bottom: 28px;
    }

    .badge-admin {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(14,165,233,.13);
        color: #0369a1;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 14px;
    }

    .topo-conteudo h1,
    .topo-secao h2 {
        margin: 0 0 8px;
        font-size: 36px;
        letter-spacing: -1px;
        color: #0f172a;
    }

    .topo-conteudo p,
    .topo-secao p {
        margin: 0;
        color: #64748b;
        line-height: 1.6;
    }

    .btn-site {
        text-decoration: none;
        padding: 14px 20px;
        border-radius: 16px;
        color: white;
        background: linear-gradient(135deg,#14b8a6,#0ea5e9);
        font-weight: 800;
        box-shadow: 0 14px 30px rgba(14,165,233,.18);
        white-space: nowrap;
    }

    .cards-dashboard {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 18px;
    }

    .card-info,
    .card-clinica,
    .clube-card,
    .gestao-card,
    .vazio-card {
        background: rgba(255,255,255,.9);
        border: 1px solid rgba(226,232,240,.9);
        box-shadow: 0 20px 55px rgba(15,23,42,.07);
        backdrop-filter: blur(18px);
    }

    .card-info {
        padding: 26px;
        border-radius: 26px;
        transition: .25s;
    }

        .card-info:hover,
        .card-clinica:hover,
        .clube-card:hover {
            transform: translateY(-3px);
        }

        .card-info span {
            color: #64748b;
