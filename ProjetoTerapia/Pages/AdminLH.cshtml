@page
@model ProjetoTerapia.Pages.AdminLHModel

<div class="layout">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h3 class="logo">Ponto Saúde</h3>

        <a href="javascript:void(0)" onclick="mostrarAba('dashboard', this)">🏠 Dashboard</a>
        <a href="javascript:void(0)" onclick="mostrarAba('clinicas', this)">🏥 Clínicas</a>
        <a href="javascript:void(0)" onclick="mostrarAba('pagamentos', this)">💰 Pagamentos</a>

        <form method="post" asp-page-handler="Logout">
            <button class="btn-logout">Sair</button>
        </form>
    </div>

    <!-- CONTEÚDO -->
    <div class="conteudo">

       <div id="dashboard" class="aba">

    <h2>📊 Painel Administrativo</h2>

    <div class="cards">
        <div class="card-info">
            <h4>Pendentes</h4>
            <p>@Model.Clinicas.Count(c => !c.Aprovado)</p>
        </div>

        <div class="card-info">
            <h4>Aprovados</h4>
            <p>@Model.Clinicas.Count(c => c.Aprovado && !c.Pago)</p>
        </div>

        <div class="card-info">
            <h4>Ativos</h4>
            <p>@Model.Clinicas.Count(c => c.Pago)</p>
        </div>
    </div>

</div>

        <hr />

        <div id="clinicas" class="aba" style="display:none">

            <h3>Gerenciar Clínicas</h3>

            @foreach (var clinica in Model.Clinicas
                        .OrderBy(c => c.Aprovado)
                        .ThenBy(c => c.Pago))
            {
                <div class="card @(clinica.Pago ? "pago" : clinica.Aprovado ? "aprovado" : "pendente")">

                    <h5>@clinica.Nome</h5>
                    <p>@clinica.Descricao</p>
                    <p><strong>R$ @clinica.Valor</strong></p>
                    <p>@clinica.Endereco</p>

                    <p>
                        @(clinica.Aprovado ? "✅ Aprovado" : "⏳ Pendente")
                        |
                        @(clinica.Pago ? "💰 Pago" : "💸 Não pago")
                    </p>

                    <form method="post">
                        <input type="hidden" name="id" value="@clinica.Id" />

                        @if (!clinica.Aprovado)
                        {
                            <button name="acao" value="aprovar">Aprovar</button>
                        }

                        @if (clinica.Aprovado && !clinica.Pago)
                        {
                            <button name="acao" value="pagar">Confirmar pagamento</button>
                        }
                    </form>

                </div>
            }

        </div>

        <div id="pagamentos" class="aba" style="display:none">

            <h3>💰 Pagamentos</h3>

            @foreach (var clinica in Model.Clinicas.Where(c => c.Aprovado && !c.Pago))
            {
                <div class="card">

                    <h5>@clinica.Nome</h5>
                    <p><strong>Plano Ponto Saúde</strong></p>
                    <p>R$ 360 / ano (até 12x no cartão)</p>

                    <a href="https://mpago.la/33FgjZL" target="_blank" rel="noopener noreferrer" class="btn-pagar">
                        💳 Assinar plano anual
                    </a>

                    <p style="font-size:12px; color:gray;">
                        Pagamento 100% seguro via Mercado Pago
                    </p>

                    <p style="font-size:12px; color:#28a745;">
                        ✔ Após o pagamento, aguarde aprovação do sistema
                    </p>

                    <form method="post">
                        <input type="hidden" name="id" value="@clinica.Id" />
                        <button name="acao" value="pagar">Confirmar pagamento</button>
                    </form>

                </div>
            }

        </div>

    </div>

</div>

<style>

    body {
        margin: 0;
        background: #f5f7fa;
    }

    /* LAYOUT */
    .layout {
        display: flex;
    }

    /* SIDEBAR */
    .sidebar {
        width: 250px;
        min-height: 100vh;
        background: #0f172a;
        color: white;
        padding: 25px 20px;
        display: flex;
        flex-direction: column;
        box-shadow: 4px 0 10px rgba(0,0,0,0.05);
    }

    .logo {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 35px;
        color: white;
    }

    .sidebar a {
        display: block;
        padding: 12px 14px;
        margin-bottom: 10px;
        color: #cbd5e1;
        text-decoration: none;
        font-size: 15px;
        border-radius: 10px;
        transition: 0.2s;
    }

        .sidebar a:hover {
            background: #1e293b;
            color: white;
        }

        .sidebar a.ativo {
            background: #009ee3;
            color: white;
            font-weight: bold;
        }

   

    .btn-logout {
        margin-top: auto;
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #dc2626;
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-logout:hover {
            background: #b91c1c;
        }

    /* CONTEÚDO */
    .conteudo {
        flex: 1;
        padding: 30px;
    }

    /* CARDS INFO */
    .cards {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .card-info {
        background: white;
        padding: 20px;
        border-radius: 12px;
        flex: 1;
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

    /* LISTA */
    .card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 15px;
        box-shadow: 0 5px 10px rgba(0,0,0,0.08);
    }

        /* BOTÕES */
        .card button {
            margin-top: 10px;
            margin-right: 5px;
            padding: 6px 12px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

            .card button[value="aprovar"] {
                background: #28a745;
                color: white;
            }

            .card button[value="pagar"] {
                background: #ffc107;
            }

    .aba {
        animation: fade 0.2s ease-in-out;
    }

    @@keyframes fade {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

  

    .btn-pagar {
        display: inline-block;
        margin-top: 10px;
        padding: 10px 18px;
        background: #009ee3;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-pagar:hover {
     background: #007bb5;
    }

</style>

<script>
    function mostrarAba(nome, el) {

        document.querySelectorAll(".aba").forEach(div => {
            div.style.display = "none";
        });

        document.querySelectorAll(".sidebar a").forEach(link => {
            link.classList.remove("ativo");
        });


        document.getElementById(nome).style.display = "block";

        if (el) {
            el.classList.add("ativo");
        }
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        mostrarAba('dashboard');
    });
</script>