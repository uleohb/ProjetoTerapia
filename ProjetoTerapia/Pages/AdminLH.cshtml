@page
@model ProjetoTerapia.Pages.AdminLHModel

<div class="layout">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h3 class="logo">Ponto Saúde</h3>

        <a href="javascript:void(0)" onclick="mostrarAba('dashboard', this)">🏠 Dashboard</a>
        <a href="javascript:void(0)" onclick="mostrarAba('clinicas', this)">🏥 Clínicas</a>
        <a href="javascript:void(0)" onclick="mostrarAba('pagamentos', this)">💰 Pagamentos</a>

        <input type="hidden" id="abaAtual" value="dashboard" /> 

        <form method="post" asp-page-handler="Logout">
            <button class="btn-logout">Sair</button>
        </form>
    </div>

    <!-- CONTEÚDO -->
    <div class="conteudo">

        <div id="dashboard" class="aba">

            <h2 class="titulo-dashboard">📊 Painel Administrativo</h2>
            <p class="subtitulo-dashboard">
                Visão geral da plataforma Ponto Saúde
            </p>

            <div class="cards-dashboard">

                <div class="card-info">
                    <span class="card-label">Total de Clínicas</span>
                    <h3>@Model.TotalClinicas</h3>
                    <p>Cadastros realizados</p>
                </div>

                <div class="card-info">
                    <span class="card-label">Pendentes</span>
                    <h3>@Model.Pendentes</h3>
                    <p>Aguardando aprovação</p>
                </div>

                <div class="card-info">
                    <span class="card-label">Ativas</span>
                    <h3>@Model.Ativas</h3>
                    <p>Pagamentos confirmados</p>
                </div>

                <div class="card-info destaque">
                    <span class="card-label">Receita Anual</span>
                    <h3>R$ @Model.ReceitaPrevista</h3>
                    <p>Plano anual ativo</p>
                </div>

                <div class="card-info destaque-secundario">
                    <span class="card-label">Taxa de Conversão</span>
                    <h3>@Model.TaxaConversao%</h3>
                    <p>De aprovadas para pagas</p>
                </div>

            </div>

        

         </div>

        <hr />

        <div id="clinicas" class="aba" style="display:none">

            <h3>Gerenciar Clínicas</h3>
            
            <form method="get" class="filtros-admin"> @*faz a página recarregar*@

                <input type="hidden" name="aba" value="clinicas" /> @*enviar junto com o filtro quando a busca é utilizada*@

                <input type="text"
                       name="Busca"
                       value="@Model.Busca"
                       placeholder="Buscar clínica pelo nome..." />

                <select name="FiltroStatus">
                    <option value="">Todos os status</option>
                    <option value="pendente">Pendentes</option>
                    <option value="aprovado">Aprovadas</option>
                    <option value="ativo">Ativas</option>
                </select>

                <button type="submit" class="btn-filtrar">
                    Filtrar
                </button>

            </form>

            @foreach (var clinica in Model.Clinicas
                        .OrderBy(c => c.Aprovado)
                        .ThenBy(c => c.Pago))
            {
                <div class="card @(clinica.Pago ? "pago" : clinica.Aprovado ? "aprovado" : "pendente")">

                    <h5>@clinica.Nome</h5>
                    <p>@clinica.Descricao</p>
                    <p><strong>R$ @clinica.Valor</strong></p>
                    <p>@clinica.Endereco</p>

                    <p>
                        @(clinica.Aprovado ? "✅ Aprovado" : "⏳ Pendente")
                        |
                        @(clinica.Pago ? "💰 Pago" : "💸 Não pago")
                    </p>

                    <form method="post">
                        <input type="hidden" name="id" value="@clinica.Id" />

                        @if (!clinica.Aprovado)
                        {
                            <button name="acao" value="aprovar">Aprovar</button>
                        }

                        @if (clinica.Aprovado && !clinica.Pago)
                        {
                            <button name="acao" value="pagar">Confirmar pagamento</button>
                        }
                    </form>

                </div>
            }

        </div>

        <div id="pagamentos" class="aba" style="display:none">

            <h3>💰 Pagamentos</h3>

            @foreach (var clinica in Model.Clinicas.Where(c => c.Aprovado && !c.Pago))
            {
                <div class="card">

                    <h5>@clinica.Nome</h5>
                    <p><strong>Plano Ponto Saúde</strong></p>
                    <p>R$ 360 / ano (até 12x no cartão)</p>

                    <a href="https://mpago.la/33FgjZL" target="_blank" rel="noopener noreferrer" class="btn-pagar">
                        💳 Assinar plano anual
                    </a>

                    <p style="font-size:12px; color:gray;">
                        Pagamento 100% seguro via Mercado Pago
                    </p>

                    <p style="font-size:12px; color:#28a745;">
                        ✔ Após o pagamento, aguarde aprovação do sistema
                    </p>

                    <form method="post">
                        <input type="hidden" name="id" value="@clinica.Id" />
                        <button name="acao" value="pagar">Confirmar pagamento</button>
                    </form>

                </div>
            }

        </div>

    </div>
   
</div>

<style>

    body {
        margin: 0;
        background: #f5f7fa;
    }

    /* LAYOUT */
    .layout {
        display: flex;
    }

    /* SIDEBAR */
    .sidebar {
        width: 250px;
        min-height: 100vh;
        background: #0f172a;
        color: white;
        padding: 25px 20px;
        display: flex;
        flex-direction: column;
        box-shadow: 4px 0 10px rgba(0,0,0,0.05);
    }

    .logo {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 35px;
        color: white;
    }

    .sidebar a {
        display: block;
        padding: 12px 14px;
        margin-bottom: 10px;
        color: #cbd5e1;
        text-decoration: none;
        font-size: 15px;
        border-radius: 10px;
        transition: 0.2s;
    }

        .sidebar a:hover {
            background: #1e293b;
            color: white;
        }

        .sidebar a.ativo {
            background: #009ee3;
            color: white;
            font-weight: bold;
        }

   

    .btn-logout {
        margin-top: auto;
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #dc2626;
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-logout:hover {
            background: #b91c1c;
        }

    /* CONTEÚDO */
    .conteudo {
        flex: 1;
        padding: 30px;
    }

    /* CARDS INFO */
    .cards {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .card-info {
        background: white;
        padding: 20px;
        border-radius: 12px;
        flex: 1;
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

    /* LISTA */
    .card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 15px;
        box-shadow: 0 5px 10px rgba(0,0,0,0.08);
    }

        /* BOTÕES */
        .card button {
            margin-top: 10px;
            margin-right: 5px;
            padding: 6px 12px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

            .card button[value="aprovar"] {
                background: #28a745;
                color: white;
            }

            .card button[value="pagar"] {
                background: #ffc107;
            }

    .aba {
        animation: fade 0.2s ease-in-out;
    }

    @@keyframes fade {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

  

    .btn-pagar {
        display: inline-block;
        margin-top: 10px;
        padding: 10px 18px;
        background: #009ee3;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-pagar:hover {
     background: #007bb5;
    }

    .titulo-dashboard {
        font-size: 32px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .subtitulo-dashboard {
        color: #64748b;
        font-size: 16px;
        margin-bottom: 30px;
    }

    .cards-dashboard {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }

    .card-info {
        background: white;
        padding: 28px;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
        transition: 0.2s;
    }

        .card-info:hover {
            transform: translateY(-4px);
        }

    .card-label {
        display: block;
        font-size: 14px;
        color: #64748b;
        margin-bottom: 12px;
        font-weight: 600;
    }

    .card-info h3 {
        font-size: 34px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .card-info p {
        font-size: 14px;
        color: #94a3b8;
        margin: 0;
    }

    .card-info.destaque {
        background: linear-gradient(135deg, #00c6ff, #009ee3);
        color: white;
    }

        .card-info.destaque h3,
        .card-info.destaque .card-label,
        .card-info.destaque p {
            color: white;
        }

    .card-info.destaque-secundario {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: white;
    }

        .card-info.destaque-secundario h3,
        .card-info.destaque-secundario .card-label,
        .card-info.destaque-secundario p {
            color: white;
        }

    .filtros-admin {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

        .filtros-admin input,
        .filtros-admin select {
            padding: 12px 14px;
            border: 1px solid #dbeafe;
            border-radius: 10px;
            font-size: 14px;
            min-width: 220px;
            background: white;
        }

    .btn-filtrar {
        padding: 12px 20px;
        border: none;
        border-radius: 10px;
        background: #009ee3;
        color: white;
        font-weight: bold;
        cursor: pointer;
    }

        .btn-filtrar:hover {
            background: #007bb5;
        }

</style>

<script>
    function mostrarAba(nome, el) {

        document.querySelectorAll(".aba").forEach(div => {
            div.style.display = "none";
        });

        document.querySelectorAll(".sidebar a").forEach(link => {
            link.classList.remove("ativo");
        });


        document.getElementById(nome).style.display = "block";

        if (el) {
            el.classList.add("ativo");
        }
    }
</script>

<script>
        document.addEventListener("DOMContentLoaded", () => {
		const params = new URLSearchParams(window.location.search);  //le a URL e pega os parâmetros
        const aba = params.get("aba") || "dashboard";

        const link = [...document.querySelectorAll(".sidebar a")]
            .find(a => a.getAttribute("onclick")?.includes(aba));

		mostrarAba(aba, link); //chama a função para mostrar a aba correta com base no parâmetro da URL
    });
</script>