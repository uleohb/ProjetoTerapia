<script>
    var formParaEnviar = null;
    var acaoSelecionada = null;

    function mostrarAba(nome, el) {
        var abas = document.querySelectorAll(".aba");

        for (var i = 0; i < abas.length; i++) {
            abas[i].style.display = "none";
        }

        var abaSelecionada = document.getElementById(nome);

        if (abaSelecionada == null) {
            console.log("Aba não encontrada: " + nome);
            return;
        }

        abaSelecionada.style.display = "block";

        var links = document.querySelectorAll(".menu-admin a");

        for (var j = 0; j < links.length; j++) {
            links[j].classList.remove("ativo");
        }

        if (el != null) {
            el.classList.add("ativo");
        }

        var url = new URL(window.location.href);
        url.searchParams.set("aba", nome);
        window.history.replaceState({}, "", url);
    }

    document.addEventListener("DOMContentLoaded", function () {
        var params = new URLSearchParams(window.location.search);
        var aba = params.get("aba");

        if (aba == null || aba === "") {
            aba = "dashboard";
        }

        var links = document.querySelectorAll(".menu-admin a");
        var linkAtivo = null;

        for (var i = 0; i < links.length; i++) {
            var onclick = links[i].getAttribute("onclick");

            if (onclick != null && onclick.indexOf("'" + aba + "'") >= 0) {
                linkAtivo = links[i];
                break;
            }
        }

        mostrarAba(aba, linkAtivo);
    });

    function confirmarAcao(botao, mensagem) {
        formParaEnviar = botao.form;
        acaoSelecionada = botao.value;

        var textoModal = document.getElementById("textoModal");
        var modal = document.getElementById("modalConfirmacao");

        if (textoModal != null) {
            textoModal.innerText = "Deseja realmente " + mensagem;
        }

        if (modal != null) {
            modal.style.display = "flex";
        }

        return false;
    }

    function fecharModal() {
        var modal = document.getElementById("modalConfirmacao");

        if (modal != null) {
            modal.style.display = "none";
        }

        formParaEnviar = null;
        acaoSelecionada = null;
    }

    document.addEventListener("DOMContentLoaded", function () {
        var btnConfirmar = document.getElementById("btnConfirmarFinal");

        if (btnConfirmar != null) {
            btnConfirmar.addEventListener("click", function () {
                if (formParaEnviar != null && acaoSelecionada != null) {
                    var inputAcao = document.createElement("input");

                    inputAcao.type = "hidden";
                    inputAcao.name = "acao";
                    inputAcao.value = acaoSelecionada;

                    formParaEnviar.appendChild(inputAcao);
                    formParaEnviar.submit();
                }
            });
        }
    });
</script>