@page
@model ProjetoTerapia.Pages.AdminLHModel

<div class="layout">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h3 class="logo">PsiConecta</h3>

        <a href="#">🏠 Dashboard</a>
        <a href="#">🏥 Clínicas</a>
        <a href="#">💰 Pagamentos</a>

        <form method="post" asp-page-handler="Logout">
            <button class="btn-logout">Sair</button>
        </form>
    </div>

    <!-- CONTEÚDO -->
    <div class="conteudo">

        <h2>Dashboard Admnistrativo</h2>

        <div class="cards">

            <div class="card-info">
                <h4>Pendentes</h4>
                <p>@Model.Clinicas.Count(c => !c.Aprovado)</p>
            </div>

            <div class="card-info">
                <h4>Aprovados</h4>
                <p>@Model.Clinicas.Count(c => c.Aprovado && !c.Pago)</p>
            </div>

            <div class="card-info">
                <h4>Ativos</h4>
                <p>@Model.Clinicas.Count(c => c.Pago)</p>
            </div>

        </div>

        <hr />

        <h3>Gerenciar Clínicas</h3>

        @foreach (var clinica in Model.Clinicas
                .OrderBy(c => c.Aprovado)
                .ThenBy(c => c.Pago)
                .ThenBy(c => c.Nome))
        {
            <div class="card">

                <h5>@clinica.Nome</h5>
                <p>@clinica.Descricao</p>

                <p>
                    Status:
                    @(clinica.Aprovado ? "✅ Aprovado" : "⏳ Pendente")
                    |
                    @(clinica.Pago ? "💰 Pago" : "💸 Não pago")
                </p>

                <form method="post">
                    <input type="hidden" name="id" value="@clinica.Id" />

                    @if (!clinica.Aprovado)
                    {
                        <button name="acao" value="aprovar">Aprovar</button>
                    }

                    @if (clinica.Aprovado && !clinica.Pago)
                    {
                        <button name="acao" value="pagar">Confirmar pagamento</button>
                    }
                </form>

            </div>
        }

    </div>

</div>

<style>

    body {
        margin: 0;
        background: #f5f7fa;
    }

    /* LAYOUT */
    .layout {
        display: flex;
    }

    /* SIDEBAR */
    .sidebar {
        width: 220px;
        height: 100vh;
        background: #111;
        color: white;
        padding: 20px;
    }

    .logo {
        margin-bottom: 20px;
    }

    .sidebar a {
        display: block;
        margin: 12px 0;
        color: white;
        text-decoration: none;
        font-size: 15px;
    }

    .btn-logout {
        margin-top: 20px;
        width: 100%;
        padding: 8px;
        border: none;
        border-radius: 8px;
        background: red;
        color: white;
    }

    /* CONTEÚDO */
    .conteudo {
        flex: 1;
        padding: 30px;
    }

    /* CARDS INFO */
    .cards {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .card-info {
        background: white;
        padding: 20px;
        border-radius: 12px;
        flex: 1;
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

    /* LISTA */
    .card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 15px;
        box-shadow: 0 5px 10px rgba(0,0,0,0.08);
    }

        /* BOTÕES */
        .card button {
            margin-top: 10px;
            margin-right: 5px;
            padding: 6px 12px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

            .card button[value="aprovar"] {
                background: #28a745;
                color: white;
            }

            .card button[value="pagar"] {
                background: #ffc107;
            }

</style>