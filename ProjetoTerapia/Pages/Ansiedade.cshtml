@page
@model ProjetoTerapia.Pages.AnsiedadeModel

<h2>Teste de Ansiedade</h2>


<form method="post">

    @for (int i = 0; i < Model.Perguntas.Count; i++)
    {
        <div class="mb-3">
            <p>@Model.Perguntas[i]</p>

            <input type="radio" name="respostas[@i]" value="1" required> Sim
            <input type="radio" name="respostas[@i]" value="0"> Não
        </div>
    }

    <button type="submit" class="btn btn-secondary">
        Calcular Resultado
    </button>

</form>


@if (Model.Porcentagem >= 0)
{
    <hr />

    <h3>Resultado: @Model.Porcentagem%</h3>

    <div class="progress mb-3">
        <div class="progress-bar bg-secondary"
             style="width:@Model.Porcentagem%">
            @Model.Porcentagem%
        </div>
    </div>

    <h4>Nível: @Model.Nivel</h4>

    <p class="lead">@Model.Mensagem</p>

    @if (Model.Porcentagem > 50)
    {
        <div class="alert alert-warning">
            ⚠️ Recomendamos procurar ajuda profissional.
        </div>

        <h5>Clínicas recomendadas:</h5>

        <ul>
            <li>Clínica Vida Mental</li>
            <li>Centro Psicológico Equilíbrio</li>
            <li>Instituto Bem-Estar</li>
        </ul>
    }
    else
    {
        <div class="alert alert-success">
            💚 Você aparenta estar bem. Continue se cuidando!
        </div>
    }

    <p class="text-muted mt-3">
        Este teste é apenas informativo e não substitui avaliação profissional.
    </p>
}