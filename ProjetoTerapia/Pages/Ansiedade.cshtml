@page
@model ProjetoTerapia.Pages.AnsiedadeModel

<h2>Teste de Ansiedade</h2>

<form method="post">

    <p>Você se sente tenso frequentemente?</p>
    <input type="radio" name="q1" value="1"> Sim
    <input type="radio" name="q1" value="0"> Não

    <br><br>

    <p>Você tem dificuldade para relaxar?</p>
    <input type="radio" name="q2" value="1"> Sim
    <input type="radio" name="q2" value="0"> Não

    <br><br>

    <button type="submit" class="btn btn-success">
        Calcular Resultado
    </button>

</form>

@if (Model.Porcentagem >= 0)
{
    <hr />
    <h3>Resultado: @Model.Porcentagem% de sintomas</h3>

    <div class="progress">
        <div class="progress-bar" style="width:@Model.Porcentagem%">
            @Model.Porcentagem%
        </div>
    </div>
}